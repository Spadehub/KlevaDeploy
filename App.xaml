<Application x:Class="DeploymentApp.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:DeploymentApp.Converters">
    <!-- No StartupUri — window is created by the DI host in App.xaml.cs OnStartup -->
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- Dark theme loaded by default; ThemeService swaps this at runtime -->
                <ResourceDictionary Source="pack://application:,,,/Themes/Dark.xaml"/>
                <!-- Shared Win11 styles (depend on theme brushes above) -->
                <ResourceDictionary Source="pack://application:,,,/Themes/Win11Styles.xaml"/>
                <!-- Vector icons — must load after theme files so DynamicResource brushes resolve -->
                <ResourceDictionary Source="pack://application:,,,/Themes/Icons.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- Converters -->
            <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
            <conv:InverseBoolConverter x:Key="InverseBoolConverter"/>
            <conv:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibility"/>
            <conv:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>
            <conv:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
            <conv:BusyToTextConverter x:Key="BusyToTextConverter"/>
            <conv:OrderToDisplayConverter x:Key="OrderToDisplayConverter"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
