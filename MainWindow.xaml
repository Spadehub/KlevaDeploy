<Window x:Class="KlevaDeploy.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:behaviors="clr-namespace:KlevaDeploy.Behaviors"
        xmlns:models="clr-namespace:KlevaDeploy.Models"
        mc:Ignorable="d"
        Title="IT Deployment Configurator"
        Width="1200" Height="760"
        MinWidth="900" MinHeight="580"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="False"
        ResizeMode="CanResizeWithGrip"
        Background="{DynamicResource AppBackgroundBrush}"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        FontFamily="Segoe UI Variable, Segoe UI, sans-serif">

    <!-- ── WindowChrome: integrates with DWM compositor, eliminates 1px white border artifact ── -->
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="32"
                      ResizeBorderThickness="6"
                      GlassFrameThickness="0,0,0,1"
                      UseAeroCaptionButtons="False"
                      CornerRadius="8"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <!-- ── Preset card item style ── -->
        <Style x:Key="PresetCardItem" TargetType="ListBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="ItemBorder"
                                Background="{DynamicResource SurfaceBrush}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="{StaticResource CornerRadiusMedium}">
                            <ContentPresenter Margin="0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource HoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#1A0078D4"/>
                                <Setter TargetName="ItemBorder" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Window chrome button style ── -->
        <Style x:Key="ChromeButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="46"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Arrow"/>
            <Setter Property="WindowChrome.IsHitTestVisibleInChrome" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderThickness="0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource HoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource BorderBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Close button style (red hover) ── -->
        <Style x:Key="ChromeCloseButton" TargetType="Button" BasedOn="{StaticResource ChromeButton}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderThickness="0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#FFE81123"/>
                                <Setter Property="Foreground" Value="#FFFFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#FFC42B1C"/>
                                <Setter Property="Foreground" Value="#FFFFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Execution queue step item style ── -->
        <Style x:Key="QueueStepItem" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="{StaticResource CornerRadiusSmall}"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
            <Setter Property="Padding" Value="10,8"/>
        </Style>

        <Style x:Key="PresetGridCardToggleButton" TargetType="ToggleButton">
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment" Value="Stretch"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Grid SnapsToDevicePixels="True">
                            <Border x:Name="CardBorder"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="{StaticResource CornerRadiusCard}"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                  VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                            </Border>
                            <Border x:Name="SelectionBorder"
                                    BorderBrush="{DynamicResource AccentBrush}"
                                    BorderThickness="2"
                                    CornerRadius="{StaticResource CornerRadiusCard}"
                                    Opacity="0"
                                    IsHitTestVisible="False"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="CardBorder" Property="Background" Value="{DynamicResource HoverBrush}"/>
                                <Setter TargetName="CardBorder" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="CardBorder" Property="Background" Value="#1A0078D4"/>
                                <Setter TargetName="CardBorder" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="SelectionBorder"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="1"
                                                             Duration="0:0:0.14"
                                                             EasingFunction="{StaticResource EaseOut}"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="SelectionBorder"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="0"
                                                             Duration="0:0:0.12"
                                                             EasingFunction="{StaticResource EaseOut}"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsChecked" Value="True"/>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="CardBorder" Property="Background" Value="#1A0078D4"/>
                                <Setter TargetName="CardBorder" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- ═══════════════════════════════════════════════════════════
         OUTER BORDER — BorderThickness="0": WindowChrome handles the frame via DWM
    ═══════════════════════════════════════════════════════════ -->
    <Border BorderThickness="0">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="32"/>   <!-- Custom title bar (caption area) -->
                <RowDefinition Height="48"/>   <!-- Toolbar -->
                <RowDefinition Height="*"/>    <!-- Main content -->
                <RowDefinition Height="190"/>  <!-- Log panel -->
            </Grid.RowDefinitions>

            <!-- ══════════════════════════════════════════════════════
                 ROW 0 — CUSTOM TITLE BAR
                 WindowChrome.IsHitTestVisibleInChrome="True" so mouse events reach children
            ══════════════════════════════════════════════════════ -->
            <Border x:Name="TitleBar"
                    Grid.Row="0"
                    Background="{DynamicResource ToolbarBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="0,0,0,1"
                    WindowChrome.IsHitTestVisibleInChrome="True">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>  <!-- App icon + title -->
                        <ColumnDefinition Width="*"/>     <!-- Drag area -->
                        <ColumnDefinition Width="Auto"/>  <!-- Chrome buttons -->
                    </Grid.ColumnDefinitions>

                    <!-- App icon + title (non-interactive — part of drag area) -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal"
                                VerticalAlignment="Center" Margin="10,0,0,0"
                                IsHitTestVisible="False">
                        <Image Source="{DynamicResource IconPackage}"
                               Width="14" Height="14"
                               VerticalAlignment="Center"
                               Margin="0,0,6,0"
                               RenderOptions.BitmapScalingMode="HighQuality"/>
                        <TextBlock Text="IT Deployment Configurator"
                                   FontSize="12"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Window chrome buttons: Minimize / Maximize / Close -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal"
                                VerticalAlignment="Stretch">
                        <!-- Minimize -->
                        <Button x:Name="BtnMinimize"
                                Style="{StaticResource ChromeButton}"
                                ToolTip="Minimizza">
                            <TextBlock Text="&#x2014;" FontSize="10"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center"/>
                        </Button>
                        <!-- Maximize / Restore -->
                        <Button x:Name="BtnMaximize"
                                Style="{StaticResource ChromeButton}"
                                ToolTip="Ingrandisci">
                            <TextBlock x:Name="MaximizeIcon" Text="&#x25A1;" FontSize="11"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center"/>
                        </Button>
                        <!-- Close -->
                        <Button x:Name="BtnClose"
                                Style="{StaticResource ChromeCloseButton}"
                                ToolTip="Chiudi">
                            <TextBlock Text="&#x2715;" FontSize="11"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ══════════════════════════════════════════════════════
                 ROW 1 — TOOLBAR
            ══════════════════════════════════════════════════════ -->
            <Border Grid.Row="1"
                    Background="{DynamicResource ToolbarBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="0,0,0,1">
                <Grid Margin="12,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- App title -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <Image Source="{DynamicResource IconPackage}"
                               Width="18" Height="18"
                               VerticalAlignment="Center"
                               Margin="0,0,8,0"
                               RenderOptions.BitmapScalingMode="HighQuality"/>
                        <TextBlock Text="KlevaDeploy"
                                   Style="{StaticResource Win11TextSubtitle}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Demo Mode Toggle -->
                    <Border Grid.Column="1"
                            CornerRadius="{StaticResource CornerRadiusSmall}"
                            Padding="10,6"
                            Margin="16,0,0,0"
                            VerticalAlignment="Center">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="{DynamicResource SurfaceElevatedBrush}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsDemoMode}" Value="True">
                                        <Setter Property="Background" Value="#1AFF9800"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel Orientation="Horizontal">
                            <CheckBox IsChecked="{Binding IsDemoMode, Mode=TwoWay}"
                                      Style="{StaticResource Win11ToggleSwitch}"
                                      VerticalAlignment="Center"
                                      Margin="0,0,8,0">
                                <TextBlock Text="Modalità Demo"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsDemoMode}" Value="True">
                                                    <Setter Property="Foreground" Value="{DynamicResource WarningBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </CheckBox>
                            <!-- Demo mode indicator badge -->
                            <Border Background="{DynamicResource WarningBrush}"
                                    CornerRadius="3"
                                    Padding="5,2"
                                    VerticalAlignment="Center"
                                    Visibility="{Binding IsDemoMode, Converter={StaticResource BoolToVisibility}}">
                                <TextBlock Text="DATI TEST"
                                           Foreground="White"
                                           FontSize="9"
                                           FontWeight="Bold"/>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- Auth status badge -->
                    <Border Grid.Column="3"
                            CornerRadius="{StaticResource CornerRadiusSmall}"
                            Padding="10,4" Margin="0,0,8,0"
                            VerticalAlignment="Center">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="{DynamicResource SurfaceElevatedBrush}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsAuthenticated}" Value="True">
                                        <Setter Property="Background" Value="#1A4CAF50"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="8" Height="8" VerticalAlignment="Center" Margin="0,0,6,0">
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse">
                                        <Setter Property="Fill" Value="{DynamicResource TextDisabledBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsAuthenticated}" Value="True">
                                                <Setter Property="Fill" Value="{DynamicResource SuccessBrush}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>
                            <TextBlock VerticalAlignment="Center" FontSize="12"
                                       Foreground="{DynamicResource TextSecondaryBrush}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="Non autenticato"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsAuthenticated}" Value="True">
                                                <Setter Property="Text" Value="Autenticato"/>
                                                <Setter Property="Foreground" Value="{DynamicResource SuccessBrush}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <!-- Toolbar action buttons -->
                    <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,8,0">
                        <ProgressBar Width="80" Height="3"
                                     IsIndeterminate="True"
                                     Style="{StaticResource Win11ProgressBar}"
                                     Margin="0,0,12,0"
                                     Visibility="{Binding IsInitializing, Converter={StaticResource BoolToVisibility}}"/>

                        <!-- Login button -->
                        <Button Command="{Binding OpenLoginCommand}"
                                Style="{StaticResource Win11Button}"
                                Margin="0,0,6,0"
                                Padding="10,6">
                            <StackPanel Orientation="Horizontal">
                                <Image Source="{DynamicResource IconLock}"
                                       Width="14" Height="14"
                                       VerticalAlignment="Center"
                                       Margin="0,0,6,0"
                                       RenderOptions.BitmapScalingMode="HighQuality"/>
                                <TextBlock Text="Accedi" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <!-- Logout button -->
                        <Button Command="{Binding LogoutCommand}"
                                Style="{StaticResource Win11Button}"
                                Padding="10,6">
                            <StackPanel Orientation="Horizontal">
                                <Image Source="{DynamicResource IconUnlock}"
                                       Width="14" Height="14"
                                       VerticalAlignment="Center"
                                       Margin="0,0,6,0"
                                       RenderOptions.BitmapScalingMode="HighQuality"/>
                                <TextBlock Text="Esci" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <!-- Theme toggle -->
                    <Button Grid.Column="5"
                            Command="{Binding ToggleThemeCommand}"
                            ToolTip="{Binding ThemeToggleTooltip}"
                            Style="{StaticResource Win11Button}"
                            Width="36" Height="36" Padding="0"
                            VerticalAlignment="Center">
                        <Image Source="{DynamicResource ThemeToggleDrawingImage}"
                               Width="16" Height="16"
                               RenderOptions.BitmapScalingMode="HighQuality"/>
                    </Button>
                </Grid>
            </Border>

            <!-- ══════════════════════════════════════════════════════
                 ROW 2 — MAIN CONTENT
                 Left 3/4 : Deployment Presets
                 Right 1/4: Execution Queue
            ══════════════════════════════════════════════════════ -->
            <Grid Grid.Row="2" Margin="12,12,12,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="3*"/>  <!-- Left: presets -->
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="2*"/>  <!-- Right: execution queue -->
                </Grid.ColumnDefinitions>

                <!-- ────────────────────────────────────────────────
                     LEFT PANEL — Deployment Presets (3/5)
                ──────────────────────────────────────────────────── -->
                <Border Grid.Column="0" Style="{StaticResource Win11Card}" Padding="0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>  <!-- Card header -->
                            <RowDefinition Height="Auto"/>  <!-- Search bar -->
                            <RowDefinition Height="*"/>     <!-- Preset list -->
                            <RowDefinition Height="Auto"/>  <!-- Action bar -->
                        </Grid.RowDefinitions>

                        <!-- Card header -->
                        <Border Grid.Row="0"
                                Background="{DynamicResource SurfaceElevatedBrush}"
                                CornerRadius="8,8,0,0"
                                Padding="16,12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Orientation="Horizontal">
                                    <Image Source="{DynamicResource IconPackage}"
                                           Width="16" Height="16"
                                           VerticalAlignment="Center"
                                           Margin="0,0,8,0"
                                           RenderOptions.BitmapScalingMode="HighQuality"/>
                                    <TextBlock Text="Preset di Installazione"
                                               Style="{StaticResource Win11TextSubtitle}"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1"
                                            Orientation="Horizontal"
                                            VerticalAlignment="Center">
                                    <TextBlock Text="{Binding SelectedPresetCount, StringFormat='{}{0} selezionati'}"
                                               Style="{StaticResource Win11TextSecondary}"
                                               VerticalAlignment="Center"
                                               Margin="0,0,10,0"/>
                                    <Border Background="{DynamicResource BorderBrush}" Width="1" Height="18" Opacity="0.6" Margin="0,0,10,0"/>
                                    <Border Background="{DynamicResource SurfaceBrush}"
                                            BorderBrush="{DynamicResource BorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="10"
                                            Padding="3"
                                            Height="40"
                                            Width="124">
                                        <Grid Width="118"
                                              Height="34"
                                              ClipToBounds="True">
                                            <Canvas IsHitTestVisible="False">
                                                <Border x:Name="PresetViewIndicator"
                                                        Canvas.Left="{Binding IsPresetGridView, Converter={StaticResource PresetViewIndicatorLeftConverter}}"
                                                        Width="59"
                                                        Height="34"
                                                        CornerRadius="8"
                                                        Background="{DynamicResource AccentBrush}"
                                                        BorderBrush="{DynamicResource AccentBrush}"
                                                        BorderThickness="1"
                                                        Opacity="0.18"
                                                        IsHitTestVisible="False"/>
                                            </Canvas>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>

                                                <RadioButton Grid.Column="0"
                                                             GroupName="PresetViewMode"
                                                             IsChecked="{Binding IsPresetGridView, Converter={StaticResource InverseBoolConverter}, Mode=TwoWay}"
                                                             Background="Transparent"
                                                             BorderThickness="0"
                                                             Padding="0"
                                                             Cursor="Hand"
                                                             ToolTip="Vista elenco"
                                                             AutomationProperties.Name="Vista elenco"
                                                             HorizontalContentAlignment="Center"
                                                             VerticalContentAlignment="Center">
                                                    <RadioButton.Template>
                                                        <ControlTemplate TargetType="RadioButton">
                                                            <Border x:Name="HoverRoot"
                                                                    CornerRadius="8,0,0,8"
                                                                    Background="Transparent">
                                                                <ContentPresenter HorizontalAlignment="Center"
                                                                                  VerticalAlignment="Center"/>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="HoverRoot" Property="Background" Value="{DynamicResource HoverBrush}"/>
                                                                    <Setter TargetName="HoverRoot" Property="Opacity" Value="0.7"/>
                                                                </Trigger>
                                                                <Trigger Property="IsPressed" Value="True">
                                                                    <Setter TargetName="HoverRoot" Property="Opacity" Value="1"/>
                                                                </Trigger>
                                                                <Trigger Property="IsEnabled" Value="False">
                                                                    <Setter Property="Opacity" Value="0.4"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </RadioButton.Template>
                                                    <Viewbox Width="16" Height="16" Margin="0,1,0,0">
                                                        <Path Data="M4 6H20V8H4V6ZM4 11H20V13H4V11ZM4 16H20V18H4V16Z">
                                                            <Path.Style>
                                                                <Style TargetType="Path">
                                                                    <Setter Property="Fill" Value="{DynamicResource TextSecondaryBrush}"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsPresetGridView}" Value="False">
                                                                            <Setter Property="Fill" Value="{DynamicResource AccentBrush}"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Path.Style>
                                                        </Path>
                                                    </Viewbox>
                                                </RadioButton>

                                                <RadioButton Grid.Column="1"
                                                             GroupName="PresetViewMode"
                                                             IsChecked="{Binding IsPresetGridView, Mode=TwoWay}"
                                                             Background="Transparent"
                                                             BorderThickness="0"
                                                             Padding="0"
                                                             Cursor="Hand"
                                                             ToolTip="Vista griglia"
                                                             AutomationProperties.Name="Vista griglia"
                                                             HorizontalContentAlignment="Center"
                                                             VerticalContentAlignment="Center">
                                                    <RadioButton.Template>
                                                        <ControlTemplate TargetType="RadioButton">
                                                            <Border x:Name="HoverRoot"
                                                                    CornerRadius="0,8,8,0"
                                                                    Background="Transparent">
                                                                <ContentPresenter HorizontalAlignment="Center"
                                                                                  VerticalAlignment="Center"/>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="HoverRoot" Property="Background" Value="{DynamicResource HoverBrush}"/>
                                                                    <Setter TargetName="HoverRoot" Property="Opacity" Value="0.7"/>
                                                                </Trigger>
                                                                <Trigger Property="IsPressed" Value="True">
                                                                    <Setter TargetName="HoverRoot" Property="Opacity" Value="1"/>
                                                                </Trigger>
                                                                <Trigger Property="IsEnabled" Value="False">
                                                                    <Setter Property="Opacity" Value="0.4"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </RadioButton.Template>
                                                    <Viewbox Width="16" Height="16" Margin="0,1,0,0">
                                                        <Path Data="M4 4H10V10H4V4ZM14 4H20V10H14V4ZM4 14H10V20H4V14ZM14 14H20V20H14V14Z">
                                                            <Path.Style>
                                                                <Style TargetType="Path">
                                                                    <Setter Property="Fill" Value="{DynamicResource TextSecondaryBrush}"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsPresetGridView}" Value="True">
                                                                            <Setter Property="Fill" Value="{DynamicResource AccentBrush}"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Path.Style>
                                                        </Path>
                                                    </Viewbox>
                                                </RadioButton>
                                            </Grid>
                                        </Grid>
                                    </Border>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Search bar -->
                        <Border Grid.Row="1"
                                Background="{DynamicResource SurfaceBrush}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="0,1,0,1"
                                Padding="12,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0"
                                         Text="{Binding PresetSearchText, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource Win11TextBox}"
                                         Padding="28,6,8,6"
                                         FontSize="12">
                                    <TextBox.Resources>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                        </Style>
                                    </TextBox.Resources>
                                </TextBox>
                                <!-- Search icon -->
                                <Image Grid.Column="0"
                                       Source="{DynamicResource IconSearch}"
                                       Width="14" Height="14"
                                       HorizontalAlignment="Left"
                                       VerticalAlignment="Center"
                                       Margin="10,0,0,0"
                                       Opacity="0.55"
                                       IsHitTestVisible="False"
                                       RenderOptions.BitmapScalingMode="HighQuality"/>
                                <!-- Clear button -->
                                <Button Grid.Column="1"
                                        Content="✕"
                                        Command="{Binding ClearPresetSearchCommand}"
                                        Style="{StaticResource Win11Button}"
                                        Width="28" Height="28"
                                        Padding="0"
                                        Margin="4,0,0,0"
                                        FontSize="12"
                                        Visibility="{Binding PresetSearchText, Converter={StaticResource StringToVisibilityConverter}}"/>
                            </Grid>
                        </Border>

                        <Grid Grid.Row="2" x:Name="PresetsViewHost">
                            <ScrollViewer VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled"
                                          Padding="10"
                                          Visibility="{Binding IsPresetGridView, Converter={StaticResource InverseBoolToVisibility}}">

                                <ItemsControl ItemsSource="{Binding FilteredPresets}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid>
                                                <ToggleButton Style="{StaticResource PresetCardToggleButton}"
                                                              IsChecked="{Binding IsSelected, Mode=TwoWay}">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>  <!-- Icon -->
                                                            <ColumnDefinition Width="*"/>     <!-- Name + desc -->
                                                            <ColumnDefinition Width="Auto"/>  <!-- Checkmark badge / step count -->
                                                        </Grid.ColumnDefinitions>

                                                    <!-- Icon -->
                                                    <Border Grid.Column="0"
                                                            Width="40" Height="40"
                                                            CornerRadius="{StaticResource CornerRadiusMedium}"
                                                            Background="{DynamicResource SurfaceElevatedBrush}"
                                                            Margin="0,0,12,0">
                                                        <Grid>
                                                            <Image Width="22"
                                                                   Height="22"
                                                                   RenderOptions.BitmapScalingMode="HighQuality"
                                                                   Visibility="{Binding HasCustomIcon, Converter={StaticResource BoolToVisibility}}">
                                                                <Image.Source>
                                                                    <MultiBinding Converter="{StaticResource IconVariantToImageSourceConverter}">
                                                                        <Binding Path="CustomIconLightPath"/>
                                                                        <Binding Path="CustomIconDarkPath"/>
                                                                        <Binding Path="DataContext.IsDarkTheme"
                                                                                 RelativeSource="{RelativeSource AncestorType=Window}"/>
                                                                    </MultiBinding>
                                                                </Image.Source>
                                                            </Image>

                                                            <TextBlock Text="{Binding Icon, Mode=OneWay}"
                                                                       FontSize="18"
                                                                       FontFamily="Segoe UI Emoji"
                                                                       HorizontalAlignment="Center"
                                                                       VerticalAlignment="Center"
                                                                       Visibility="{Binding HasEmojiIcon, Converter={StaticResource BoolToVisibility}}"/>

                                                            <Image Source="{DynamicResource IconPackage}"
                                                                   Width="20"
                                                                   Height="20"
                                                                   Visibility="{Binding ShowDefaultIcon, Converter={StaticResource BoolToVisibility}}"
                                                                   RenderOptions.BitmapScalingMode="HighQuality"/>
                                                        </Grid>
                                                    </Border>

                                                    <!-- Name + description + category -->
                                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding Name, Mode=OneWay}"
                                                                   FontWeight="SemiBold"
                                                                   FontSize="13">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock" BasedOn="{StaticResource Win11TextBody}">
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                            <Setter Property="Foreground" Value="White"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                        <TextBlock Text="{Binding Description, Mode=OneWay}"
                                                                   FontSize="11"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   Margin="0,2,0,0">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock" BasedOn="{StaticResource Win11TextSecondary}">
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                            <Setter Property="Foreground" Value="#E0E0E0"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                        <TextBlock FontSize="11"
                                                                   Margin="0,2,0,0">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock" BasedOn="{StaticResource Win11TextSecondary}">
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                            <Setter Property="Foreground" Value="#D0D0D0"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                            <Run Text="{Binding Category, Mode=OneWay}"/>
                                                            <Run Text=" · "/>
                                                            <Run Text="{Binding StepCount, Mode=OneWay}"/>
                                                            <Run Text=" step"/>
                                                        </TextBlock>
                                                    </StackPanel>

                                                    <StackPanel Grid.Column="2"
                                                                Orientation="Horizontal"
                                                                HorizontalAlignment="Right"
                                                                VerticalAlignment="Top"
                                                                Margin="8,0,0,0">
                                                        <Border Background="{DynamicResource SurfaceElevatedBrush}"
                                                                CornerRadius="{StaticResource CornerRadiusSmall}"
                                                                Padding="8,3"
                                                                Visibility="{Binding IsSelected, Converter={StaticResource InverseBoolToVisibility}}">
                                                            <TextBlock Text="{Binding StepCount, StringFormat='{}{0} step', Mode=OneWay}"
                                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                                       FontSize="11"/>
                                                        </Border>
                                                        <Border Width="22" Height="22"
                                                                Background="White"
                                                                CornerRadius="11"
                                                                Visibility="{Binding IsSelected, Converter={StaticResource BoolToVisibility}}">
                                                            <TextBlock Text="✓"
                                                                       FontSize="12"
                                                                       FontWeight="Bold"
                                                                       Foreground="{DynamicResource AccentBrush}"
                                                                       HorizontalAlignment="Center"
                                                                       VerticalAlignment="Center"/>
                                                        </Border>

                                                        <Button Command="{Binding DataContext.EditPresetCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                CommandParameter="{Binding}"
                                                                Margin="8,0,0,0"
                                                                ToolTip="Modifica Preset"
                                                                Cursor="Hand"
                                                                Background="Transparent"
                                                                BorderThickness="0">
                                                            <Button.Template>
                                                                <ControlTemplate TargetType="Button">
                                                                    <Border Background="Transparent" Padding="4">
                                                                        <Viewbox x:Name="PencilIcon"
                                                                                 Width="14"
                                                                                 Height="14"
                                                                                 Opacity="0.7"
                                                                                 RenderTransformOrigin="0.5,0.5">
                                                                            <Viewbox.RenderTransform>
                                                                                <ScaleTransform ScaleX="1" ScaleY="1"/>
                                                                            </Viewbox.RenderTransform>
                                                                            <Path x:Name="PencilPath"
                                                                                  Fill="{DynamicResource TextSecondaryBrush}"
                                                                                  Data="M3 17.25V21h3.75L17.81 9.94l-3.75-3.75L3 17.25zM20.71 7.04c.39-.39.39-1.02 0-1.41l-2.34-2.34c-.39-.39-1.02-.39-1.41 0l-1.83 1.83 3.75 3.75 1.83-1.83z"/>
                                                                        </Viewbox>
                                                                    </Border>
                                                                    <ControlTemplate.Triggers>
                                                                        <MultiDataTrigger>
                                                                            <MultiDataTrigger.Conditions>
                                                                                <Condition Binding="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=IsMouseOver}" Value="True"/>
                                                                                <Condition Binding="{Binding RelativeSource={RelativeSource AncestorType=ToggleButton}, Path=IsChecked}" Value="True"/>
                                                                            </MultiDataTrigger.Conditions>
                                                                            <Setter TargetName="PencilIcon" Property="Opacity" Value="1.0"/>
                                                                            <Setter TargetName="PencilPath" Property="Fill" Value="White"/>
                                                                            <Setter TargetName="PencilIcon" Property="RenderTransform">
                                                                                <Setter.Value>
                                                                                    <ScaleTransform ScaleX="1.1" ScaleY="1.1"/>
                                                                                </Setter.Value>
                                                                            </Setter>
                                                                        </MultiDataTrigger>
                                                                        <MultiDataTrigger>
                                                                            <MultiDataTrigger.Conditions>
                                                                                <Condition Binding="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=IsMouseOver}" Value="True"/>
                                                                                <Condition Binding="{Binding RelativeSource={RelativeSource AncestorType=ToggleButton}, Path=IsChecked}" Value="False"/>
                                                                            </MultiDataTrigger.Conditions>
                                                                            <Setter TargetName="PencilIcon" Property="Opacity" Value="1.0"/>
                                                                            <Setter TargetName="PencilPath" Property="Fill" Value="{DynamicResource TextPrimaryBrush}"/>
                                                                            <Setter TargetName="PencilIcon" Property="RenderTransform">
                                                                                <Setter.Value>
                                                                                    <ScaleTransform ScaleX="1.1" ScaleY="1.1"/>
                                                                                </Setter.Value>
                                                                            </Setter>
                                                                        </MultiDataTrigger>
                                                                        <MultiDataTrigger>
                                                                            <MultiDataTrigger.Conditions>
                                                                                <Condition Binding="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=IsPressed}" Value="True"/>
                                                                                <Condition Binding="{Binding RelativeSource={RelativeSource AncestorType=ToggleButton}, Path=IsChecked}" Value="True"/>
                                                                            </MultiDataTrigger.Conditions>
                                                                            <Setter TargetName="PencilIcon" Property="Opacity" Value="0.85"/>
                                                                            <Setter TargetName="PencilPath" Property="Fill" Value="White"/>
                                                                            <Setter TargetName="PencilIcon" Property="RenderTransform">
                                                                                <Setter.Value>
                                                                                    <ScaleTransform ScaleX="0.95" ScaleY="0.95"/>
                                                                                </Setter.Value>
                                                                            </Setter>
                                                                        </MultiDataTrigger>
                                                                        <MultiDataTrigger>
                                                                            <MultiDataTrigger.Conditions>
                                                                                <Condition Binding="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=IsPressed}" Value="True"/>
                                                                                <Condition Binding="{Binding RelativeSource={RelativeSource AncestorType=ToggleButton}, Path=IsChecked}" Value="False"/>
                                                                            </MultiDataTrigger.Conditions>
                                                                            <Setter TargetName="PencilIcon" Property="Opacity" Value="0.85"/>
                                                                            <Setter TargetName="PencilPath" Property="Fill" Value="{DynamicResource TextPrimaryBrush}"/>
                                                                            <Setter TargetName="PencilIcon" Property="RenderTransform">
                                                                                <Setter.Value>
                                                                                    <ScaleTransform ScaleX="0.95" ScaleY="0.95"/>
                                                                                </Setter.Value>
                                                                            </Setter>
                                                                        </MultiDataTrigger>
                                                                    </ControlTemplate.Triggers>
                                                                </ControlTemplate>
                                                            </Button.Template>
                                                        </Button>
                                                    </StackPanel>
                                                    </Grid>
                                                </ToggleButton>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>

                            <ScrollViewer VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled"
                                          Padding="12,12,44,44"
                                          Visibility="{Binding IsPresetGridView, Converter={StaticResource BoolToVisibility}}">

                                <ItemsControl ItemsSource="{Binding FilteredPresets}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel Orientation="Horizontal"
                                                       HorizontalAlignment="Center"
                                                       ItemWidth="160"
                                                       ItemHeight="160"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Width="160" Height="160">
                                                <ToggleButton Style="{StaticResource PresetGridCardToggleButton}"
                                                              Width="150"
                                                              Height="150"
                                                              HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"
                                                              IsChecked="{Binding IsSelected, Mode=TwoWay}">
                                                    <Grid>
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="*"/>
                                                        </Grid.RowDefinitions>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>

                                                        <Border Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2"
                                                                Width="22" Height="22"
                                                                Background="White"
                                                                CornerRadius="11"
                                                                HorizontalAlignment="Left"
                                                                VerticalAlignment="Top"
                                                                Margin="-2,-2,0,0"
                                                                Panel.ZIndex="2"
                                                                Visibility="{Binding IsSelected, Converter={StaticResource BoolToVisibility}}"
                                                                IsHitTestVisible="False">
                                                            <TextBlock Text="✓"
                                                                       FontSize="12"
                                                                       FontWeight="Bold"
                                                                       Foreground="{DynamicResource AccentBrush}"
                                                                       HorizontalAlignment="Center"
                                                                       VerticalAlignment="Center"/>
                                                        </Border>

                                                        <Border Grid.Row="0" Grid.Column="0"
                                                                Width="56" Height="56"
                                                                CornerRadius="{StaticResource CornerRadiusMedium}"
                                                                Background="{DynamicResource SurfaceElevatedBrush}">
                                                            <Grid>
                                                                <Image Width="32"
                                                                       Height="32"
                                                                       RenderOptions.BitmapScalingMode="HighQuality"
                                                                       Visibility="{Binding HasCustomIcon, Converter={StaticResource BoolToVisibility}}">
                                                                    <Image.Source>
                                                                        <MultiBinding Converter="{StaticResource IconVariantToImageSourceConverter}">
                                                                            <Binding Path="CustomIconLightPath"/>
                                                                            <Binding Path="CustomIconDarkPath"/>
                                                                            <Binding Path="DataContext.IsDarkTheme"
                                                                                     RelativeSource="{RelativeSource AncestorType=Window}"/>
                                                                        </MultiBinding>
                                                                    </Image.Source>
                                                                </Image>

                                                                <TextBlock Text="{Binding Icon, Mode=OneWay}"
                                                                           FontSize="26"
                                                                           FontFamily="Segoe UI Emoji"
                                                                           HorizontalAlignment="Center"
                                                                           VerticalAlignment="Center"
                                                                           Visibility="{Binding HasEmojiIcon, Converter={StaticResource BoolToVisibility}}"/>

                                                                <Image Source="{DynamicResource IconPackage}"
                                                                       Width="30"
                                                                       Height="30"
                                                                       Visibility="{Binding ShowDefaultIcon, Converter={StaticResource BoolToVisibility}}"
                                                                       RenderOptions.BitmapScalingMode="HighQuality"/>
                                                            </Grid>
                                                        </Border>

                                                        <StackPanel Grid.Row="0" Grid.Column="1"
                                                                    Orientation="Horizontal"
                                                                    HorizontalAlignment="Right"
                                                                    VerticalAlignment="Top">
                                                            <Button Command="{Binding DataContext.EditPresetCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                    CommandParameter="{Binding}"
                                                                    ToolTip="Modifica Preset"
                                                                    Cursor="Hand"
                                                                    Background="Transparent"
                                                                    BorderThickness="0">
                                                                <Button.Template>
                                                                    <ControlTemplate TargetType="Button">
                                                                        <Border Background="Transparent" Padding="4">
                                                                            <Viewbox x:Name="PencilIcon"
                                                                                     Width="14"
                                                                                     Height="14"
                                                                                     Opacity="0.7"
                                                                                     RenderTransformOrigin="0.5,0.5">
                                                                                <Viewbox.RenderTransform>
                                                                                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                                                                                </Viewbox.RenderTransform>
                                                                                <Path x:Name="PencilPath"
                                                                                      Fill="{DynamicResource TextSecondaryBrush}"
                                                                                      Data="M3 17.25V21h3.75L17.81 9.94l-3.75-3.75L3 17.25zM20.71 7.04c.39-.39.39-1.02 0-1.41l-2.34-2.34c-.39-.39-1.02-.39-1.41 0l-1.83 1.83 3.75 3.75 1.83-1.83z"/>
                                                                            </Viewbox>
                                                                        </Border>
                                                                        <ControlTemplate.Triggers>
                                                                            <MultiDataTrigger>
                                                                                <MultiDataTrigger.Conditions>
                                                                                    <Condition Binding="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=IsMouseOver}" Value="True"/>
                                                                                    <Condition Binding="{Binding RelativeSource={RelativeSource AncestorType=ToggleButton}, Path=IsChecked}" Value="True"/>
                                                                                </MultiDataTrigger.Conditions>
                                                                                <Setter TargetName="PencilIcon" Property="Opacity" Value="1.0"/>
                                                                                <Setter TargetName="PencilPath" Property="Fill" Value="White"/>
                                                                                <Setter TargetName="PencilIcon" Property="RenderTransform">
                                                                                    <Setter.Value>
                                                                                        <ScaleTransform ScaleX="1.1" ScaleY="1.1"/>
                                                                                    </Setter.Value>
                                                                                </Setter>
                                                                            </MultiDataTrigger>
                                                                            <MultiDataTrigger>
                                                                                <MultiDataTrigger.Conditions>
                                                                                    <Condition Binding="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=IsMouseOver}" Value="True"/>
                                                                                    <Condition Binding="{Binding RelativeSource={RelativeSource AncestorType=ToggleButton}, Path=IsChecked}" Value="False"/>
                                                                                </MultiDataTrigger.Conditions>
                                                                                <Setter TargetName="PencilIcon" Property="Opacity" Value="1.0"/>
                                                                                <Setter TargetName="PencilPath" Property="Fill" Value="{DynamicResource TextPrimaryBrush}"/>
                                                                                <Setter TargetName="PencilIcon" Property="RenderTransform">
                                                                                    <Setter.Value>
                                                                                        <ScaleTransform ScaleX="1.1" ScaleY="1.1"/>
                                                                                    </Setter.Value>
                                                                                </Setter>
                                                                            </MultiDataTrigger>
                                                                            <MultiDataTrigger>
                                                                                <MultiDataTrigger.Conditions>
                                                                                    <Condition Binding="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=IsPressed}" Value="True"/>
                                                                                    <Condition Binding="{Binding RelativeSource={RelativeSource AncestorType=ToggleButton}, Path=IsChecked}" Value="True"/>
                                                                                </MultiDataTrigger.Conditions>
                                                                                <Setter TargetName="PencilIcon" Property="Opacity" Value="0.85"/>
                                                                                <Setter TargetName="PencilPath" Property="Fill" Value="White"/>
                                                                                <Setter TargetName="PencilIcon" Property="RenderTransform">
                                                                                    <Setter.Value>
                                                                                        <ScaleTransform ScaleX="0.95" ScaleY="0.95"/>
                                                                                    </Setter.Value>
                                                                                </Setter>
                                                                            </MultiDataTrigger>
                                                                            <MultiDataTrigger>
                                                                                <MultiDataTrigger.Conditions>
                                                                                    <Condition Binding="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=IsPressed}" Value="True"/>
                                                                                    <Condition Binding="{Binding RelativeSource={RelativeSource AncestorType=ToggleButton}, Path=IsChecked}" Value="False"/>
                                                                                </MultiDataTrigger.Conditions>
                                                                                <Setter TargetName="PencilIcon" Property="Opacity" Value="0.85"/>
                                                                                <Setter TargetName="PencilPath" Property="Fill" Value="{DynamicResource TextPrimaryBrush}"/>
                                                                                <Setter TargetName="PencilIcon" Property="RenderTransform">
                                                                                    <Setter.Value>
                                                                                        <ScaleTransform ScaleX="0.95" ScaleY="0.95"/>
                                                                                    </Setter.Value>
                                                                                </Setter>
                                                                            </MultiDataTrigger>
                                                                        </ControlTemplate.Triggers>
                                                                    </ControlTemplate>
                                                                </Button.Template>
                                                            </Button>
                                                        </StackPanel>

                                                        <TextBlock Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                                                                   Text="{Binding Name, Mode=OneWay}"
                                                                   Style="{StaticResource Win11TextBody}"
                                                                   FontWeight="SemiBold"
                                                                   FontSize="13"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   Margin="0,3,0,0"/>

                                                        <TextBlock Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                                                                   Text="{Binding Description, Mode=OneWay}"
                                                                   Style="{StaticResource Win11TextSecondary}"
                                                                   FontSize="11"
                                                                   TextWrapping="Wrap"
                                                                   TextTrimming="WordEllipsis"
                                                                   VerticalAlignment="Top"
                                                                   Margin="0,1,0,0"/>
                                                    </Grid>
                                                </ToggleButton>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Grid>

                        <!-- Action bar with Create Preset button -->
                        <Border Grid.Row="3"
                                Background="{DynamicResource SurfaceElevatedBrush}"
                                CornerRadius="0,0,8,8"
                                Padding="16,12">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Create New Preset button -->
                                <Button Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2"
                                        Command="{Binding OpenCreatePresetCommand}"
                                        Style="{StaticResource Win11AccentButton}"
                                        HorizontalAlignment="Stretch"
                                        Padding="12,8"
                                        Margin="0,0,0,8">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <TextBlock Text="➕" FontSize="16" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <TextBlock Text="Crea Nuovo Preset" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>

                                <!-- Overall status -->
                                <TextBlock Grid.Row="1" Grid.Column="0"
                                           Text="{Binding OverallStatus}"
                                           TextWrapping="Wrap"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           FontSize="12"/>

                                <!-- Run queue button -->
                                <Button Grid.Row="1" Grid.Column="1"
                                        Content="{Binding IsRunning, Converter={StaticResource BusyToTextConverter},
                                                  ConverterParameter='▶  Esegui Coda|⏳  Esecuzione…'}"
                                        Command="{Binding RunQueueCommand}"
                                        Style="{StaticResource Win11AccentButton}"
                                        Height="36" MinWidth="160"
                                        IsEnabled="{Binding IsRunning, Converter={StaticResource InverseBoolConverter}, FallbackValue=True}"/>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>

                <!-- Splitter -->
                <GridSplitter Grid.Column="1"
                              Width="8"
                              HorizontalAlignment="Stretch"
                              Background="Transparent"
                              Cursor="SizeWE"/>

                <!-- ────────────────────────────────────────────────
                     RIGHT PANEL — Execution Queue (2/5)
                ──────────────────────────────────────────────────── -->
                <Border Grid.Column="2" Style="{StaticResource Win11Card}" Padding="0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>  <!-- Card header -->
                            <RowDefinition Height="Auto"/>  <!-- Search bar + Create button -->
                            <RowDefinition Height="*"/>     <!-- Queue list -->
                        </Grid.RowDefinitions>

                        <!-- Card header -->
                        <Border Grid.Row="0"
                                Background="{DynamicResource SurfaceElevatedBrush}"
                                CornerRadius="8,8,0,0"
                                Padding="14,12">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <Image Source="{DynamicResource IconSettings}"
                                           Width="15" Height="15"
                                           VerticalAlignment="Center"
                                           Margin="0,0,7,0"
                                           RenderOptions.BitmapScalingMode="HighQuality"/>
                                    <TextBlock Text="Coda di Esecuzione"
                                               Style="{StaticResource Win11TextSubtitle}"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Search bar + Create Process button -->
                        <Border Grid.Row="1"
                                Background="{DynamicResource SurfaceBrush}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="0,1,0,1"
                                Padding="12,8">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Search bar -->
                                <Grid Grid.Row="0" Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox Grid.Column="0"
                                             Text="{Binding ProcessSearchText, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource Win11TextBox}"
                                             Padding="28,6,8,6"
                                             FontSize="12">
                                        <TextBox.Resources>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                            </Style>
                                        </TextBox.Resources>
                                    </TextBox>
                                    <!-- Search icon -->
                                    <Image Grid.Column="0"
                                           Source="{DynamicResource IconSearch}"
                                           Width="14" Height="14"
                                           HorizontalAlignment="Left"
                                           VerticalAlignment="Center"
                                           Margin="10,0,0,0"
                                           Opacity="0.55"
                                           IsHitTestVisible="False"
                                           RenderOptions.BitmapScalingMode="HighQuality"/>
                                    <!-- Clear button -->
                                    <Button Grid.Column="1"
                                            Content="✕"
                                            Command="{Binding ClearProcessSearchCommand}"
                                            Style="{StaticResource Win11Button}"
                                            Width="28" Height="28"
                                            Padding="0"
                                            Margin="4,0,0,0"
                                            FontSize="12"
                                            Visibility="{Binding ProcessSearchText, Converter={StaticResource StringToVisibilityConverter}}"/>
                                </Grid>

                                <!-- Create Process button -->
                                <Button Grid.Row="1"
                                        Command="{Binding CreateProcessCommand}"
                                        Style="{StaticResource Win11AccentButton}"
                                        HorizontalAlignment="Stretch"
                                        Padding="10,8">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <TextBlock Text="➕" FontSize="14" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                        <TextBlock Text="Nuovo Processo" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </Grid>
                        </Border>

                        <!-- Empty state -->
                        <TextBlock Grid.Row="2"
                                   Text="Seleziona uno o più preset per costruire la coda di esecuzione"
                                   Style="{StaticResource Win11TextSecondary}"
                                   TextWrapping="Wrap"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   TextAlignment="Center"
                                   Margin="16"
                                   Visibility="{Binding ExecutionQueue.Count,
                                                Converter={StaticResource NullToVisibilityConverter},
                                                ConverterParameter=Inverse}"/>

                        <!-- Queue items -->
                        <ScrollViewer Grid.Row="2"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled"
                                      Padding="8,8,8,8">
                            <ItemsControl ItemsSource="{Binding FilteredExecutionQueue}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <ToggleButton IsChecked="{Binding IsEnabled, Mode=TwoWay}">
                                            <ToggleButton.Style>
                                                <Style TargetType="ToggleButton" BasedOn="{StaticResource ProcessCardToggleButton}">
                                                    <Style.Triggers>
                                                        <!-- ISSUE 4 & 6 FIX: Grey out ONLY when not in selected preset AND not manually enabled -->
                                                        <!-- If IsEnabled=true, always show at full opacity (1.0) -->
                                                        <DataTrigger Binding="{Binding IsEnabled}" Value="True">
                                                            <Setter Property="Opacity" Value="1.0"/>
                                                        </DataTrigger>
                                                        <!-- If IsEnabled=false AND not in preset, grey out more -->
                                                        <MultiDataTrigger>
                                                            <MultiDataTrigger.Conditions>
                                                                <Condition Binding="{Binding IsEnabled}" Value="False"/>
                                                                <Condition Binding="{Binding IsInSelectedPreset}" Value="False"/>
                                                            </MultiDataTrigger.Conditions>
                                                            <Setter Property="Opacity" Value="0.3"/>
                                                        </MultiDataTrigger>
                                                        <!-- If IsEnabled=false BUT in preset (manually deselected), moderate grey -->
                                                        <MultiDataTrigger>
                                                            <MultiDataTrigger.Conditions>
                                                                <Condition Binding="{Binding IsEnabled}" Value="False"/>
                                                                <Condition Binding="{Binding IsInSelectedPreset}" Value="True"/>
                                                            </MultiDataTrigger.Conditions>
                                                            <Setter Property="Opacity" Value="0.5"/>
                                                        </MultiDataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </ToggleButton.Style>
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>  <!-- Checkbox indicator -->
                                                    <ColumnDefinition Width="Auto"/>  <!-- Status icon -->
                                                    <ColumnDefinition Width="*"/>     <!-- Name -->
                                                    <ColumnDefinition Width="Auto"/>  <!-- Kind label -->
                                                </Grid.ColumnDefinitions>

                                                <!-- Checkbox indicator (visual only) -->
                                                <Border Grid.Row="0" Grid.Column="0"
                                                        Width="22" Height="22"
                                                        CornerRadius="11"
                                                        BorderThickness="2"
                                                        VerticalAlignment="Center"
                                                        Margin="0,0,8,0">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
                                                            <Setter Property="Background" Value="Transparent"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsEnabled}" Value="True">
                                                                    <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                                                                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <TextBlock Text="✓"
                                                               FontSize="13"
                                                               FontWeight="Bold"
                                                               Foreground="White"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsEnabled}" Value="True">
                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Border>

                                                <!-- Status icon -->
                                                <TextBlock Grid.Row="0" Grid.Column="1"
                                                           Text="{Binding StatusIcon}"
                                                           FontSize="13"
                                                           VerticalAlignment="Center"
                                                           Margin="0,0,7,0"
                                                           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}"/>

                                                <!-- Process name -->
                                                <TextBlock Grid.Row="0" Grid.Column="2"
                                                           Text="{Binding Name}"
                                                           Style="{StaticResource Win11TextBody}"
                                                           FontWeight="SemiBold"
                                                           TextTrimming="CharacterEllipsis"
                                                           VerticalAlignment="Center"
                                                           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}"/>

                                                <!-- Action icons (Internet + Edit + Kind) -->
                                                <StackPanel Grid.Row="0" Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                                                    <!-- Internet Badge -->
                                                    <Border Background="#1A0078D4"
                                                            CornerRadius="3"
                                                            Padding="5,1"
                                                            Margin="6,0,0,0"
                                                            Visibility="{Binding Process.RequiresInternet, Converter={StaticResource BoolToVisibility}}">
                                                        <TextBlock Text="🌐 WEB"
                                                                   Foreground="{DynamicResource AccentBrush}"
                                                                   FontWeight="SemiBold"
                                                                   FontSize="9"/>
                                                    </Border>

                                                    <!-- Edit Button (Pencil) -->
                                                    <Button Command="{Binding DataContext.EditProcessCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                            CommandParameter="{Binding}"
                                                            Margin="6,0,0,0"
                                                            Cursor="Hand"
                                                            Background="Transparent"
                                                            BorderThickness="0"
                                                            ToolTip="Modifica Processo">
                                                        <Button.Template>
                                                            <ControlTemplate TargetType="Button">
                                                                <Border Background="Transparent" Padding="4">
                                                                    <Viewbox x:Name="PencilIcon"
                                                                             Width="14"
                                                                             Height="14"
                                                                             Opacity="0.85"
                                                                             RenderTransformOrigin="0.5,0.5">
                                                                        <Viewbox.RenderTransform>
                                                                            <ScaleTransform ScaleX="1" ScaleY="1"/>
                                                                        </Viewbox.RenderTransform>
                                                                        <Path x:Name="PencilPath"
                                                                              Fill="{DynamicResource TextSecondaryBrush}"
                                                                              Data="M3 17.25V21h3.75L17.81 9.94l-3.75-3.75L3 17.25zM20.71 7.04c.39-.39.39-1.02 0-1.41l-2.34-2.34c-.39-.39-1.02-.39-1.41 0l-1.83 1.83 3.75 3.75 1.83-1.83z"/>
                                                                    </Viewbox>
                                                                </Border>
                                                                <ControlTemplate.Triggers>
                                                                    <MultiDataTrigger>
                                                                        <MultiDataTrigger.Conditions>
                                                                            <Condition Binding="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=IsMouseOver}" Value="True"/>
                                                                            <Condition Binding="{Binding RelativeSource={RelativeSource AncestorType=ToggleButton}, Path=IsChecked}" Value="True"/>
                                                                        </MultiDataTrigger.Conditions>
                                                                        <Setter TargetName="PencilIcon" Property="Opacity" Value="1.0"/>
                                                                        <Setter TargetName="PencilPath" Property="Fill" Value="White"/>
                                                                        <Setter TargetName="PencilIcon" Property="RenderTransform">
                                                                            <Setter.Value>
                                                                                <ScaleTransform ScaleX="1.1" ScaleY="1.1"/>
                                                                            </Setter.Value>
                                                                        </Setter>
                                                                    </MultiDataTrigger>
                                                                    <MultiDataTrigger>
                                                                        <MultiDataTrigger.Conditions>
                                                                            <Condition Binding="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=IsMouseOver}" Value="True"/>
                                                                            <Condition Binding="{Binding RelativeSource={RelativeSource AncestorType=ToggleButton}, Path=IsChecked}" Value="False"/>
                                                                        </MultiDataTrigger.Conditions>
                                                                        <Setter TargetName="PencilIcon" Property="Opacity" Value="1.0"/>
                                                                        <Setter TargetName="PencilPath" Property="Fill" Value="{DynamicResource TextPrimaryBrush}"/>
                                                                        <Setter TargetName="PencilIcon" Property="RenderTransform">
                                                                            <Setter.Value>
                                                                                <ScaleTransform ScaleX="1.1" ScaleY="1.1"/>
                                                                            </Setter.Value>
                                                                        </Setter>
                                                                    </MultiDataTrigger>
                                                                    <MultiDataTrigger>
                                                                        <MultiDataTrigger.Conditions>
                                                                            <Condition Binding="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=IsPressed}" Value="True"/>
                                                                            <Condition Binding="{Binding RelativeSource={RelativeSource AncestorType=ToggleButton}, Path=IsChecked}" Value="True"/>
                                                                        </MultiDataTrigger.Conditions>
                                                                        <Setter TargetName="PencilIcon" Property="Opacity" Value="0.85"/>
                                                                        <Setter TargetName="PencilPath" Property="Fill" Value="White"/>
                                                                        <Setter TargetName="PencilIcon" Property="RenderTransform">
                                                                            <Setter.Value>
                                                                                <ScaleTransform ScaleX="0.95" ScaleY="0.95"/>
                                                                            </Setter.Value>
                                                                        </Setter>
                                                                    </MultiDataTrigger>
                                                                    <MultiDataTrigger>
                                                                        <MultiDataTrigger.Conditions>
                                                                            <Condition Binding="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=IsPressed}" Value="True"/>
                                                                            <Condition Binding="{Binding RelativeSource={RelativeSource AncestorType=ToggleButton}, Path=IsChecked}" Value="False"/>
                                                                        </MultiDataTrigger.Conditions>
                                                                        <Setter TargetName="PencilIcon" Property="Opacity" Value="0.85"/>
                                                                        <Setter TargetName="PencilPath" Property="Fill" Value="{DynamicResource TextPrimaryBrush}"/>
                                                                        <Setter TargetName="PencilIcon" Property="RenderTransform">
                                                                            <Setter.Value>
                                                                                <ScaleTransform ScaleX="0.95" ScaleY="0.95"/>
                                                                            </Setter.Value>
                                                                        </Setter>
                                                                    </MultiDataTrigger>
                                                                </ControlTemplate.Triggers>
                                                            </ControlTemplate>
                                                        </Button.Template>
                                                    </Button>

                                                    <!-- Kind label badge -->
                                                    <Border Background="{DynamicResource SurfaceElevatedBrush}"
                                                            CornerRadius="3"
                                                            Padding="5,1"
                                                            Margin="6,0,0,0">
                                                        <TextBlock Text="{Binding KindLabel}"
                                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                                   FontSize="10"/>
                                                    </Border>
                                                </StackPanel>

                                                <!-- Description + required badge + status text -->
                                                <StackPanel Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="3"
                                                            Orientation="Horizontal"
                                                            Margin="0,4,0,0">
                                                    <TextBlock Text="{Binding Description}"
                                                               Style="{StaticResource Win11TextSecondary}"
                                                               TextTrimming="CharacterEllipsis"
                                                               Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}"/>
                                                    <!-- Required badge -->
                                                    <Border Background="#1AFF9800"
                                                            CornerRadius="3"
                                                            Padding="5,1"
                                                            Margin="6,0,0,0"
                                                            VerticalAlignment="Center"
                                                            Visibility="{Binding IsRequired, Converter={StaticResource BoolToVisibility}}">
                                                        <TextBlock Text="Richiesto"
                                                                   Foreground="{DynamicResource WarningBrush}"
                                                                   FontSize="10"
                                                                   FontWeight="SemiBold"/>
                                                    </Border>
                                                    <!-- Status text -->
                                                    <TextBlock Text="{Binding StatusText}"
                                                               Style="{StaticResource Win11TextSecondary}"
                                                               Margin="8,0,0,0"
                                                               FontSize="10"
                                                               Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}"/>
                                                </StackPanel>
                                            </Grid>
                                        </ToggleButton>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>

            <!-- ══════════════════════════════════════════════════════
                 ROW 3 — LOG PANEL
            ══════════════════════════════════════════════════════ -->
            <Border Grid.Row="3"
                    Margin="12,0,12,12"
                    Style="{StaticResource Win11Card}"
                    Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Background="{DynamicResource SurfaceElevatedBrush}"
                            CornerRadius="8,8,0,0"
                            Padding="16,10">
                        <StackPanel Orientation="Horizontal">
                            <Image Source="{DynamicResource IconLog}"
                                   Width="14" Height="14"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0"
                                   RenderOptions.BitmapScalingMode="HighQuality"/>
                            <TextBlock Text="Log"
                                       Style="{StaticResource Win11TextSubtitle}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="1"
                            Background="{DynamicResource LogBackgroundBrush}"
                            CornerRadius="0,0,8,8">
                        <ListView ItemsSource="{Binding LogViewModel.LogEntries}"
                                  FontFamily="Cascadia Code, Consolas, monospace"
                                  FontSize="11"
                                  Background="Transparent"
                                  BorderThickness="0"
                                  Foreground="{DynamicResource LogTextBrush}"
                                  ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                  Padding="4">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="Ora" Width="72"
                                                    DisplayMemberBinding="{Binding Timestamp, StringFormat=HH:mm:ss}"/>
                                    <GridViewColumn Header="Livello" Width="64"
                                                    DisplayMemberBinding="{Binding Level}"/>
                                    <GridViewColumn Header="Messaggio" Width="900"
                                                    DisplayMemberBinding="{Binding Message}"/>
                                </GridView>
                            </ListView.View>
                        </ListView>
                    </Border>
                </Grid>
            </Border>

            <!-- ══════════════════════════════════════════════════════
                 SLIDING PANEL OVERLAY — Create Preset Panel
                 Appears from left with animation, overlays main content
            ══════════════════════════════════════════════════════ -->
            <Grid Grid.Row="0" Grid.RowSpan="4"
                  Visibility="{Binding IsCreatePresetPanelOpen, Converter={StaticResource BoolToVisibility}}"
                  x:Name="CreatePresetOverlay">
                
                <!-- Semi-transparent backdrop -->
                <Border Background="#80000000" x:Name="Backdrop">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Opacity" Value="0"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsCreatePresetPanelOpen}" Value="True">
                                    <DataTrigger.EnterActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                               To="1" Duration="0:0:0.2"
                                                               EasingFunction="{StaticResource EaseOut}"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </DataTrigger.EnterActions>
                                    <DataTrigger.ExitActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                               To="0" Duration="0:0:0.15"
                                                               EasingFunction="{StaticResource EaseIn}"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </DataTrigger.ExitActions>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                </Border>

                <!-- Sliding panel from left -->
                <Border x:Name="SlidingPanel"
                        Width="900"
                        HorizontalAlignment="Left"
                        Background="{DynamicResource AppBackgroundBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="0,0,1,0"
                        Effect="{StaticResource CardShadow}"
                        RenderTransformOrigin="0,0">
                    <Border.RenderTransform>
                        <TranslateTransform X="-900"/>
                    </Border.RenderTransform>
                    <Border.Style>
                        <Style TargetType="Border">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsCreatePresetPanelOpen}" Value="True">
                                    <DataTrigger.EnterActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(TranslateTransform.X)"
                                                               To="0" Duration="0:0:0.3">
                                                    <DoubleAnimation.EasingFunction>
                                                        <CubicEase EasingMode="EaseOut"/>
                                                    </DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </DataTrigger.EnterActions>
                                    <DataTrigger.ExitActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(TranslateTransform.X)"
                                                               To="-900" Duration="0:0:0.25">
                                                    <DoubleAnimation.EasingFunction>
                                                        <CubicEase EasingMode="EaseIn"/>
                                                    </DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </DataTrigger.ExitActions>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>

                    <Grid DataContext="{Binding CreatePresetViewModel}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>  <!-- Header -->
                            <RowDefinition Height="*"/>     <!-- Content -->
                            <RowDefinition Height="Auto"/>  <!-- Actions -->
                        </Grid.RowDefinitions>

                        <!-- Header -->
                        <Border Grid.Row="0"
                                Background="{DynamicResource SurfaceElevatedBrush}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="0,0,0,1"
                                Padding="20,16">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                
                                <StackPanel Grid.Column="0">
                                    <TextBlock Margin="0,0,0,4">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock" BasedOn="{StaticResource Win11TextTitle}">
                                                <Setter Property="Text" Value="Crea Nuovo Preset"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsEditMode}" Value="True">
                                                        <Setter Property="Text" Value="Modifica Preset"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <TextBlock>
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock" BasedOn="{StaticResource Win11TextSecondary}">
                                                <Setter Property="Text" Value="Configura un nuovo preset di installazione personalizzato"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsEditMode}" Value="True">
                                                        <Setter Property="Text" Value="Modifica il preset di installazione"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>

                                <!-- Close button -->
                                <Button Grid.Column="1"
                                        Command="{Binding CancelCommand}"
                                        Style="{StaticResource Win11CloseButton}"
                                        Width="36" Height="36"
                                        Padding="0"
                                        ToolTip="Chiudi">
                                    <TextBlock Text="✕" FontSize="16"/>
                                </Button>
                            </Grid>
                        </Border>

                        <!-- Content -->
                        <Grid Grid.Row="1">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0"
                                    Background="#1AFF3333"
                                    BorderBrush="{DynamicResource ErrorBrush}"
                                    BorderThickness="1"
                                    CornerRadius="{StaticResource CornerRadiusSmall}"
                                    Padding="12,8"
                                    Margin="20,16,20,0"
                                    Panel.ZIndex="100"
                                    Visibility="{Binding ValidationError, Converter={StaticResource StringToVisibilityConverter}}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="⚠️" FontSize="16" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBlock Text="{Binding ValidationError}"
                                               Foreground="{DynamicResource ErrorBrush}"
                                               TextWrapping="Wrap"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>

                            <ScrollViewer Grid.Row="1"
                                          VerticalScrollBarVisibility="Auto"
                                          Padding="20,16">
                            <StackPanel>

                                <TextBlock Text="Nome *" Style="{StaticResource Win11TextBody}" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                <Grid Margin="0,0,0,16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <Button Grid.Column="0"
                                            Command="{Binding OpenIconPickerCommand}"
                                            Style="{StaticResource Win11Button}"
                                            Width="44" Height="44"
                                            Padding="0"
                                            Margin="0,0,10,0"
                                            ToolTip="Seleziona icona">
                                        <Grid>
                                            <Image Width="22"
                                                   Height="22"
                                                   RenderOptions.BitmapScalingMode="HighQuality"
                                                   Visibility="{Binding HasCustomIcon, Converter={StaticResource BoolToVisibility}}">
                                                <Image.Source>
                                                    <MultiBinding Converter="{StaticResource IconVariantToImageSourceConverter}">
                                                        <Binding Path="CustomIconLightPath"/>
                                                        <Binding Path="CustomIconDarkPath"/>
                                                        <Binding Path="DataContext.IsDarkTheme"
                                                                 RelativeSource="{RelativeSource AncestorType=Window}"/>
                                                    </MultiBinding>
                                                </Image.Source>
                                            </Image>

                                            <TextBlock Text="{Binding Icon}"
                                                       FontSize="18"
                                                       FontFamily="Segoe UI Emoji"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       Visibility="{Binding HasCustomIcon, Converter={StaticResource InverseBoolToVisibility}}"/>
                                        </Grid>
                                    </Button>

                                    <TextBox Grid.Column="1"
                                             Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource Win11TextBox}"/>
                                </Grid>

                                <TextBlock Text="Descrizione" Style="{StaticResource Win11TextBody}" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource Win11TextBox}"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         MinHeight="60"
                                         VerticalScrollBarVisibility="Auto"
                                         Margin="0,0,0,16"/>

                                <!-- Categoria -->
                                <TextBlock Text="Categoria" Style="{StaticResource Win11TextBody}" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                <TextBox Text="{Binding Category, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource Win11TextBox}"
                                         Margin="0,0,0,20"/>

                                <!-- Process Selection Section -->
                                <TextBlock Text="Processi *" Style="{StaticResource Win11TextBody}" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                <TextBlock Text="Trascina o sposta i processi nella colonna di destra per includerli nel preset."
                                           Style="{StaticResource Win11TextSecondary}"
                                           Margin="0,0,0,12"/>

                                <!-- Two Columns Layout for Process Selection -->
                                <Grid Height="500">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="16"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Left Column: Available Processes -->
                                    <Border Grid.Column="0" 
                                            Style="{StaticResource Win11Card}" 
                                            Padding="0">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>
                                            
                                            <Border Background="{DynamicResource SurfaceElevatedBrush}" Padding="10,8" CornerRadius="8,8,0,0">
                                                <TextBlock Text="Disponibili"
                                                           FontWeight="SemiBold"
                                                           FontSize="14"
                                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                                            </Border>

                                            <Grid Grid.Row="1" Margin="8">
                                                <TextBox Grid.Column="0"
                                                         Text="{Binding AvailableSearchText, UpdateSourceTrigger=PropertyChanged}"
                                                         Style="{StaticResource Win11TextBox}"
                                                         Padding="28,4,8,4"
                                                         FontSize="14"/>
                                                <Image Source="{DynamicResource IconSearch}"
                                                       Width="14" Height="14"
                                                       HorizontalAlignment="Left"
                                                       VerticalAlignment="Center"
                                                       Margin="10,0,0,0"
                                                       Opacity="0.55"
                                                       IsHitTestVisible="False"
                                                       RenderOptions.BitmapScalingMode="HighQuality"/>
                                            </Grid>

                                            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                                                <ItemsControl ItemsSource="{Binding FilteredAvailableProcesses}">
                                                    <ItemsControl.ItemContainerStyle>
                                                        <Style TargetType="ContentPresenter">
                                                            <Setter Property="HorizontalAlignment" Value="Stretch"/>
                                                        </Style>
                                                    </ItemsControl.ItemContainerStyle>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <ToggleButton Command="{Binding DataContext.ActivateProcessCommand, RelativeSource={RelativeSource AncestorType=ScrollViewer}}"
                                                                          CommandParameter="{Binding}"
                                                                          Style="{StaticResource ProcessCardToggleButton}"
                                                                          Margin="4" Padding="8,6">
                                                                <Grid>
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="*"/>
                                                                        <ColumnDefinition Width="Auto"/>
                                                                    </Grid.ColumnDefinitions>
                                                                    <StackPanel>
                                                                        <TextBlock Text="{Binding Name}"
                                                                                   FontWeight="SemiBold"
                                                                                   FontSize="14"
                                                                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                                        <TextBlock Text="{Binding Description}"
                                                                                   FontSize="12"
                                                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                                                   TextTrimming="CharacterEllipsis"/>
                                                                    </StackPanel>
                                                                    <TextBlock Grid.Column="1"
                                                                               Text="➜"
                                                                               FontSize="14"
                                                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                                                               VerticalAlignment="Center"
                                                                               Margin="4,0,0,0"/>
                                                                </Grid>
                                                            </ToggleButton>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </ScrollViewer>
                                        </Grid>
                                    </Border>

                                    <!-- Center Arrows -->
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0">
                                        <TextBlock Text="⇄" FontSize="18" Opacity="0.3" HorizontalAlignment="Center"/>
                                    </StackPanel>

                                    <!-- Right Column: Selected Processes -->
                                    <Border Grid.Column="2" 
                                            Style="{StaticResource Win11Card}" 
                                            Padding="0">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>

                                            <Border Background="{DynamicResource SurfaceElevatedBrush}" Padding="10,8" CornerRadius="8,8,0,0">
                                                <TextBlock Text="Selezionati (Coda)"
                                                           FontWeight="SemiBold"
                                                           FontSize="14"
                                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                                            </Border>

                                            <Grid Grid.Row="1" Margin="8">
                                                <TextBox Grid.Column="0"
                                                         Text="{Binding SelectedSearchText, UpdateSourceTrigger=PropertyChanged}"
                                                         Style="{StaticResource Win11TextBox}"
                                                         Padding="28,4,8,4"
                                                         FontSize="14"/>
                                                <Image Source="{DynamicResource IconSearch}"
                                                       Width="14" Height="14"
                                                       HorizontalAlignment="Left"
                                                       VerticalAlignment="Center"
                                                       Margin="10,0,0,0"
                                                       Opacity="0.55"
                                                       IsHitTestVisible="False"
                                                       RenderOptions.BitmapScalingMode="HighQuality"/>
                                            </Grid>

                                            <ListBox Grid.Row="2"
                                                     ItemsSource="{Binding FilteredSelectedProcesses}"
                                                     Background="Transparent"
                                                     BorderThickness="0"
                                                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                                                     HorizontalContentAlignment="Stretch"
                                                     behaviors:DragDropReorder.IsEnabled="{Binding IsSelectedReorderEnabled}"
                                                     behaviors:DragDropReorder.ReorderCommand="{Binding ReorderSelectedProcessCommand}">
                                                <ListBox.ItemContainerStyle>
                                                    <Style TargetType="ListBoxItem">
                                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                                    </Style>
                                                </ListBox.ItemContainerStyle>
                                                <ListBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Background="{DynamicResource SurfaceBrush}"
                                                                BorderBrush="{DynamicResource BorderBrush}"
                                                                BorderThickness="1"
                                                                CornerRadius="4"
                                                                Margin="4"
                                                                Padding="6"
                                                                HorizontalAlignment="Stretch">
                                                            <Border.Style>
                                                                <Style TargetType="Border">
                                                                    <Setter Property="Opacity" Value="1"/>
                                                                    <Setter Property="Effect" Value="{x:Null}"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=(behaviors:DragDropReorder.IsDropTarget)}" Value="True">
                                                                            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                                                            <Setter Property="BorderThickness" Value="2"/>
                                                                        </DataTrigger>
                                                                    <DataTrigger Binding="{Binding IsDragging}" Value="True">
                                                                        <Setter Property="Opacity" Value="0.35"/>
                                                                        <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                                                    </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Border.Style>
                                                            <Grid>
                                                                <Grid.RowDefinitions>
                                                                    <RowDefinition Height="Auto"/>
                                                                    <RowDefinition Height="Auto"/>
                                                                </Grid.RowDefinitions>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                </Grid.ColumnDefinitions>

                                                                <Button Grid.Column="0"
                                                                        Command="{Binding DataContext.DeactivateProcessCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                                        CommandParameter="{Binding}"
                                                                        Style="{StaticResource Win11Button}"
                                                                        Width="28" Height="28" Padding="0" Margin="0,0,8,0">
                                                                    <TextBlock Text="⬅"
                                                                               FontSize="14"
                                                                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                                </Button>

                                                                <StackPanel Grid.Column="1">
                                                                    <TextBlock Text="{Binding Name}"
                                                                               FontWeight="SemiBold"
                                                                               FontSize="14"
                                                                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                                    <CheckBox IsChecked="{Binding IsRequired}" Margin="0,4,0,0">
                                                                        <TextBlock Text="Richiesto"
                                                                                   FontSize="12"
                                                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                                                   Opacity="0.7"/>
                                                                    </CheckBox>
                                                                </StackPanel>

                                                                <StackPanel Grid.Column="2" Orientation="Horizontal">
                                                                    <Button Command="{Binding DataContext.MoveProcessUpCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                                            CommandParameter="{Binding}"
                                                                            Style="{StaticResource Win11Button}"
                                                                            Width="28" Height="28" Padding="0" Margin="0,0,4,0">
                                                                        <TextBlock Text="▲"
                                                                                   FontSize="14"
                                                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                                                   VerticalAlignment="Center"
                                                                                   HorizontalAlignment="Center"/>
                                                                    </Button>
                                                                    <Button Command="{Binding DataContext.MoveProcessDownCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                                            CommandParameter="{Binding}"
                                                                            Style="{StaticResource Win11Button}"
                                                                            Width="28" Height="28" Padding="0">
                                                                        <TextBlock Text="▼"
                                                                                   FontSize="14"
                                                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                                                   VerticalAlignment="Center"
                                                                                   HorizontalAlignment="Center"/>
                                                                    </Button>
                                                                </StackPanel>
                                                            </Grid>
                                                        </Border>
                                                    </DataTemplate>
                                                </ListBox.ItemTemplate>
                                            </ListBox>
                                        </Grid>
                                    </Border>
                                </Grid>
                            </StackPanel>
                            </ScrollViewer>

                            <Grid Background="#80000000"
                                  Visibility="{Binding IsIconPickerOpen, Converter={StaticResource BoolToVisibility}}">
                                <Border Style="{StaticResource Win11Card}"
                                        Padding="16"
                                        Width="620"
                                        MaxHeight="680"
                                        VerticalAlignment="Center"
                                        HorizontalAlignment="Center">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <Grid Grid.Row="0" Margin="0,0,0,12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Text="Seleziona icona"
                                                       Style="{StaticResource Win11TextSubtitle}"
                                                       FontWeight="SemiBold"/>

                                            <Button Grid.Column="1"
                                                    Command="{Binding CloseIconPickerCommand}"
                                                    Style="{StaticResource Win11CloseButton}"
                                                    Width="32"
                                                    Height="32"
                                                    Padding="0">
                                                <TextBlock Text="✕" FontSize="14"/>
                                            </Button>
                                        </Grid>

                                        <ScrollViewer Grid.Row="1"
                                                      VerticalScrollBarVisibility="Auto">
                                            <StackPanel>
                                                <TextBlock Text="Emoji"
                                                           Style="{StaticResource Win11TextBody}"
                                                           FontWeight="SemiBold"
                                                           Margin="0,0,0,8"/>

                                                <ItemsControl ItemsSource="{Binding AvailableIcons}"
                                                              Margin="0,0,0,16">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <WrapPanel/>
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Button Command="{Binding DataContext.SelectEmojiIconCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                    CommandParameter="{Binding}"
                                                                    Style="{StaticResource Win11Button}"
                                                                    Width="44"
                                                                    Height="44"
                                                                    Padding="0"
                                                                    Margin="0,0,8,8">
                                                                <TextBlock Text="{Binding}"
                                                                           FontSize="20"
                                                                           FontFamily="Segoe UI Emoji"
                                                                           HorizontalAlignment="Center"
                                                                           VerticalAlignment="Center"/>
                                                            </Button>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>

                                                <TextBlock Text="Icone caricate"
                                                           Style="{StaticResource Win11TextBody}"
                                                           FontWeight="SemiBold"
                                                           Margin="0,0,0,8"/>

                                                <Border Background="{DynamicResource SurfaceElevatedBrush}"
                                                        BorderBrush="{DynamicResource BorderBrush}"
                                                        BorderThickness="1"
                                                        CornerRadius="{StaticResource CornerRadiusSmall}"
                                                        Padding="12"
                                                        Margin="0,0,0,12">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>

                                                        <Border Width="40"
                                                                Height="40"
                                                                CornerRadius="{StaticResource CornerRadiusSmall}"
                                                                Background="{DynamicResource SurfaceBrush}"
                                                                BorderBrush="{DynamicResource BorderBrush}"
                                                                BorderThickness="1"
                                                                VerticalAlignment="Center"
                                                                Margin="0,0,12,0">
                                                            <Grid>
                                                                <Image Width="22"
                                                                       Height="22"
                                                                       RenderOptions.BitmapScalingMode="HighQuality"
                                                                       Visibility="{Binding HasCustomIcon, Converter={StaticResource BoolToVisibility}}">
                                                                    <Image.Source>
                                                                        <MultiBinding Converter="{StaticResource IconVariantToImageSourceConverter}">
                                                                            <Binding Path="CustomIconLightPath"/>
                                                                            <Binding Path="CustomIconDarkPath"/>
                                                                            <Binding Path="DataContext.IsDarkTheme"
                                                                                     RelativeSource="{RelativeSource AncestorType=Window}"/>
                                                                        </MultiBinding>
                                                                    </Image.Source>
                                                                </Image>

                                                                <TextBlock Text="{Binding Icon}"
                                                                           FontSize="18"
                                                                           FontFamily="Segoe UI Emoji"
                                                                           HorizontalAlignment="Center"
                                                                           VerticalAlignment="Center"
                                                                           Visibility="{Binding HasCustomIcon, Converter={StaticResource InverseBoolToVisibility}}"/>
                                                            </Grid>
                                                        </Border>

                                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                            <CheckBox Content="Scegli icona diversa per tema"
                                                                      IsChecked="{Binding UseSeparateThemeIcons}"
                                                                      Style="{StaticResource Win11ToggleSwitch}"/>
                                                            <TextBlock Text="Se attivo, puoi scegliere un’icona per tema chiaro e una per tema scuro."
                                                                       Style="{StaticResource Win11TextSecondary}"
                                                                       FontSize="11"
                                                                       Margin="0,4,0,0"/>
                                                        </StackPanel>

                                                        <Button Grid.Column="2"
                                                                Content="Importa"
                                                                Command="{Binding ImportLibraryIconCommand}"
                                                                Style="{StaticResource Win11Button}"
                                                                Height="36"
                                                                MinWidth="120"
                                                                VerticalAlignment="Center"/>
                                                    </Grid>
                                                </Border>

                                                <StackPanel Orientation="Horizontal"
                                                            Margin="0,0,0,12"
                                                            Visibility="{Binding UseSeparateThemeIcons, Converter={StaticResource BoolToVisibility}}">
                                                    <Button Content="Chiaro"
                                                            Command="{Binding SetIconPickerTargetLightCommand}"
                                                            Height="32"
                                                            MinWidth="120">
                                                        <Button.Style>
                                                            <Style TargetType="Button" BasedOn="{StaticResource Win11Button}">
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsIconPickerTargetDark}" Value="False">
                                                                        <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                                                                        <Setter Property="Foreground" Value="White"/>
                                                                        <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Button.Style>
                                                    </Button>
                                                    <Button Content="Scuro"
                                                            Command="{Binding SetIconPickerTargetDarkCommand}"
                                                            Height="32"
                                                            MinWidth="120"
                                                            Margin="8,0,0,0">
                                                        <Button.Style>
                                                            <Style TargetType="Button" BasedOn="{StaticResource Win11Button}">
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsIconPickerTargetDark}" Value="True">
                                                                        <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                                                                        <Setter Property="Foreground" Value="White"/>
                                                                        <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Button.Style>
                                                    </Button>
                                                </StackPanel>

                                                <ItemsControl ItemsSource="{Binding LibraryIcons}"
                                                              Margin="0,0,0,16">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <WrapPanel/>
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Button Command="{Binding DataContext.SelectLibraryIconCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                    CommandParameter="{Binding}"
                                                                    Style="{StaticResource Win11Button}"
                                                                    Width="56"
                                                                    Height="56"
                                                                    Padding="0"
                                                                    Margin="0,0,8,8">
                                                                <Image Stretch="Uniform"
                                                                       RenderOptions.BitmapScalingMode="HighQuality"
                                                                       Width="28"
                                                                       Height="28">
                                                                    <Image.Source>
                                                                        <MultiBinding Converter="{StaticResource IconVariantToImageSourceConverter}">
                                                                            <Binding Path="LightPath"/>
                                                                            <Binding Path="DarkPath"/>
                                                                            <Binding Path="DataContext.IsDarkTheme"
                                                                                     RelativeSource="{RelativeSource AncestorType=Window}"/>
                                                                        </MultiBinding>
                                                                    </Image.Source>
                                                                </Image>
                                                            </Button>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>

                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="12"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>

                                                    <StackPanel Grid.Column="0">
                                                        <TextBlock Text="Chiaro"
                                                                   Style="{StaticResource Win11TextSecondary}"
                                                                   Margin="0,0,0,6"/>
                                                        <Border Background="{DynamicResource SurfaceElevatedBrush}"
                                                                BorderBrush="{DynamicResource BorderBrush}"
                                                                BorderThickness="1"
                                                                CornerRadius="{StaticResource CornerRadiusSmall}"
                                                                Width="96"
                                                                Height="96"
                                                                HorizontalAlignment="Left">
                                                            <Image Stretch="Uniform"
                                                                   RenderOptions.BitmapScalingMode="HighQuality">
                                                                <Image.Source>
                                                                    <MultiBinding Converter="{StaticResource IconVariantToImageSourceConverter}">
                                                                        <Binding Path="CustomIconLightPath"/>
                                                                        <Binding Path="CustomIconDarkPath"/>
                                                                        <Binding Source="False"/>
                                                                    </MultiBinding>
                                                                </Image.Source>
                                                            </Image>
                                                        </Border>
                                                    </StackPanel>

                                                    <StackPanel Grid.Column="2">
                                                        <TextBlock Text="Scuro"
                                                                   Style="{StaticResource Win11TextSecondary}"
                                                                   Margin="0,0,0,6"/>
                                                        <Border Background="{DynamicResource SurfaceElevatedBrush}"
                                                                BorderBrush="{DynamicResource BorderBrush}"
                                                                BorderThickness="1"
                                                                CornerRadius="{StaticResource CornerRadiusSmall}"
                                                                Width="96"
                                                                Height="96"
                                                                HorizontalAlignment="Left">
                                                            <Image Stretch="Uniform"
                                                                   RenderOptions.BitmapScalingMode="HighQuality">
                                                                <Image.Source>
                                                                    <MultiBinding Converter="{StaticResource IconVariantToImageSourceConverter}">
                                                                        <Binding Path="CustomIconLightPath"/>
                                                                        <Binding Path="CustomIconDarkPath"/>
                                                                        <Binding Source="True"/>
                                                                    </MultiBinding>
                                                                </Image.Source>
                                                            </Image>
                                                        </Border>
                                                    </StackPanel>
                                                </Grid>
                                            </StackPanel>
                                        </ScrollViewer>

                                        <Grid Grid.Row="2" Margin="0,12,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <Button Content="Rimuovi"
                                                    Command="{Binding RemoveCustomIconCommand}"
                                                    Style="{StaticResource Win11Button}"
                                                    Height="36"
                                                    Visibility="{Binding HasCustomIcon, Converter={StaticResource BoolToVisibility}}"
                                                    HorizontalAlignment="Left"/>

                                            <Button Grid.Column="1"
                                                    Content="Chiudi"
                                                    Command="{Binding CloseIconPickerCommand}"
                                                    Style="{StaticResource Win11AccentButton}"
                                                    Height="36"
                                                    MinWidth="120"/>
                                        </Grid>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Grid>

                        <!-- Action buttons -->
                        <Border Grid.Row="2"
                                Background="{DynamicResource SurfaceElevatedBrush}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="0,1,0,0"
                                Padding="20,16">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <Button Grid.Column="0"
                                        Content="Annulla"
                                        Command="{Binding CancelCommand}"
                                        Style="{StaticResource Win11Button}"
                                        Height="40"
                                        Margin="0,0,8,0"/>

                                <Button Grid.Column="1"
                                        Command="{Binding SaveCommand}"
                                        Height="40"
                                        MinWidth="140">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource Win11AccentButton}">
                                            <Setter Property="Content" Value="Salva Preset"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsEditMode}" Value="True">
                                                    <Setter Property="Content" Value="Salva Modifiche"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>
            </Grid>

            <Grid Grid.Row="0" Grid.RowSpan="4"
                  Visibility="{Binding IsCreateProcessPanelOpen, Converter={StaticResource BoolToVisibility}}"
                  x:Name="CreateProcessOverlay">

                <Border Background="#80000000">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Opacity" Value="0"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsCreateProcessPanelOpen}" Value="True">
                                    <DataTrigger.EnterActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                               To="1" Duration="0:0:0.2"
                                                               EasingFunction="{StaticResource EaseOut}"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </DataTrigger.EnterActions>
                                    <DataTrigger.ExitActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                               To="0" Duration="0:0:0.15"
                                                               EasingFunction="{StaticResource EaseIn}"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </DataTrigger.ExitActions>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                </Border>

                <Border Width="700"
                        HorizontalAlignment="Right"
                        Background="{DynamicResource AppBackgroundBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1,0,0,0"
                        Effect="{StaticResource CardShadow}"
                        RenderTransformOrigin="1,0">
                    <Border.RenderTransform>
                        <TranslateTransform X="700"/>
                    </Border.RenderTransform>
                    <Border.Style>
                        <Style TargetType="Border">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsCreateProcessPanelOpen}" Value="True">
                                    <DataTrigger.EnterActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(TranslateTransform.X)"
                                                               To="0" Duration="0:0:0.3">
                                                    <DoubleAnimation.EasingFunction>
                                                        <CubicEase EasingMode="EaseOut"/>
                                                    </DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </DataTrigger.EnterActions>
                                    <DataTrigger.ExitActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(TranslateTransform.X)"
                                                               To="700" Duration="0:0:0.25">
                                                    <DoubleAnimation.EasingFunction>
                                                        <CubicEase EasingMode="EaseIn"/>
                                                    </DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </DataTrigger.ExitActions>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>

                    <Grid DataContext="{Binding CreateProcessViewModel}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0"
                                Background="{DynamicResource SurfaceElevatedBrush}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="0,0,0,1"
                                Padding="20,16">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" Orientation="Horizontal">
                                    <Image Source="{DynamicResource IconSettings}"
                                           Width="18" Height="18"
                                           VerticalAlignment="Center"
                                           Margin="0,0,10,0"
                                           RenderOptions.BitmapScalingMode="HighQuality"/>
                                    <TextBlock Text="{Binding Title}"
                                               Style="{StaticResource Win11TextTitle}"
                                               VerticalAlignment="Center"/>
                                </StackPanel>

                                <Button Grid.Column="1"
                                        Command="{Binding CancelCommand}"
                                        Style="{StaticResource Win11CloseButton}"
                                        Width="36" Height="36"
                                        Padding="0"
                                        ToolTip="Chiudi"/>
                            </Grid>
                        </Border>

                        <Grid Grid.Row="1">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0"
                                    Background="#1AFF3333"
                                    BorderBrush="{DynamicResource ErrorBrush}"
                                    BorderThickness="1"
                                    CornerRadius="{StaticResource CornerRadiusSmall}"
                                    Padding="12,8"
                                    Margin="20,16,20,0"
                                    Panel.ZIndex="100"
                                    Visibility="{Binding ValidationError, Converter={StaticResource StringToVisibilityConverter}}">
                                <StackPanel Orientation="Horizontal">
                                    <Image Source="{DynamicResource IconError}"
                                           Width="16" Height="16"
                                           VerticalAlignment="Center"
                                           Margin="0,0,8,0"
                                           RenderOptions.BitmapScalingMode="HighQuality"/>
                                    <TextBlock Text="{Binding ValidationError}"
                                               Foreground="{DynamicResource ErrorBrush}"
                                               TextWrapping="Wrap"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>

                            <ScrollViewer Grid.Row="1"
                                          VerticalScrollBarVisibility="Auto"
                                          Padding="20,16">
                                <StackPanel>
                                    <TextBlock Text="Nome Processo *"
                                               Style="{StaticResource Win11TextBody}"
                                               FontWeight="SemiBold"
                                               Margin="0,0,0,6"/>
                                    <TextBox Text="{Binding ProcessName, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource Win11TextBox}"
                                             Margin="0,0,0,16"/>

                                    <TextBlock Text="Descrizione"
                                               Style="{StaticResource Win11TextBody}"
                                               FontWeight="SemiBold"
                                               Margin="0,0,0,6"/>
                                    <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource Win11TextBox}"
                                             Margin="0,0,0,16"/>

                                    <TextBlock Text="Tipo di Processo *"
                                               Style="{StaticResource Win11TextBody}"
                                               FontWeight="SemiBold"
                                               Margin="0,0,0,6"/>
                                    <ComboBox ItemsSource="{Binding AvailableProcessKinds}"
                                              SelectedItem="{Binding SelectedProcessKind}"
                                              Style="{StaticResource Win11ComboBox}"
                                              Margin="0,0,0,16">
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock>
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Text" Value="{Binding}"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding}" Value="{x:Static models:ProcessKind.Installer}">
                                                                    <Setter Property="Text" Value="Installer (.exe, .msi, .zip)"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding}" Value="{x:Static models:ProcessKind.PowerShellScript}">
                                                                    <Setter Property="Text" Value="PowerShell Script"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding}" Value="{x:Static models:ProcessKind.BatchScript}">
                                                                    <Setter Property="Text" Value="Batch/CMD Script"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>

                                    <StackPanel Visibility="{Binding IsInstallerMode, Converter={StaticResource BoolToVisibility}}">
                                        <TextBlock Text="Percorso File Installer *"
                                                   Style="{StaticResource Win11TextBody}"
                                                   FontWeight="SemiBold"
                                                   Margin="0,0,0,6"/>
                                        <Grid Margin="0,0,0,16">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBox Grid.Column="0"
                                                     Text="{Binding FilePath, UpdateSourceTrigger=PropertyChanged}"
                                                     Style="{StaticResource Win11TextBox}"
                                                     Margin="0,0,8,0"/>
                                            <Button Grid.Column="1"
                                                    Content="Sfoglia..."
                                                    Command="{Binding BrowseFileCommand}"
                                                    Style="{StaticResource Win11Button}"
                                                    Padding="12,6"/>
                                        </Grid>

                                        <TextBlock Text="Argomenti Riga di Comando"
                                                   Style="{StaticResource Win11TextBody}"
                                                   FontWeight="SemiBold"
                                                   Margin="0,0,0,6"/>
                                        <TextBox Text="{Binding Arguments, UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{StaticResource Win11TextBox}"
                                                 Margin="0,0,0,16"/>
                                    </StackPanel>

                                    <StackPanel Visibility="{Binding IsScriptMode, Converter={StaticResource BoolToVisibility}}">
                                        <TextBlock Text="Contenuto Script (inline)"
                                                   Style="{StaticResource Win11TextBody}"
                                                   FontWeight="SemiBold"
                                                   Margin="0,0,0,6"/>
                                        <TextBox Text="{Binding ScriptContent, UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{StaticResource Win11TextBox}"
                                                 AcceptsReturn="True"
                                                 TextWrapping="Wrap"
                                                 Height="120"
                                                 VerticalScrollBarVisibility="Auto"
                                                 FontFamily="Cascadia Code, Consolas, monospace"
                                                 FontSize="11"
                                                 Margin="0,0,0,8"/>
                                        <TextBlock Text="— OPPURE —"
                                                   Style="{StaticResource Win11TextSecondary}"
                                                   HorizontalAlignment="Center"
                                                   Margin="0,0,0,8"/>

                                        <TextBlock Text="Percorso File Script"
                                                   Style="{StaticResource Win11TextBody}"
                                                   FontWeight="SemiBold"
                                                   Margin="0,0,0,6"/>
                                        <Grid Margin="0,0,0,16">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBox Grid.Column="0"
                                                     Text="{Binding FilePath, UpdateSourceTrigger=PropertyChanged}"
                                                     Style="{StaticResource Win11TextBox}"
                                                     Margin="0,0,8,0"/>
                                            <Button Grid.Column="1"
                                                    Content="Sfoglia..."
                                                    Command="{Binding BrowseFileCommand}"
                                                    Style="{StaticResource Win11Button}"
                                                    Padding="12,6"/>
                                        </Grid>
                                    </StackPanel>

                                    <TextBlock Text="Icona"
                                               Style="{StaticResource Win11TextBody}"
                                               FontWeight="SemiBold"
                                               Margin="0,0,0,6"/>
                                    <ComboBox ItemsSource="{Binding AvailableIcons}"
                                              SelectedValue="{Binding SelectedIconKey}"
                                              SelectedValuePath="Key"
                                              DisplayMemberPath="DisplayName"
                                              Style="{StaticResource Win11ComboBox}"
                                              Margin="0,0,0,16"/>

                                    <StackPanel Margin="0,0,0,16">
                                        <CheckBox IsChecked="{Binding RunAsAdmin}"
                                                  Style="{StaticResource Win11CheckBox}"
                                                  Margin="0,0,0,8">
                                            <TextBlock Text="Esegui come Amministratore"
                                                       Style="{StaticResource Win11TextBody}"/>
                                        </CheckBox>

                                        <CheckBox IsChecked="{Binding RequiresInternet}"
                                                  Style="{StaticResource Win11CheckBox}">
                                            <TextBlock Text="Richiede Connessione Internet"
                                                       Style="{StaticResource Win11TextBody}"/>
                                        </CheckBox>
                                    </StackPanel>

                                    <Border Background="#1A0078D4"
                                            BorderBrush="{DynamicResource AccentBrush}"
                                            BorderThickness="1"
                                            CornerRadius="{StaticResource CornerRadiusSmall}"
                                            Padding="12,8"
                                            Margin="0,0,0,16"
                                            Visibility="{Binding IsEditMode, Converter={StaticResource BoolToVisibility}}">
                                        <StackPanel Orientation="Horizontal">
                                            <Image Source="{DynamicResource IconWarning}"
                                                   Width="16" Height="16"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,8,0"
                                                   RenderOptions.BitmapScalingMode="HighQuality"/>
                                            <TextBlock Text="Attenzione: la modifica di questo processo influirà su tutti i preset che lo utilizzano."
                                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                                       FontSize="11"
                                                       TextWrapping="Wrap"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </ScrollViewer>
                        </Grid>

                        <Border Grid.Row="2"
                                Background="{DynamicResource SurfaceElevatedBrush}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="0,1,0,0"
                                Padding="20,16">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <Button Grid.Column="0"
                                        Content="Annulla"
                                        Command="{Binding CancelCommand}"
                                        Style="{StaticResource Win11Button}"
                                        Height="40"
                                        Margin="0,0,8,0"/>

                                <Button Grid.Column="1"
                                        Command="{Binding SaveCommand}"
                                        Height="40"
                                        MinWidth="160">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource Win11AccentButton}">
                                            <Setter Property="Content" Value="Crea Processo"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsEditMode}" Value="True">
                                                    <Setter Property="Content" Value="Salva Modifiche"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>
