<Window x:Class="KlevaDeploy.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:behaviors="clr-namespace:KlevaDeploy.Behaviors"
        xmlns:conv="clr-namespace:KlevaDeploy.Converters"
        xmlns:models="clr-namespace:KlevaDeploy.Models"
        xmlns:vm="clr-namespace:KlevaDeploy.ViewModels"
        mc:Ignorable="d"
        Title="KlevaDeploy"
        Width="1200" Height="760"
        MinWidth="900" MinHeight="580"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="False"
        ResizeMode="CanResizeWithGrip"
        Background="{DynamicResource AppBackgroundBrush}"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        FontFamily="Segoe UI Variable, Segoe UI, sans-serif">

    <Window.Icon>
        <MultiBinding Converter="{StaticResource IconVariantToImageSourceConverter}">
            <Binding Source="pack://application:,,,/Assets/Brand/KlevaDeploy.ico"/>
            <Binding Source="pack://application:,,,/Assets/Brand/KlevaDeploy.ico"/>
            <Binding Source="pack://application:,,,/Assets/Brand/KlevaDeploy%20Icon.png"/>
            <Binding Source="pack://application:,,,/Assets/Brand/KlevaDeploy%20Icon.png"/>
            <Binding RelativeSource="{RelativeSource Self}" Path="DataContext.IsDarkTheme"/>
        </MultiBinding>
    </Window.Icon>

    <!-- ── WindowChrome: integrates with DWM compositor, eliminates 1px white border artifact ── -->
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="48"
                      ResizeBorderThickness="6"
                      GlassFrameThickness="0,0,0,1"
                      UseAeroCaptionButtons="True"
                      CornerRadius="8"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <conv:BoolToDoubleConverter x:Key="OutputTabsIndicatorLeftConverter" FalseValue="0" TrueValue="79"/>

        <Style x:Key="Win11SegmentRadioButton" TargetType="RadioButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="HoverRoot"
                                Background="{TemplateBinding Background}"
                                CornerRadius="0"
                                ClipToBounds="True"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Stretch">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <!-- Segment corner rounding (used by the installer source segmented toggle) -->
                            <Trigger Property="Grid.Column" Value="0">
                                <Setter TargetName="HoverRoot" Property="CornerRadius" Value="10,0,0,10"/>
                            </Trigger>
                            <Trigger Property="Grid.Column" Value="2">
                                <Setter TargetName="HoverRoot" Property="CornerRadius" Value="0,10,10,0"/>
                            </Trigger>

                            <!-- Hover highlight only for unselected segments -->
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="IsChecked" Value="False"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="HoverRoot" Property="Background" Value="{DynamicResource HoverBrush}"/>
                                <Setter TargetName="HoverRoot" Property="Opacity" Value="0.7"/>
                            </MultiTrigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="HoverRoot" Property="Opacity" Value="1"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Foreground" Value="{DynamicResource SelectionForegroundBrush}"/>
                                <Setter TargetName="HoverRoot" Property="Background" Value="Transparent"/>
                                <Setter TargetName="HoverRoot" Property="Opacity" Value="1"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Preset card item style ── -->
        <Style x:Key="PresetCardItem" TargetType="ListBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="ItemBorder"
                                Background="{DynamicResource SurfaceBrush}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="{StaticResource CornerRadiusMedium}">
                            <ContentPresenter Margin="0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource HoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource SelectionSurfaceBrush}"/>
                                <Setter TargetName="ItemBorder" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Window chrome button style ── -->
        <Style x:Key="ChromeButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="46"/>
            <Setter Property="Height" Value="48"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Arrow"/>
            <Setter Property="WindowChrome.IsHitTestVisibleInChrome" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderThickness="0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource HoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource BorderBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Close button style (red hover) ── -->
        <Style x:Key="ChromeCloseButton" TargetType="Button" BasedOn="{StaticResource ChromeButton}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderThickness="0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#FFE81123"/>
                                <Setter Property="Foreground" Value="#FFFFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#FFC42B1C"/>
                                <Setter Property="Foreground" Value="#FFFFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Execution queue step item style ── -->
        <Style x:Key="QueueStepItem" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="{StaticResource CornerRadiusSmall}"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
            <Setter Property="Padding" Value="10,8"/>
        </Style>

        <Style x:Key="PresetGridCardToggleButton" TargetType="ToggleButton">
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment" Value="Stretch"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Grid SnapsToDevicePixels="True">
                            <Border x:Name="CardBorder"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="{StaticResource CornerRadiusCard}"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                  VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                            </Border>
                            <Border x:Name="SelectionBorder"
                                    BorderBrush="{DynamicResource AccentBrush}"
                                    BorderThickness="2"
                                    CornerRadius="{StaticResource CornerRadiusCard}"
                                    Opacity="0"
                                    IsHitTestVisible="False"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="CardBorder" Property="Background" Value="{DynamicResource HoverBrush}"/>
                                <Setter TargetName="CardBorder" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="CardBorder" Property="Background" Value="{DynamicResource SelectionSurfaceBrush}"/>
                                <Setter TargetName="CardBorder" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="SelectionBorder"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="1"
                                                             Duration="0:0:0.14"
                                                             EasingFunction="{StaticResource EaseOut}"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="SelectionBorder"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="0"
                                                             Duration="0:0:0.12"
                                                             EasingFunction="{StaticResource EaseOut}"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsChecked" Value="True"/>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="CardBorder" Property="Background" Value="{DynamicResource SelectionSurfaceBrush}"/>
                                <Setter TargetName="CardBorder" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- ═══════════════════════════════════════════════════════════
         OUTER BORDER — BorderThickness="0": WindowChrome handles the frame via DWM
    ═══════════════════════════════════════════════════════════ -->
    <Border BorderThickness="0">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="48"/>
                <RowDefinition Height="0"/>
                <RowDefinition Height="*"/>    <!-- Main content -->
                <RowDefinition Height="190"/>  <!-- Log panel -->
            </Grid.RowDefinitions>

            <!-- ══════════════════════════════════════════════════════
                 ROW 0 — CUSTOM TITLE BAR
                 WindowChrome.IsHitTestVisibleInChrome="True" so mouse events reach children
            ══════════════════════════════════════════════════════ -->
            <Border x:Name="TitleBar"
                    Grid.Row="0"
                    Background="{DynamicResource ToolbarBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="0,0,0,1">
                <Grid Margin="12,0,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0"
                                Orientation="Horizontal"
                                VerticalAlignment="Center"
                                IsHitTestVisible="False">
                        <Image x:Name="AppLogoImage"
                               Height="28"
                               VerticalAlignment="Center"
                               RenderOptions.BitmapScalingMode="HighQuality">
                            <Image.Source>
                                <MultiBinding Converter="{StaticResource IconVariantToImageSourceConverter}">
                                    <Binding Source="pack://application:,,,/Assets/Brand/KlevaDeploy%20logo%20light.png"/>
                                    <Binding Source="pack://application:,,,/Assets/Brand/KlevaDeploy%20logo%20dark.png"/>
                                    <Binding Path="IsDarkTheme"/>
                                </MultiBinding>
                            </Image.Source>
                        </Image>
                        <TextBlock Text="KlevaDeploy"
                                   Style="{StaticResource Win11TextSubtitle}"
                                   VerticalAlignment="Center"
                                   Visibility="{Binding ElementName=AppLogoImage, Path=Source, Converter={StaticResource NullToVisibilityConverter}, ConverterParameter=Inverse}"/>
                    </StackPanel>

                    <Border x:Name="DragRegion"
                            Grid.Column="2"
                            Background="Transparent"/>

                    <Button Grid.Column="3"
                            Command="{Binding OpenLoginCommand}"
                            Style="{StaticResource Win11Button}"
                            Padding="10,6" Margin="0,0,8,0"
                            VerticalAlignment="Center"
                            WindowChrome.IsHitTestVisibleInChrome="True">
                        <StackPanel Orientation="Horizontal">
                            <Grid Width="14" Height="14"
                                  VerticalAlignment="Center"
                                  Margin="0,0,8,0">
                                <Image RenderOptions.BitmapScalingMode="HighQuality">
                                    <Image.Style>
                                        <Style TargetType="Image">
                                            <Setter Property="Source" Value="{DynamicResource IconLock}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsAuthenticated}" Value="True">
                                                    <Setter Property="Source" Value="{DynamicResource IconUnlock}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Image.Style>
                                </Image>
                                <Ellipse Width="7" Height="7"
                                         Fill="{DynamicResource SuccessBrush}"
                                         Stroke="{DynamicResource SurfaceBrush}"
                                         StrokeThickness="1"
                                         HorizontalAlignment="Right"
                                         VerticalAlignment="Top"
                                         Margin="0,-1,-1,0"
                                         Visibility="{Binding IsAuthenticated, Converter={StaticResource BoolToVisibility}, FallbackValue=Collapsed}"/>
                            </Grid>
                            <TextBlock Text="Accedi"
                                       VerticalAlignment="Center"
                                       FontWeight="SemiBold"
                                       Visibility="{Binding IsAuthenticated, Converter={StaticResource InverseBoolToVisibility}, FallbackValue=Visible}"/>
                            <TextBlock Text="{Binding AuthenticatedPortalsCount}"
                                       VerticalAlignment="Center"
                                       FontWeight="SemiBold"
                                       Visibility="{Binding IsAuthenticated, Converter={StaticResource BoolToVisibility}, FallbackValue=Collapsed}"/>
                        </StackPanel>
                    </Button>

                    <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,8,0"
                                WindowChrome.IsHitTestVisibleInChrome="True">
                        <ProgressBar Width="80" Height="3"
                                     IsIndeterminate="True"
                                     Style="{StaticResource Win11ProgressBar}"
                                     Margin="0,0,12,0"
                                     Visibility="{Binding IsInitializing, Converter={StaticResource BoolToVisibility}}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="5"
                                Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Margin="0,0,8,0"
                                WindowChrome.IsHitTestVisibleInChrome="True">
                        <Button Command="{Binding OpenSettingsCommand}"
                                ToolTip="Impostazioni"
                                Style="{StaticResource Win11Button}"
                                Width="36" Height="36" Padding="0"
                                Margin="0,0,6,0">
                            <Image Source="{DynamicResource IconSettings}"
                                   Width="16" Height="16"
                                   RenderOptions.BitmapScalingMode="HighQuality"/>
                        </Button>
                        <Button Command="{Binding ToggleThemeCommand}"
                                ToolTip="{Binding ThemeToggleTooltip}"
                                Style="{StaticResource Win11Button}"
                                Width="36" Height="36" Padding="0">
                            <Image Source="{DynamicResource ThemeToggleDrawingImage}"
                                   Width="16" Height="16"
                                   RenderOptions.BitmapScalingMode="HighQuality"/>
                        </Button>
                    </StackPanel>

                    <StackPanel Grid.Column="6" Orientation="Horizontal" VerticalAlignment="Stretch">
                        <Button x:Name="BtnMinimize"
                                Style="{StaticResource ChromeButton}"
                                ToolTip="Minimizza">
                            <TextBlock Text="&#x2014;" FontSize="10"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center"/>
                        </Button>
                        <Button x:Name="BtnMaximize"
                                Style="{StaticResource ChromeButton}"
                                ToolTip="Ingrandisci">
                            <TextBlock x:Name="MaximizeIcon" Text="&#x25A1;" FontSize="11"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center"/>
                        </Button>
                        <Button x:Name="BtnClose"
                                Style="{StaticResource ChromeCloseButton}"
                                ToolTip="Chiudi">
                            <TextBlock Text="&#x2715;" FontSize="11"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ══════════════════════════════════════════════════════
                 ROW 2 — MAIN CONTENT
                 Left 3/4 : Deployment Presets
                 Right 1/4: Execution Queue
            ══════════════════════════════════════════════════════ -->
            <Grid Grid.Row="2" Margin="12,12,12,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="3*"/>  <!-- Left: presets -->
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="2*"/>  <!-- Right: execution queue -->
                </Grid.ColumnDefinitions>

                <!-- ────────────────────────────────────────────────
                     LEFT PANEL — Deployment Presets (3/5)
                ──────────────────────────────────────────────────── -->
                <Border Grid.Column="0" Style="{StaticResource Win11Card}" Padding="0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>  <!-- Card header -->
                            <RowDefinition Height="Auto"/>  <!-- Search bar -->
                            <RowDefinition Height="*"/>     <!-- Preset list -->
                            <RowDefinition Height="Auto"/>  <!-- Action bar -->
                        </Grid.RowDefinitions>

                        <!-- Card header -->
                        <Border Grid.Row="0"
                                Background="{DynamicResource SurfaceElevatedBrush}"
                                CornerRadius="8,8,0,0"
                                Padding="16,12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Orientation="Horizontal">
                                    <Image Source="{DynamicResource IconPackage}"
                                           Width="16" Height="16"
                                           VerticalAlignment="Center"
                                           Margin="0,0,8,0"
                                           RenderOptions.BitmapScalingMode="HighQuality"/>
                                    <TextBlock Text="Pacchetti"
                                               Style="{StaticResource Win11TextSubtitle}"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1"
                                            Orientation="Horizontal"
                                            VerticalAlignment="Center">
                                    <TextBlock Text="{Binding SelectedPresetCount, StringFormat='{}{0} pacchetti selezionati'}"
                                               Style="{StaticResource Win11TextSecondary}"
                                               VerticalAlignment="Center"
                                               Margin="0,0,10,0"/>
                                    <Border Background="{DynamicResource BorderBrush}" Width="1" Height="18" Opacity="0.6" Margin="0,0,10,0"/>
                                    <Border Background="{DynamicResource SurfaceBrush}"
                                            BorderBrush="{DynamicResource BorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="10"
                                            Padding="3"
                                            Height="40"
                                            Width="124">
                                        <Grid Width="118"
                                              Height="34"
                                              ClipToBounds="True">
                                            <Canvas IsHitTestVisible="False">
                                                <Border x:Name="PresetViewIndicator"
                                                        Canvas.Left="{Binding IsPresetGridView, Converter={StaticResource PresetViewIndicatorLeftConverter}}"
                                                        Width="59"
                                                        Height="34"
                                                        Background="{DynamicResource AccentBrush}"
                                                        BorderBrush="{DynamicResource AccentBrush}"
                                                        BorderThickness="1"
                                                        Opacity="0.18"
                                                        Panel.ZIndex="0"
                                                        IsHitTestVisible="False">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="CornerRadius" Value="8,0,0,8"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsPresetGridView}" Value="True">
                                                                    <Setter Property="CornerRadius" Value="0,8,8,0"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                </Border>
                                            </Canvas>
                                            <Grid Panel.ZIndex="1">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>

                                                <RadioButton Grid.Column="0"
                                                             GroupName="PresetViewMode"
                                                             IsChecked="{Binding IsPresetGridView, Converter={StaticResource InverseBoolConverter}, Mode=TwoWay}"
                                                             Background="Transparent"
                                                             BorderThickness="0"
                                                             Padding="0"
                                                             Cursor="Hand"
                                                             ToolTip="Vista elenco"
                                                             AutomationProperties.Name="Vista elenco"
                                                             HorizontalContentAlignment="Center"
                                                             VerticalContentAlignment="Center">
                                                    <RadioButton.Template>
                                                        <ControlTemplate TargetType="RadioButton">
                                                            <Border x:Name="HoverRoot"
                                                                    CornerRadius="8,0,0,8"
                                                                    Background="Transparent">
                                                                <ContentPresenter HorizontalAlignment="Center"
                                                                                  VerticalAlignment="Center"/>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="HoverRoot" Property="Background" Value="{DynamicResource HoverBrush}"/>
                                                                    <Setter TargetName="HoverRoot" Property="Opacity" Value="0.7"/>
                                                                </Trigger>
                                                                <Trigger Property="IsPressed" Value="True">
                                                                    <Setter TargetName="HoverRoot" Property="Opacity" Value="1"/>
                                                                </Trigger>
                                                                <Trigger Property="IsEnabled" Value="False">
                                                                    <Setter Property="Opacity" Value="0.4"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </RadioButton.Template>
                                                    <Viewbox Width="{StaticResource IconSizeLg}" Height="{StaticResource IconSizeLg}">
                                                        <Path Data="M4 6H20V8H4V6ZM4 11H20V13H4V11ZM4 16H20V18H4V16Z">
                                                            <Path.Style>
                                                                <Style TargetType="Path">
                                                                    <Setter Property="Fill" Value="{DynamicResource TextSecondaryBrush}"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsPresetGridView}" Value="False">
                                                                            <Setter Property="Fill" Value="{DynamicResource SelectionForegroundBrush}"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Path.Style>
                                                        </Path>
                                                    </Viewbox>
                                                </RadioButton>

                                                <RadioButton Grid.Column="1"
                                                             GroupName="PresetViewMode"
                                                             IsChecked="{Binding IsPresetGridView, Mode=TwoWay}"
                                                             Background="Transparent"
                                                             BorderThickness="0"
                                                             Padding="0"
                                                             Cursor="Hand"
                                                             ToolTip="Vista griglia"
                                                             AutomationProperties.Name="Vista griglia"
                                                             HorizontalContentAlignment="Center"
                                                             VerticalContentAlignment="Center">
                                                    <RadioButton.Template>
                                                        <ControlTemplate TargetType="RadioButton">
                                                            <Border x:Name="HoverRoot"
                                                                    CornerRadius="0,8,8,0"
                                                                    Background="Transparent">
                                                                <ContentPresenter HorizontalAlignment="Center"
                                                                                  VerticalAlignment="Center"/>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="HoverRoot" Property="Background" Value="{DynamicResource HoverBrush}"/>
                                                                    <Setter TargetName="HoverRoot" Property="Opacity" Value="0.7"/>
                                                                </Trigger>
                                                                <Trigger Property="IsPressed" Value="True">
                                                                    <Setter TargetName="HoverRoot" Property="Opacity" Value="1"/>
                                                                </Trigger>
                                                                <Trigger Property="IsEnabled" Value="False">
                                                                    <Setter Property="Opacity" Value="0.4"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </RadioButton.Template>
                                                    <Viewbox Width="{StaticResource IconSizeLg}" Height="{StaticResource IconSizeLg}">
                                                        <Path Data="M4 4H10V10H4V4ZM14 4H20V10H14V4ZM4 14H10V20H4V14ZM14 14H20V20H14V14Z">
                                                            <Path.Style>
                                                                <Style TargetType="Path">
                                                                    <Setter Property="Fill" Value="{DynamicResource TextSecondaryBrush}"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsPresetGridView}" Value="True">
                                                                            <Setter Property="Fill" Value="{DynamicResource SelectionForegroundBrush}"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Path.Style>
                                                        </Path>
                                                    </Viewbox>
                                                </RadioButton>
                                            </Grid>
                                        </Grid>
                                    </Border>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Search bar -->
                        <Border Grid.Row="1"
                                Background="{DynamicResource SurfaceBrush}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="0,1,0,1"
                                Padding="12,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0"
                                         Text="{Binding PresetSearchText, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource Win11TextBox}"
                                         Padding="28,6,8,6"
                                         FontSize="12">
                                    <TextBox.Resources>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                        </Style>
                                    </TextBox.Resources>
                                </TextBox>
                                <!-- Search icon -->
                                <Image Grid.Column="0"
                                       Source="{DynamicResource IconSearch}"
                                       Width="14" Height="14"
                                       HorizontalAlignment="Left"
                                       VerticalAlignment="Center"
                                       Margin="10,0,0,0"
                                       Opacity="0.55"
                                       IsHitTestVisible="False"
                                       RenderOptions.BitmapScalingMode="HighQuality"/>
                                <!-- Clear button -->
                                <Button Grid.Column="1"
                                        Content="✕"
                                        Command="{Binding ClearPresetSearchCommand}"
                                        Style="{StaticResource Win11Button}"
                                        Width="28" Height="28"
                                        Padding="0"
                                        Margin="4,0,0,0"
                                        FontSize="12"
                                        Visibility="{Binding PresetSearchText, Converter={StaticResource StringToVisibilityConverter}}"/>
                            </Grid>
                        </Border>

                        <Grid Grid.Row="2" x:Name="PresetsViewHost">
                            <ScrollViewer VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled"
                                          Padding="10"
                                          Visibility="{Binding IsPresetGridView, Converter={StaticResource InverseBoolToVisibility}}">

                                <ItemsControl ItemsSource="{Binding FilteredPresets}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid>
                                                <ToggleButton Style="{StaticResource PresetCardToggleButton}"
                                                              IsChecked="{Binding IsSelected, Mode=TwoWay}">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>  <!-- Icon -->
                                                            <ColumnDefinition Width="*"/>     <!-- Name + desc -->
                                                            <ColumnDefinition Width="Auto"/>  <!-- Checkmark badge / step count -->
                                                        </Grid.ColumnDefinitions>

                                                    <!-- Icon -->
                                                    <Border Grid.Column="0"
                                                            Width="40" Height="40"
                                                            CornerRadius="{StaticResource CornerRadiusMedium}"
                                                            Background="{DynamicResource SurfaceElevatedBrush}"
                                                            Margin="0,0,12,0">
                                                        <Grid>
                                                            <Image Width="22"
                                                                   Height="22"
                                                                   RenderOptions.BitmapScalingMode="HighQuality"
                                                                   Visibility="{Binding HasCustomIcon, Converter={StaticResource BoolToVisibility}}">
                                                                <Image.Source>
                                                                    <MultiBinding Converter="{StaticResource IconVariantToImageSourceConverter}">
                                                                        <Binding Path="CustomIconLightPath"/>
                                                                        <Binding Path="CustomIconDarkPath"/>
                                                                        <Binding Path="DataContext.IsDarkTheme"
                                                                                 RelativeSource="{RelativeSource AncestorType=Window}"/>
                                                                    </MultiBinding>
                                                                </Image.Source>
                                                            </Image>

                                                            <TextBlock Text="{Binding Icon, Mode=OneWay}"
                                                                       FontSize="18"
                                                                       FontFamily="Segoe UI Emoji"
                                                                       HorizontalAlignment="Center"
                                                                       VerticalAlignment="Center"
                                                                       Visibility="{Binding HasEmojiIcon, Converter={StaticResource BoolToVisibility}}"/>

                                                            <Image Source="{DynamicResource IconPackage}"
                                                                   Width="20"
                                                                   Height="20"
                                                                   Visibility="{Binding ShowDefaultIcon, Converter={StaticResource BoolToVisibility}}"
                                                                   RenderOptions.BitmapScalingMode="HighQuality"/>
                                                        </Grid>
                                                    </Border>

                                                    <!-- Name + description + category -->
                                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding Name, Mode=OneWay}"
                                                                   FontWeight="SemiBold"
                                                                   FontSize="13">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock" BasedOn="{StaticResource Win11TextBody}">
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                            <Setter Property="Foreground" Value="White"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                        <TextBlock Text="{Binding Description, Mode=OneWay}"
                                                                   FontSize="11"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   Margin="0,2,0,0">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock" BasedOn="{StaticResource Win11TextSecondary}">
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                            <Setter Property="Foreground" Value="#E0E0E0"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                        <TextBlock FontSize="11"
                                                                   Margin="0,2,0,0">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock" BasedOn="{StaticResource Win11TextSecondary}">
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                            <Setter Property="Foreground" Value="#D0D0D0"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                            <Run Text="{Binding Category, Mode=OneWay}"/>
                                                            <Run Text=" · "/>
                                                            <Run Text="{Binding StepCount, Mode=OneWay}"/>
                                                            <Run Text=" step"/>
                                                        </TextBlock>
                                                    </StackPanel>

                                                    <StackPanel Grid.Column="2"
                                                                Orientation="Horizontal"
                                                                HorizontalAlignment="Right"
                                                                VerticalAlignment="Top"
                                                                Margin="8,0,0,0">
                                                        <Border Background="{DynamicResource WarningSurfaceBrush}"
                                                                Style="{StaticResource Win11Badge}"
                                                                Margin="0,0,8,0"
                                                                VerticalAlignment="Center"
                                                                ToolTip="{Binding MissingProcessSummary}"
                                                                Visibility="{Binding HasMissingProcesses, Converter={StaticResource BoolToVisibility}}">
                                                            <TextBlock Text="{Binding MissingStepCount, StringFormat=⚠ {0} mancanti}"
                                                                       Style="{StaticResource Win11BadgeText}"
                                                                       Foreground="{DynamicResource WarningBrush}"/>
                                                        </Border>
                                                        <Border Background="{DynamicResource SurfaceElevatedBrush}"
                                                                CornerRadius="{StaticResource CornerRadiusSmall}"
                                                            Padding="6,2"
                                                                Visibility="{Binding IsSelected, Converter={StaticResource InverseBoolToVisibility}}">
                                                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                                                <TextBlock Text="{Binding StepCount, Mode=OneWay}"
                                                                           TextAlignment="Center"
                                                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                                                           FontSize="12"
                                                                           FontWeight="SemiBold"/>
                                                                <TextBlock Text="step"
                                                                           TextAlignment="Center"
                                                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                                                           FontSize="10"/>
                                                            </StackPanel>
                                                        </Border>
                                                        <Border Width="22" Height="22"
                                                                Background="White"
                                                                CornerRadius="11"
                                                                Visibility="{Binding IsSelected, Converter={StaticResource BoolToVisibility}}">
                                                            <TextBlock Text="✓"
                                                                       FontSize="12"
                                                                       FontWeight="Bold"
                                                                       Foreground="{DynamicResource AccentBrush}"
                                                                       HorizontalAlignment="Center"
                                                                       VerticalAlignment="Center"/>
                                                        </Border>
                                                        <Button Style="{StaticResource Win11IconButton}"
                                                                Margin="8,0,0,0"
                                                                ToolTip="Azioni"
                                                                AutomationProperties.Name="Azioni"
                                                                behaviors:ContextMenuOpenOnClickBehavior.IsEnabled="True"
                                                                Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Window}}">
                                                            <Button.Content>
                                                                <Image Source="{DynamicResource IconMoreHorizontal}"
                                                                       Width="{StaticResource IconSizeMd}"
                                                                       Height="{StaticResource IconSizeMd}"
                                                                       RenderOptions.BitmapScalingMode="HighQuality"/>
                                                            </Button.Content>
                                                            <Button.ContextMenu>
                                                                <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}"
                                                                             Style="{StaticResource Win11ContextMenu}"
                                                                             ItemContainerStyle="{StaticResource Win11ContextMenuItem}">
                                                                    <MenuItem Header="Modifica"
                                                                              Command="{Binding PlacementTarget.Tag.EditPresetCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                              CommandParameter="{Binding}">
                                                                        <MenuItem.Icon>
                                                                            <Image Source="{DynamicResource IconEdit}"
                                                                                   Width="{StaticResource IconSizeMd}"
                                                                                   Height="{StaticResource IconSizeMd}"
                                                                                   RenderOptions.BitmapScalingMode="HighQuality"/>
                                                                        </MenuItem.Icon>
                                                                    </MenuItem>
                                                                    <MenuItem Header="Esporta..."
                                                                              Command="{Binding PlacementTarget.Tag.ExportPackageCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                              CommandParameter="{Binding}">
                                                                        <MenuItem.Icon>
                                                                            <Image Source="{DynamicResource IconDownload}"
                                                                                   Width="{StaticResource IconSizeMd}"
                                                                                   Height="{StaticResource IconSizeMd}"
                                                                                   RenderOptions.BitmapScalingMode="HighQuality"/>
                                                                        </MenuItem.Icon>
                                                                    </MenuItem>
                                                                    <MenuItem Header="Elimina"
                                                                              Command="{Binding PlacementTarget.Tag.DeletePresetCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                              CommandParameter="{Binding}">
                                                                        <MenuItem.Icon>
                                                                            <Image Source="{DynamicResource IconDelete}"
                                                                                   Width="{StaticResource IconSizeMd}"
                                                                                   Height="{StaticResource IconSizeMd}"
                                                                                   RenderOptions.BitmapScalingMode="HighQuality"/>
                                                                        </MenuItem.Icon>
                                                                    </MenuItem>
                                                                </ContextMenu>
                                                            </Button.ContextMenu>
                                                        </Button>
                                                    </StackPanel>
                                                    </Grid>
                                                </ToggleButton>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>

                            <ScrollViewer VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled"
                                          Padding="12,12,44,44"
                                          Visibility="{Binding IsPresetGridView, Converter={StaticResource BoolToVisibility}}">

                                <ItemsControl ItemsSource="{Binding FilteredPresets}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel Orientation="Horizontal"
                                                       HorizontalAlignment="Center"
                                                       ItemWidth="160"
                                                       ItemHeight="160"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Width="160" Height="160">
                                                <ToggleButton Style="{StaticResource PresetGridCardToggleButton}"
                                                              Width="150"
                                                              Height="150"
                                                              HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"
                                                              IsChecked="{Binding IsSelected, Mode=TwoWay}">
                                                    <Grid>
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="*"/>
                                                        </Grid.RowDefinitions>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>

                                                        <Border Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2"
                                                                Width="22" Height="22"
                                                                Background="White"
                                                                CornerRadius="11"
                                                                HorizontalAlignment="Left"
                                                                VerticalAlignment="Top"
                                                                Margin="-2,-2,0,0"
                                                                Panel.ZIndex="2"
                                                                Visibility="{Binding IsSelected, Converter={StaticResource BoolToVisibility}}"
                                                                IsHitTestVisible="False">
                                                            <TextBlock Text="✓"
                                                                       FontSize="12"
                                                                       FontWeight="Bold"
                                                                       Foreground="{DynamicResource AccentBrush}"
                                                                       HorizontalAlignment="Center"
                                                                       VerticalAlignment="Center"/>
                                                        </Border>

                                                        <Border Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2"
                                                                Background="{DynamicResource WarningSurfaceBrush}"
                                                                Style="{StaticResource Win11Badge}"
                                                                HorizontalAlignment="Left"
                                                                VerticalAlignment="Top"
                                                                Margin="24,-2,0,0"
                                                                Panel.ZIndex="2"
                                                                ToolTip="{Binding MissingProcessSummary}"
                                                                Visibility="{Binding HasMissingProcesses, Converter={StaticResource BoolToVisibility}}"
                                                                IsHitTestVisible="False">
                                                            <TextBlock Text="{Binding MissingStepCount, StringFormat=⚠ {0}}"
                                                                       Style="{StaticResource Win11BadgeText}"
                                                                       Foreground="{DynamicResource WarningBrush}"/>
                                                        </Border>

                                                        <Border Grid.Row="0" Grid.Column="0"
                                                                Width="56" Height="56"
                                                                CornerRadius="{StaticResource CornerRadiusMedium}"
                                                                Background="{DynamicResource SurfaceElevatedBrush}">
                                                            <Grid>
                                                                <Image Width="32"
                                                                       Height="32"
                                                                       RenderOptions.BitmapScalingMode="HighQuality"
                                                                       Visibility="{Binding HasCustomIcon, Converter={StaticResource BoolToVisibility}}">
                                                                    <Image.Source>
                                                                        <MultiBinding Converter="{StaticResource IconVariantToImageSourceConverter}">
                                                                            <Binding Path="CustomIconLightPath"/>
                                                                            <Binding Path="CustomIconDarkPath"/>
                                                                            <Binding Path="DataContext.IsDarkTheme"
                                                                                     RelativeSource="{RelativeSource AncestorType=Window}"/>
                                                                        </MultiBinding>
                                                                    </Image.Source>
                                                                </Image>

                                                                <TextBlock Text="{Binding Icon, Mode=OneWay}"
                                                                           FontSize="26"
                                                                           FontFamily="Segoe UI Emoji"
                                                                           HorizontalAlignment="Center"
                                                                           VerticalAlignment="Center"
                                                                           Visibility="{Binding HasEmojiIcon, Converter={StaticResource BoolToVisibility}}"/>

                                                                <Image Source="{DynamicResource IconPackage}"
                                                                       Width="30"
                                                                       Height="30"
                                                                       Visibility="{Binding ShowDefaultIcon, Converter={StaticResource BoolToVisibility}}"
                                                                       RenderOptions.BitmapScalingMode="HighQuality"/>
                                                            </Grid>
                                                        </Border>

                                                        <StackPanel Grid.Row="0" Grid.Column="1"
                                                                    Orientation="Horizontal"
                                                                    HorizontalAlignment="Right"
                                                                    VerticalAlignment="Top">
                                                            <Button Style="{StaticResource Win11IconButton}"
                                                                    ToolTip="Azioni"
                                                                    AutomationProperties.Name="Azioni"
                                                                    behaviors:ContextMenuOpenOnClickBehavior.IsEnabled="True"
                                                                    Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Window}}">
                                                                <Button.Content>
                                                                    <Image Source="{DynamicResource IconMoreHorizontal}"
                                                                           Width="{StaticResource IconSizeMd}"
                                                                           Height="{StaticResource IconSizeMd}"
                                                                           RenderOptions.BitmapScalingMode="HighQuality"/>
                                                                </Button.Content>
                                                                <Button.ContextMenu>
                                                                    <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}"
                                                                                 Style="{StaticResource Win11ContextMenu}"
                                                                                 ItemContainerStyle="{StaticResource Win11ContextMenuItem}">
                                                                        <MenuItem Header="Modifica"
                                                                                  Command="{Binding PlacementTarget.Tag.EditPresetCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                                  CommandParameter="{Binding}">
                                                                            <MenuItem.Icon>
                                                                                <Image Source="{DynamicResource IconEdit}"
                                                                                       Width="{StaticResource IconSizeMd}"
                                                                                       Height="{StaticResource IconSizeMd}"
                                                                                       RenderOptions.BitmapScalingMode="HighQuality"/>
                                                                            </MenuItem.Icon>
                                                                        </MenuItem>
                                                                        <MenuItem Header="Esporta..."
                                                                                  Command="{Binding PlacementTarget.Tag.ExportPackageCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                                  CommandParameter="{Binding}">
                                                                            <MenuItem.Icon>
                                                                                <Image Source="{DynamicResource IconDownload}"
                                                                                       Width="{StaticResource IconSizeMd}"
                                                                                       Height="{StaticResource IconSizeMd}"
                                                                                       RenderOptions.BitmapScalingMode="HighQuality"/>
                                                                            </MenuItem.Icon>
                                                                        </MenuItem>
                                                                        <MenuItem Header="Elimina"
                                                                                  Command="{Binding PlacementTarget.Tag.DeletePresetCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                                  CommandParameter="{Binding}">
                                                                            <MenuItem.Icon>
                                                                                <Image Source="{DynamicResource IconDelete}"
                                                                                       Width="{StaticResource IconSizeMd}"
                                                                                       Height="{StaticResource IconSizeMd}"
                                                                                       RenderOptions.BitmapScalingMode="HighQuality"/>
                                                                            </MenuItem.Icon>
                                                                        </MenuItem>
                                                                    </ContextMenu>
                                                                </Button.ContextMenu>
                                                            </Button>
                                                        </StackPanel>

                                                        <TextBlock Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                                                                   Text="{Binding Name, Mode=OneWay}"
                                                                   Style="{StaticResource Win11TextBody}"
                                                                   FontWeight="SemiBold"
                                                                   FontSize="13"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   Margin="0,3,0,0"/>

                                                        <TextBlock Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                                                                   Text="{Binding Description, Mode=OneWay}"
                                                                   Style="{StaticResource Win11TextSecondary}"
                                                                   FontSize="11"
                                                                   TextWrapping="Wrap"
                                                                   TextTrimming="WordEllipsis"
                                                                   VerticalAlignment="Top"
                                                                   Margin="0,1,0,0"/>
                                                    </Grid>
                                                </ToggleButton>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>

                            <Grid Panel.ZIndex="50"
                                  Visibility="{Binding Presets.Count, Converter={StaticResource CollectionNotEmptyToVisibilityConverter}, ConverterParameter=Inverse}">
                                <Border Style="{StaticResource Win11Card}"
                                        Width="520"
                                        Padding="18"
                                        VerticalAlignment="Center"
                                        HorizontalAlignment="Center">
                                    <StackPanel HorizontalAlignment="Center">
                                        <Image Source="{DynamicResource IconPackage}"
                                               Width="28" Height="28"
                                               Margin="0,0,0,12"
                                               RenderOptions.BitmapScalingMode="HighQuality"/>
                                        <TextBlock Text="Nessun pacchetto"
                                                   Style="{StaticResource Win11TextSubtitle}"
                                                   TextAlignment="Center"
                                                   Margin="0,0,0,6"/>
                                        <TextBlock Text="Importa un pacchetto oppure creane uno nuovo. Se il file contiene anche i processi associati, l'app ti chiede se importarli."
                                                   Style="{StaticResource Win11TextSecondary}"
                                                   TextAlignment="Center"
                                                   TextWrapping="Wrap"
                                                   Margin="0,0,0,14"
                                                   Width="460"/>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                            <Button Content="Importa pacchetto"
                                                    Command="{Binding ImportPackageCommand}"
                                                    Style="{StaticResource Win11Button}"
                                                    Height="36"
                                                    MinWidth="160"
                                                    Margin="0,0,10,0"/>
                                            <Button Content="Crea pacchetto"
                                                    Command="{Binding OpenCreatePresetCommand}"
                                                    Style="{StaticResource Win11AccentButton}"
                                                    Height="36"
                                                    MinWidth="160"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Grid>

                        <!-- Action bar with Create Package button -->
                        <Border Grid.Row="3"
                                Background="{DynamicResource SurfaceElevatedBrush}"
                                CornerRadius="0,0,8,8"
                                Padding="16,12">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <Button Grid.Row="0" Grid.Column="0"
                                        Command="{Binding OpenCreatePresetCommand}"
                                        Style="{StaticResource Win11AccentButton}"
                                        HorizontalAlignment="Stretch"
                                        Padding="12,8"
                                        Margin="0,0,8,8"
                                        Visibility="{Binding Presets.Count, Converter={StaticResource CollectionNotEmptyToVisibilityConverter}}">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <TextBlock Text="➕" FontSize="16" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <TextBlock Text="Crea Nuovo Pacchetto" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>

                                <Button Grid.Row="0" Grid.Column="1"
                                        Command="{Binding ImportPackageCommand}"
                                        Style="{StaticResource Win11Button}"
                                        HorizontalAlignment="Stretch"
                                        Padding="12,8"
                                        Margin="0,0,0,8"
                                        Visibility="{Binding Presets.Count, Converter={StaticResource CollectionNotEmptyToVisibilityConverter}}">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <TextBlock Text="⤓" FontSize="16" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <TextBlock Text="Importa" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>

                                <TextBox Grid.Row="1" Grid.Column="0"
                                         Text="{Binding OverallStatus}"
                                         IsReadOnly="True"
                                         IsReadOnlyCaretVisible="True"
                                         TextWrapping="Wrap"
                                         VerticalAlignment="Center"
                                         Foreground="{DynamicResource TextSecondaryBrush}"
                                         FontSize="12"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         Padding="0"
                                         VerticalScrollBarVisibility="Hidden"
                                         HorizontalScrollBarVisibility="Hidden"/>

                                <StackPanel Grid.Row="1" Grid.Column="1"
                                            Orientation="Horizontal"
                                            VerticalAlignment="Center">
                                    <Button Content="{Binding IsRunning, Converter={StaticResource BusyToTextConverter},
                                                      ConverterParameter='▶  Esegui Coda|⏳  Esecuzione…'}"
                                            Command="{Binding RunQueueCommand}"
                                            Style="{StaticResource Win11AccentButton}"
                                            Height="36" MinWidth="160"
                                            IsEnabled="{Binding IsRunning, Converter={StaticResource InverseBoolConverter}, FallbackValue=True}"/>
                                    <Button Content="⛔  Annulla"
                                            Command="{Binding CancelQueueCommand}"
                                            Style="{StaticResource Win11Button}"
                                            Height="36"
                                            MinWidth="120"
                                            Margin="8,0,0,0"
                                            Visibility="{Binding IsRunning, Converter={StaticResource BoolToVisibility}, FallbackValue=Collapsed}"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>

                <!-- Splitter -->
                <GridSplitter Grid.Column="1"
                              Width="8"
                              HorizontalAlignment="Stretch"
                              Background="Transparent"
                              Cursor="SizeWE"/>

                <!-- ────────────────────────────────────────────────
                     RIGHT PANEL — Execution Queue (2/5)
                ──────────────────────────────────────────────────── -->
                <Border Grid.Column="2" Style="{StaticResource Win11Card}" Padding="0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>  <!-- Card header -->
                            <RowDefinition Height="Auto"/>  <!-- Search bar + Create button -->
                            <RowDefinition Height="*"/>     <!-- Queue list -->
                        </Grid.RowDefinitions>

                        <!-- Card header -->
                        <Border Grid.Row="0"
                                Background="{DynamicResource SurfaceElevatedBrush}"
                                CornerRadius="8,8,0,0"
                                Padding="14,12">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <Image Source="{DynamicResource IconSettings}"
                                           Width="15" Height="15"
                                           VerticalAlignment="Center"
                                           Margin="0,0,7,0"
                                           RenderOptions.BitmapScalingMode="HighQuality"/>
                                    <TextBlock Text="Coda di Esecuzione"
                                               Style="{StaticResource Win11TextSubtitle}"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Search bar + Create Process button -->
                        <Border Grid.Row="1"
                                Background="{DynamicResource SurfaceBrush}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="0,1,0,1"
                                Padding="12,8">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Search bar -->
                                <Grid Grid.Row="0" Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox Grid.Column="0"
                                             Text="{Binding ProcessSearchText, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource Win11TextBox}"
                                             Padding="28,6,8,6"
                                             FontSize="12">
                                        <TextBox.Resources>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                            </Style>
                                        </TextBox.Resources>
                                    </TextBox>
                                    <!-- Search icon -->
                                    <Image Grid.Column="0"
                                           Source="{DynamicResource IconSearch}"
                                           Width="14" Height="14"
                                           HorizontalAlignment="Left"
                                           VerticalAlignment="Center"
                                           Margin="10,0,0,0"
                                           Opacity="0.55"
                                           IsHitTestVisible="False"
                                           RenderOptions.BitmapScalingMode="HighQuality"/>
                                    <!-- Clear button -->
                                    <Button Grid.Column="1"
                                            Content="✕"
                                            Command="{Binding ClearProcessSearchCommand}"
                                            Style="{StaticResource Win11Button}"
                                            Width="28" Height="28"
                                            Padding="0"
                                            Margin="4,0,0,0"
                                            FontSize="12"
                                            Visibility="{Binding ProcessSearchText, Converter={StaticResource StringToVisibilityConverter}}"/>
                                </Grid>

                                <!-- Create Process button -->
                                <Button Grid.Row="1"
                                        Command="{Binding CreateProcessCommand}"
                                        Style="{StaticResource Win11AccentButton}"
                                        HorizontalAlignment="Stretch"
                                        Padding="10,8"
                                        Visibility="{Binding ExecutionQueue.Count, Converter={StaticResource CollectionNotEmptyToVisibilityConverter}}">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <TextBlock Text="➕" FontSize="14" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                        <TextBlock Text="Nuovo Processo" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </Grid>
                        </Border>

                        <Grid Grid.Row="2"
                              Panel.ZIndex="50"
                              Visibility="{Binding ExecutionQueue.Count, Converter={StaticResource CollectionNotEmptyToVisibilityConverter}, ConverterParameter=Inverse}">
                            <Border Style="{StaticResource Win11Card}"
                                    Width="420"
                                    Padding="18"
                                    VerticalAlignment="Center"
                                    HorizontalAlignment="Center">
                                <StackPanel HorizontalAlignment="Center">
                                    <Image Source="{DynamicResource IconSettings}"
                                           Width="28" Height="28"
                                           Margin="0,0,0,12"
                                           RenderOptions.BitmapScalingMode="HighQuality"/>
                                    <TextBlock Text="Nessun processo"
                                               Style="{StaticResource Win11TextSubtitle}"
                                               TextAlignment="Center"
                                               Margin="0,0,0,6"/>
                                    <TextBlock Text="Importa un processo (.kdp.json) oppure creane uno nuovo per iniziare."
                                               Style="{StaticResource Win11TextSecondary}"
                                               TextAlignment="Center"
                                               TextWrapping="Wrap"
                                               Margin="0,0,0,14"
                                               Width="360"/>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <Button Content="Importa processo"
                                                Command="{Binding ImportProcessLibraryCommand}"
                                                Style="{StaticResource Win11Button}"
                                                Height="36"
                                                MinWidth="150"
                                                Margin="0,0,10,0"/>
                                        <Button Content="Nuovo processo"
                                                Command="{Binding CreateProcessCommand}"
                                                Style="{StaticResource Win11AccentButton}"
                                                Height="36"
                                                MinWidth="150"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <!-- Queue items -->
                        <ScrollViewer Grid.Row="2"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled"
                                      Padding="8,8,8,8"
                                      Visibility="{Binding ExecutionQueue.Count, Converter={StaticResource CollectionNotEmptyToVisibilityConverter}}">
                            <ItemsControl ItemsSource="{Binding FilteredExecutionQueueDisplayItems}">
                                <ItemsControl.Resources>
                                    <DataTemplate DataType="{x:Type vm:ProcessStepViewModel}">
                                        <ToggleButton IsChecked="{Binding IsEnabled, Mode=TwoWay}"
                                                      Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Window}}">
                                            <ToggleButton.ContextMenu>
                                                <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}"
                                                             Style="{StaticResource Win11ContextMenu}"
                                                             ItemContainerStyle="{StaticResource Win11ContextMenuItem}">
                                                    <MenuItem Header="Modifica"
                                                              Command="{Binding PlacementTarget.Tag.EditProcessCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                              CommandParameter="{Binding}">
                                                        <MenuItem.Icon>
                                                            <Image Source="{DynamicResource IconEdit}"
                                                                   Width="{StaticResource IconSizeMd}"
                                                                   Height="{StaticResource IconSizeMd}"
                                                                   RenderOptions.BitmapScalingMode="HighQuality"/>
                                                        </MenuItem.Icon>
                                                    </MenuItem>
                                                    <MenuItem Header="Elimina"
                                                              Command="{Binding PlacementTarget.Tag.DeleteProcessCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                              CommandParameter="{Binding}">
                                                        <MenuItem.Icon>
                                                            <Image Source="{DynamicResource IconDelete}"
                                                                   Width="{StaticResource IconSizeMd}"
                                                                   Height="{StaticResource IconSizeMd}"
                                                                   RenderOptions.BitmapScalingMode="HighQuality"/>
                                                        </MenuItem.Icon>
                                                    </MenuItem>
                                                    <MenuItem Style="{StaticResource Win11ContextMenuSeparatorItem}"/>
                                                    <MenuItem Header="Aggiorna installer"
                                                              Command="{Binding PlacementTarget.Tag.UpdateInstallerCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                              CommandParameter="{Binding}">
                                                        <MenuItem.Icon>
                                                            <Image Source="{DynamicResource IconRefresh}"
                                                                   Width="{StaticResource IconSizeMd}"
                                                                   Height="{StaticResource IconSizeMd}"
                                                                   RenderOptions.BitmapScalingMode="HighQuality"/>
                                                        </MenuItem.Icon>
                                                        <MenuItem.Style>
                                                            <Style TargetType="MenuItem" BasedOn="{StaticResource Win11ContextMenuItem}">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Process.Kind}" Value="{x:Static models:ProcessKind.Installer}">
                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </MenuItem.Style>
                                                    </MenuItem>
                                                    <MenuItem Header="Apri cartella installer"
                                                              Command="{Binding PlacementTarget.Tag.RevealInstallerInExplorerCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                              CommandParameter="{Binding}">
                                                        <MenuItem.Icon>
                                                            <Image Source="{DynamicResource IconFolder}"
                                                                   Width="{StaticResource IconSizeMd}"
                                                                   Height="{StaticResource IconSizeMd}"
                                                                   RenderOptions.BitmapScalingMode="HighQuality"/>
                                                        </MenuItem.Icon>
                                                        <MenuItem.Style>
                                                            <Style TargetType="MenuItem" BasedOn="{StaticResource Win11ContextMenuItem}">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Process.Kind}" Value="{x:Static models:ProcessKind.Installer}">
                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </MenuItem.Style>
                                                    </MenuItem>
                                                </ContextMenu>
                                            </ToggleButton.ContextMenu>
                                            <ToggleButton.Style>
                                                <Style TargetType="ToggleButton" BasedOn="{StaticResource ProcessCardToggleButton}">
                                                    <Style.Triggers>
                                                        <!-- ISSUE 4 & 6 FIX: Grey out ONLY when not in selected preset AND not manually enabled -->
                                                        <!-- If IsEnabled=true, always show at full opacity (1.0) -->
                                                        <DataTrigger Binding="{Binding IsEnabled}" Value="True">
                                                            <Setter Property="Opacity" Value="1.0"/>
                                                        </DataTrigger>
                                                        <!-- If IsEnabled=false AND not in preset, grey out more -->
                                                        <MultiDataTrigger>
                                                            <MultiDataTrigger.Conditions>
                                                                <Condition Binding="{Binding IsEnabled}" Value="False"/>
                                                                <Condition Binding="{Binding IsInSelectedPreset}" Value="False"/>
                                                            </MultiDataTrigger.Conditions>
                                                            <Setter Property="Opacity" Value="0.3"/>
                                                        </MultiDataTrigger>
                                                        <!-- If IsEnabled=false BUT in preset (manually deselected), moderate grey -->
                                                        <MultiDataTrigger>
                                                            <MultiDataTrigger.Conditions>
                                                                <Condition Binding="{Binding IsEnabled}" Value="False"/>
                                                                <Condition Binding="{Binding IsInSelectedPreset}" Value="True"/>
                                                            </MultiDataTrigger.Conditions>
                                                            <Setter Property="Opacity" Value="0.5"/>
                                                        </MultiDataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </ToggleButton.Style>
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>  <!-- Indicator + reorder -->
                                                    <ColumnDefinition Width="Auto"/>  <!-- Process icon + state -->
                                                    <ColumnDefinition Width="*"/>     <!-- Name -->
                                                    <ColumnDefinition Width="Auto"/>  <!-- Badges / actions -->
                                                </Grid.ColumnDefinitions>

                                                <Grid Grid.Row="0" Grid.Column="0"
                                                      Grid.RowSpan="4"
                                                      Margin="0,0,10,0">
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>

                                                    <Border Grid.Row="0"
                                                            Width="22" Height="22"
                                                            CornerRadius="11"
                                                            Background="{DynamicResource AccentBrush}"
                                                            BorderBrush="{DynamicResource AccentBrush}"
                                                            BorderThickness="1"
                                                            VerticalAlignment="Top">
                                                        <TextBlock Text="{Binding ExecutionIndex}"
                                                                   FontSize="12"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="White"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center"/>
                                                    </Border>

                                                    <Button Grid.Row="1"
                                                            Command="{Binding DataContext.MoveQueueStepUpCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                            CommandParameter="{Binding}"
                                                            Style="{StaticResource Win11IconButton}"
                                                            Width="20"
                                                            Height="20"
                                                            Padding="0"
                                                            Margin="0,8,0,0"
                                                            ToolTip="Sposta su">
                                                        <Image Source="{DynamicResource IconChevronUp}"
                                                               Width="14"
                                                               Height="14"
                                                               RenderOptions.BitmapScalingMode="HighQuality"/>
                                                    </Button>

                                                    <Button Grid.Row="2"
                                                            Command="{Binding DataContext.MoveQueueStepDownCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                            CommandParameter="{Binding}"
                                                            Style="{StaticResource Win11IconButton}"
                                                            Width="20"
                                                            Height="20"
                                                            Padding="0"
                                                            Margin="0,2,0,0"
                                                            ToolTip="Sposta giù">
                                                        <Image Source="{DynamicResource IconChevronDown}"
                                                               Width="14"
                                                               Height="14"
                                                               RenderOptions.BitmapScalingMode="HighQuality"/>
                                                    </Button>

                                                    <Grid.Style>
                                                        <Style TargetType="Grid">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsEnabled}" Value="True">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Grid.Style>
                                                </Grid>

                                                <Grid Grid.Row="0" Grid.Column="1"
                                                      Grid.RowSpan="4"
                                                      Margin="0,0,12,0">
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>

                                                    <Border Grid.Row="0"
                                                            Width="40" Height="40"
                                                            CornerRadius="{StaticResource CornerRadiusMedium}"
                                                            Background="{DynamicResource SurfaceElevatedBrush}">
                                                        <Grid>
                                                            <Image Width="22"
                                                                   Height="22"
                                                                   RenderOptions.BitmapScalingMode="HighQuality"
                                                                   Visibility="{Binding HasCustomIcon, Converter={StaticResource BoolToVisibility}}">
                                                                <Image.Source>
                                                                    <MultiBinding Converter="{StaticResource IconVariantToImageSourceConverter}">
                                                                        <Binding Path="CustomIconLightPath"/>
                                                                        <Binding Path="CustomIconDarkPath"/>
                                                                        <Binding Path="DataContext.IsDarkTheme"
                                                                                 RelativeSource="{RelativeSource AncestorType=Window}"/>
                                                                    </MultiBinding>
                                                                </Image.Source>
                                                            </Image>

                                                            <TextBlock Text="{Binding Icon}"
                                                                       FontSize="18"
                                                                       FontFamily="Segoe UI Emoji"
                                                                       HorizontalAlignment="Center"
                                                                       VerticalAlignment="Center"
                                                                       Visibility="{Binding HasEmojiIcon, Converter={StaticResource BoolToVisibility}}"/>

                                                            <Image Source="{DynamicResource IconPackage}"
                                                                   Width="22"
                                                                   Height="22"
                                                                   Visibility="{Binding ShowDefaultIcon, Converter={StaticResource BoolToVisibility}}"
                                                                   RenderOptions.BitmapScalingMode="HighQuality"/>
                                                        </Grid>
                                                    </Border>

                                                    <Grid Grid.Row="1"
                                                          Width="40"
                                                          Height="18"
                                                          Margin="0,4,0,0">
                                                        <Grid.Style>
                                                            <Style TargetType="Grid">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsEnabled}" Value="True">
                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Grid.Style>

                                                        <Image Source="{DynamicResource IconPending}"
                                                               Width="14"
                                                               Height="14"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center">
                                                            <Image.Style>
                                                                <Style TargetType="Image">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                    <Style.Triggers>
                                                                        <MultiDataTrigger>
                                                                            <MultiDataTrigger.Conditions>
                                                                                <Condition Binding="{Binding DataContext.IsRunning, RelativeSource={RelativeSource AncestorType=Window}}" Value="False"/>
                                                                            </MultiDataTrigger.Conditions>
                                                                            <Setter Property="Visibility" Value="Visible"/>
                                                                        </MultiDataTrigger>
                                                                        <DataTrigger Binding="{Binding StatusIcon}" Value="✅">
                                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Image.Style>
                                                        </Image>

                                                        <TextBlock Text="⏳"
                                                                   FontSize="13"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center"
                                                                   Foreground="{DynamicResource TextSecondaryBrush}">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                    <Style.Triggers>
                                                                        <MultiDataTrigger>
                                                                            <MultiDataTrigger.Conditions>
                                                                                <Condition Binding="{Binding DataContext.IsRunning, RelativeSource={RelativeSource AncestorType=Window}}" Value="True"/>
                                                                                <Condition Binding="{Binding IsRunningStep}" Value="False"/>
                                                                            </MultiDataTrigger.Conditions>
                                                                            <Setter Property="Visibility" Value="Visible"/>
                                                                        </MultiDataTrigger>
                                                                        <DataTrigger Binding="{Binding StatusIcon}" Value="✅">
                                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>

                                                        <Grid Width="14"
                                                              Height="14"
                                                              HorizontalAlignment="Center"
                                                              VerticalAlignment="Center">
                                                            <Grid.Style>
                                                                <Style TargetType="Grid">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsRunningStep}" Value="True">
                                                                            <Setter Property="Visibility" Value="Visible"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Grid.Style>
                                                            <Ellipse Stroke="{DynamicResource BorderBrush}" StrokeThickness="2" Opacity="0.35"/>
                                                            <Path Stroke="{DynamicResource AccentBrush}"
                                                                  StrokeThickness="2"
                                                                  StrokeStartLineCap="Round"
                                                                  StrokeEndLineCap="Round"
                                                                  Data="M 7,1 A 6,6 0 1 1 1,7">
                                                                <Path.RenderTransform>
                                                                    <RotateTransform x:Name="SpinnerRotate2" CenterX="7" CenterY="7"/>
                                                                </Path.RenderTransform>
                                                                <Path.Triggers>
                                                                    <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                                                                        <BeginStoryboard>
                                                                            <Storyboard RepeatBehavior="Forever">
                                                                                <DoubleAnimation Storyboard.TargetName="SpinnerRotate2"
                                                                                                 Storyboard.TargetProperty="Angle"
                                                                                                 From="0"
                                                                                                 To="360"
                                                                                                 Duration="0:0:0.9"/>
                                                                            </Storyboard>
                                                                        </BeginStoryboard>
                                                                    </EventTrigger>
                                                                </Path.Triggers>
                                                            </Path>
                                                        </Grid>

                                                        <Image Source="{DynamicResource IconCheckCircle}"
                                                               Width="14"
                                                               Height="14"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center">
                                                            <Image.Style>
                                                                <Style TargetType="Image">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding StatusIcon}" Value="✅">
                                                                            <Setter Property="Visibility" Value="Visible"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Image.Style>
                                                        </Image>
                                                    </Grid>
                                                </Grid>

                                                <!-- Process name -->
                                                <TextBlock Grid.Row="0" Grid.Column="2"
                                                           Text="{Binding Name}"
                                                           Style="{StaticResource Win11TextBody}"
                                                           FontWeight="SemiBold"
                                                           TextTrimming="CharacterEllipsis"
                                                           VerticalAlignment="Center"
                                                           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}"/>

                                                

                                                <!-- Action icons (Internet + Edit + Kind) -->
                                                <StackPanel Grid.Row="0" Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                                                    <!-- Internet Badge -->
                                                    <Border Background="{DynamicResource InfoSurfaceBrush}"
                                                            Style="{StaticResource Win11Badge}"
                                                            Margin="6,0,0,0"
                                                            Visibility="{Binding Process.RequiresInternet, Converter={StaticResource BoolToVisibility}}">
                                                        <TextBlock Text="🌐 WEB"
                                                                   Style="{StaticResource Win11BadgeText}"
                                                                   Foreground="{DynamicResource AccentBrush}"/>
                                                    </Border>

                                                    <Border Background="{DynamicResource WarningSurfaceBrush}"
                                                            Margin="6,0,0,0">
                                                        <Border.Style>
                                                            <Style TargetType="Border" BasedOn="{StaticResource Win11Badge}">
                                                                <Setter Property="Visibility" Value="{Binding ShowLoginBadge, Converter={StaticResource BoolToVisibility}}"/>
                                                            </Style>
                                                        </Border.Style>
                                                        <TextBlock Text="🔒 LOGIN"
                                                                   Style="{StaticResource Win11BadgeText}"
                                                                   Foreground="{DynamicResource WarningBrush}"/>
                                                    </Border>

                                                    <!-- Kind label badge -->
                                                    <Border Background="{DynamicResource SurfaceElevatedBrush}"
                                                            Style="{StaticResource Win11Badge}"
                                                            Margin="6,0,0,0">
                                                        <TextBlock Text="{Binding KindLabel}"
                                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                                   FontSize="9"
                                                                   VerticalAlignment="Center"/>
                                                    </Border>

                                                    <Button Content="Annulla"
                                                            Command="{Binding DataContext.CancelStepCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                            CommandParameter="{Binding}"
                                                            Height="24"
                                                            Padding="10,3"
                                                            Margin="6,0,0,0">
                                                        <Button.Style>
                                                            <Style TargetType="Button" BasedOn="{StaticResource Win11Button}">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=ToggleButton}}" Value="True">
                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Button.Style>
                                                    </Button>
                                                    
                                                    <Button Style="{StaticResource Win11IconButton}"
                                                            Margin="6,0,0,0"
                                                            ToolTip="Azioni"
                                                            AutomationProperties.Name="Azioni"
                                                            behaviors:ContextMenuOpenOnClickBehavior.IsEnabled="True"
                                                            Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Window}}">
                                                        <Button.Content>
                                                            <Image Source="{DynamicResource IconMoreHorizontal}"
                                                                   Width="{StaticResource IconSizeMd}"
                                                                   Height="{StaticResource IconSizeMd}"
                                                                   RenderOptions.BitmapScalingMode="HighQuality"/>
                                                        </Button.Content>
                                                        <Button.ContextMenu>
                                                            <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}"
                                                                         Style="{StaticResource Win11ContextMenu}"
                                                                         ItemContainerStyle="{StaticResource Win11ContextMenuItem}">
                                                                <MenuItem Header="Modifica"
                                                                          Command="{Binding PlacementTarget.Tag.EditProcessCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                          CommandParameter="{Binding}">
                                                                    <MenuItem.Icon>
                                                                        <Image Source="{DynamicResource IconEdit}"
                                                                               Width="{StaticResource IconSizeMd}"
                                                                               Height="{StaticResource IconSizeMd}"
                                                                               RenderOptions.BitmapScalingMode="HighQuality"/>
                                                                    </MenuItem.Icon>
                                                                </MenuItem>
                                                                <MenuItem Header="Elimina"
                                                                          Command="{Binding PlacementTarget.Tag.DeleteProcessCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                          CommandParameter="{Binding}">
                                                                    <MenuItem.Icon>
                                                                        <Image Source="{DynamicResource IconDelete}"
                                                                               Width="{StaticResource IconSizeMd}"
                                                                               Height="{StaticResource IconSizeMd}"
                                                                               RenderOptions.BitmapScalingMode="HighQuality"/>
                                                                    </MenuItem.Icon>
                                                                </MenuItem>
                                                                <MenuItem Style="{StaticResource Win11ContextMenuSeparatorItem}"/>
                                                                <MenuItem Header="Aggiorna installer"
                                                                          Command="{Binding PlacementTarget.Tag.UpdateInstallerCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                          CommandParameter="{Binding}">
                                                                    <MenuItem.Icon>
                                                                        <Image Source="{DynamicResource IconRefresh}"
                                                                               Width="{StaticResource IconSizeMd}"
                                                                               Height="{StaticResource IconSizeMd}"
                                                                               RenderOptions.BitmapScalingMode="HighQuality"/>
                                                                    </MenuItem.Icon>
                                                                    <MenuItem.Style>
                                                                        <Style TargetType="MenuItem" BasedOn="{StaticResource Win11ContextMenuItem}">
                                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding Process.Kind}" Value="{x:Static models:ProcessKind.Installer}">
                                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </MenuItem.Style>
                                                                </MenuItem>
                                                                <MenuItem Header="Riscarica installer"
                                                                          Command="{Binding PlacementTarget.Tag.RedownloadInstallerCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                          CommandParameter="{Binding}">
                                                                    <MenuItem.Icon>
                                                                        <Image Source="{DynamicResource IconDownload}"
                                                                               Width="{StaticResource IconSizeMd}"
                                                                               Height="{StaticResource IconSizeMd}"
                                                                               RenderOptions.BitmapScalingMode="HighQuality"/>
                                                                    </MenuItem.Icon>
                                                                    <MenuItem.Style>
                                                                        <Style TargetType="MenuItem" BasedOn="{StaticResource Win11ContextMenuItem}">
                                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                                            <Style.Triggers>
                                                                                <MultiDataTrigger>
                                                                                    <MultiDataTrigger.Conditions>
                                                                                        <Condition Binding="{Binding Process.Kind}" Value="{x:Static models:ProcessKind.Installer}"/>
                                                                                        <Condition Binding="{Binding Process.InstallerSourceMode}" Value="{x:Static models:InstallerSourceMode.StaticWeb}"/>
                                                                                    </MultiDataTrigger.Conditions>
                                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                                </MultiDataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </MenuItem.Style>
                                                                </MenuItem>
                                                                <MenuItem Header="Apri cartella installer"
                                                                          Command="{Binding PlacementTarget.Tag.RevealInstallerInExplorerCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                          CommandParameter="{Binding}">
                                                                    <MenuItem.Icon>
                                                                        <Image Source="{DynamicResource IconFolder}"
                                                                               Width="{StaticResource IconSizeMd}"
                                                                               Height="{StaticResource IconSizeMd}"
                                                                               RenderOptions.BitmapScalingMode="HighQuality"/>
                                                                    </MenuItem.Icon>
                                                                    <MenuItem.Style>
                                                                        <Style TargetType="MenuItem" BasedOn="{StaticResource Win11ContextMenuItem}">
                                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding Process.Kind}" Value="{x:Static models:ProcessKind.Installer}">
                                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </MenuItem.Style>
                                                                </MenuItem>
                                                            </ContextMenu>
                                                        </Button.ContextMenu>
                                                    </Button>
                                                </StackPanel>

                                                <!-- Description + required badge + status text -->
                                                <StackPanel Grid.Row="1" Grid.Column="2" Grid.ColumnSpan="2"
                                                            Orientation="Horizontal"
                                                            Margin="0,4,0,0">
                                                    <TextBlock Text="{Binding Description}"
                                                               Style="{StaticResource Win11TextSecondary}"
                                                               TextTrimming="CharacterEllipsis"
                                                               Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}"/>
                                                    <!-- Required badge -->
                                                    <Border Background="{DynamicResource WarningSurfaceBrush}"
                                                            Style="{StaticResource Win11Badge}"
                                                            Margin="6,0,0,0"
                                                            VerticalAlignment="Center"
                                                            Visibility="{Binding IsRequired, Converter={StaticResource BoolToVisibility}}">
                                                        <TextBlock Text="Richiesto"
                                                                   Foreground="{DynamicResource WarningBrush}"
                                                                   FontSize="9"
                                                                   FontWeight="SemiBold"
                                                                   VerticalAlignment="Center"/>
                                                    </Border>
                                                    <!-- Status text -->
                                                    <TextBlock Text="{Binding StatusText}"
                                                               Style="{StaticResource Win11TextSecondary}"
                                                               Margin="8,0,0,0"
                                                               FontSize="10"
                                                               Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}"/>
                                                </StackPanel>

                                                <ProgressBar Grid.Row="2"
                                                             Grid.Column="2"
                                                             Grid.ColumnSpan="2"
                                                             Height="3"
                                                             Maximum="100"
                                                             Value="{Binding ProgressValue}"
                                                             IsIndeterminate="{Binding IsProgressIndeterminate}"
                                                             Margin="0,6,0,0"
                                                             IsHitTestVisible="False">
                                                    <ProgressBar.Style>
                                                        <Style TargetType="ProgressBar" BasedOn="{StaticResource Win11ProgressBar}">
                                                            <Setter Property="Opacity" Value="0.25"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsRunningStep}" Value="True">
                                                                    <Setter Property="Opacity" Value="1"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </ProgressBar.Style>
                                                </ProgressBar>

                                                <StackPanel Grid.Row="3"
                                                            Grid.Column="2"
                                                            Grid.ColumnSpan="2"
                                                            Margin="0,4,0,0"
                                                            Visibility="{Binding IsSubProcessRunning, Converter={StaticResource BoolToVisibility}}">
                                                    <TextBlock Text="{Binding CurrentSubProcessName}"
                                                               Style="{StaticResource Win11TextSecondary}"
                                                               FontSize="10"
                                                               Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}"/>
                                                    <ProgressBar Height="3"
                                                                 Maximum="100"
                                                                 Value="{Binding SubProgressValue}"
                                                                 IsIndeterminate="{Binding IsSubProgressIndeterminate}"
                                                                 Margin="0,4,0,0"
                                                                 IsHitTestVisible="False"
                                                                 Style="{StaticResource Win11ProgressBar}"/>
                                                </StackPanel>
                                            </Grid>
                                        </ToggleButton>
                                    </DataTemplate>
                                    <DataTemplate DataType="{x:Type models:ListSeparatorItem}">
                                        <Border Height="1"
                                                Background="{DynamicResource BorderBrush}"
                                                Margin="0,8,0,10"/>
                                    </DataTemplate>
                                </ItemsControl.Resources>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>

            <!-- ══════════════════════════════════════════════════════
                 ROW 3 — LOG PANEL
            ══════════════════════════════════════════════════════ -->
            <Border Grid.Row="3"
                    Margin="12,0,12,12"
                    Style="{StaticResource Win11Card}"
                    Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Background="{DynamicResource SurfaceElevatedBrush}"
                            CornerRadius="8,8,0,0"
                            Padding="16,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Orientation="Horizontal">
                                <Image Source="{DynamicResource IconLog}"
                                       Width="14" Height="14"
                                       VerticalAlignment="Center"
                                       Margin="0,0,8,0"
                                       RenderOptions.BitmapScalingMode="HighQuality"/>
                                <TextBlock Text="Output"
                                           Style="{StaticResource Win11TextSubtitle}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>

                            <Border Grid.Column="1"
                                    Background="{DynamicResource SurfaceBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    Padding="3"
                                    Height="34"
                                    Width="164"
                                    VerticalAlignment="Center">
                                <Grid Width="158"
                                      Height="28"
                                      ClipToBounds="True">
                                    <Canvas IsHitTestVisible="False">
                                        <Border Canvas.Left="{Binding IsTerminalTabSelected, Converter={StaticResource OutputTabsIndicatorLeftConverter}}"
                                                Width="79"
                                                Height="28"
                                                Background="{DynamicResource AccentBrush}"
                                                BorderBrush="{DynamicResource AccentBrush}"
                                                BorderThickness="1"
                                                Opacity="0.16"
                                                Panel.ZIndex="0"
                                                IsHitTestVisible="False">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="CornerRadius" Value="8,0,0,8"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsTerminalTabSelected}" Value="True">
                                                            <Setter Property="CornerRadius" Value="0,8,8,0"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                        </Border>
                                    </Canvas>
                                    <Grid Panel.ZIndex="1">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <RadioButton Grid.Column="0"
                                                     GroupName="OutputTabs"
                                                     IsChecked="{Binding IsTerminalTabSelected, Converter={StaticResource InverseBoolConverter}, Mode=TwoWay}"
                                                     Background="Transparent"
                                                     BorderThickness="0"
                                                     Padding="0"
                                                     Cursor="Hand"
                                                     ToolTip="Log"
                                                     HorizontalContentAlignment="Center"
                                                     VerticalContentAlignment="Center">
                                            <RadioButton.Template>
                                                <ControlTemplate TargetType="RadioButton">
                                                    <Border x:Name="HoverRoot"
                                                            CornerRadius="8,0,0,8"
                                                            Background="Transparent">
                                                        <ContentPresenter HorizontalAlignment="Center"
                                                                          VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="HoverRoot" Property="Background" Value="{DynamicResource HoverBrush}"/>
                                                            <Setter TargetName="HoverRoot" Property="Opacity" Value="0.7"/>
                                                        </Trigger>
                                                        <Trigger Property="IsPressed" Value="True">
                                                            <Setter TargetName="HoverRoot" Property="Opacity" Value="1"/>
                                                        </Trigger>
                                                        <Trigger Property="IsEnabled" Value="False">
                                                            <Setter Property="Opacity" Value="0.4"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </RadioButton.Template>
                                            <TextBlock Text="Log"
                                                       FontSize="12">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsTerminalTabSelected}" Value="False">
                                                                <Setter Property="Foreground" Value="{DynamicResource SelectionForegroundBrush}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </RadioButton>

                                        <RadioButton Grid.Column="1"
                                                     GroupName="OutputTabs"
                                                     IsChecked="{Binding IsTerminalTabSelected, Mode=TwoWay}"
                                                     Background="Transparent"
                                                     BorderThickness="0"
                                                     Padding="0"
                                                     Cursor="Hand"
                                                     ToolTip="Terminal"
                                                     HorizontalContentAlignment="Center"
                                                     VerticalContentAlignment="Center">
                                            <RadioButton.Template>
                                                <ControlTemplate TargetType="RadioButton">
                                                    <Border x:Name="HoverRoot"
                                                            CornerRadius="0,8,8,0"
                                                            Background="Transparent">
                                                        <ContentPresenter HorizontalAlignment="Center"
                                                                          VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="HoverRoot" Property="Background" Value="{DynamicResource HoverBrush}"/>
                                                            <Setter TargetName="HoverRoot" Property="Opacity" Value="0.7"/>
                                                        </Trigger>
                                                        <Trigger Property="IsPressed" Value="True">
                                                            <Setter TargetName="HoverRoot" Property="Opacity" Value="1"/>
                                                        </Trigger>
                                                        <Trigger Property="IsEnabled" Value="False">
                                                            <Setter Property="Opacity" Value="0.4"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </RadioButton.Template>
                                            <TextBlock Text="Terminal"
                                                       FontSize="12">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsTerminalTabSelected}" Value="True">
                                                                <Setter Property="Foreground" Value="{DynamicResource SelectionForegroundBrush}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </RadioButton>
                                    </Grid>
                                </Grid>
                            </Border>
                        </Grid>
                    </Border>

                    <Grid Grid.Row="1">
                        <Border Background="{DynamicResource LogBackgroundBrush}"
                                CornerRadius="0,0,8,8"
                                Visibility="{Binding IsTerminalTabSelected, Converter={StaticResource InverseBoolToVisibility}}">
                            <TextBox x:Name="LogOutputText"
                                     Text="{Binding LogViewModel.LogText}"
                                     FontFamily="Cascadia Code, Consolas, monospace"
                                     FontSize="11"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Foreground="{DynamicResource LogTextBrush}"
                                     ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                                     Padding="6"
                                     IsReadOnly="True"
                                     IsReadOnlyCaretVisible="True"
                                     TextWrapping="NoWrap"
                                     AcceptsReturn="True"
                                     behaviors:TextBoxLineHoverBehavior.IsEnabled="True"
                                     behaviors:TextBoxLineHoverBehavior.HoverBrush="{DynamicResource OutputLineHoverBrush}"
                                     Style="{x:Null}">
                                <TextBox.ContextMenu>
                                    <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                        <MenuItem Header="Copy selection"
                                                  Command="ApplicationCommands.Copy"
                                                  CommandTarget="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                        <MenuItem Header="Copy line"
                                                  Command="{Binding LogViewModel.CopyLogLineCommand}"
                                                  CommandParameter="{Binding PlacementTarget.(behaviors:TextBoxLineHoverBehavior.HoverCharacterIndex), RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                        <MenuItem Header="Copy all"
                                                  Command="{Binding LogViewModel.CopyLogAllCommand}"/>
                                    </ContextMenu>
                                </TextBox.ContextMenu>
                            </TextBox>
                        </Border>

                        <Border Background="{DynamicResource LogBackgroundBrush}"
                                CornerRadius="0,0,8,8"
                                Visibility="{Binding IsTerminalTabSelected, Converter={StaticResource BoolToVisibility}}">
                            <TextBox x:Name="TerminalOutputText"
                                     Text="{Binding LogViewModel.TerminalText}"
                                     FontFamily="Cascadia Code, Consolas, monospace"
                                     FontSize="11"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Foreground="{DynamicResource LogTextBrush}"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                                     Padding="6"
                                     IsReadOnly="True"
                                     IsReadOnlyCaretVisible="True"
                                     TextWrapping="Wrap"
                                     AcceptsReturn="True"
                                     behaviors:TextBoxLineHoverBehavior.IsEnabled="True"
                                     behaviors:TextBoxLineHoverBehavior.HoverBrush="{DynamicResource OutputLineHoverBrush}"
                                     Style="{x:Null}">
                                <TextBox.ContextMenu>
                                    <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                        <MenuItem Header="Copy selection"
                                                  Command="ApplicationCommands.Copy"
                                                  CommandTarget="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                        <MenuItem Header="Copy line"
                                                  Command="{Binding LogViewModel.CopyTerminalLineCommand}"
                                                  CommandParameter="{Binding PlacementTarget.(behaviors:TextBoxLineHoverBehavior.HoverCharacterIndex), RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                        <MenuItem Header="Copy all"
                                                  Command="{Binding LogViewModel.CopyTerminalAllCommand}"/>
                                    </ContextMenu>
                                </TextBox.ContextMenu>
                            </TextBox>
                        </Border>
                    </Grid>
                </Grid>
            </Border>

            <!-- ══════════════════════════════════════════════════════
                 SLIDING PANEL OVERLAY — Create Preset Panel
                 Appears from left with animation, overlays main content
            ══════════════════════════════════════════════════════ -->
            <Grid Grid.Row="0" Grid.RowSpan="4"
                  Visibility="{Binding IsCreatePresetPanelOpen, Converter={StaticResource BoolToVisibility}}"
                  x:Name="CreatePresetOverlay">
                
                <!-- Semi-transparent backdrop -->
                <Border Background="#80000000" x:Name="Backdrop">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Opacity" Value="0"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsCreatePresetPanelOpen}" Value="True">
                                    <DataTrigger.EnterActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                               To="1" Duration="0:0:0.2"
                                                               EasingFunction="{StaticResource EaseOut}"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </DataTrigger.EnterActions>
                                    <DataTrigger.ExitActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                               To="0" Duration="0:0:0.15"
                                                               EasingFunction="{StaticResource EaseIn}"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </DataTrigger.ExitActions>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                </Border>

                <!-- Sliding panel from left -->
                <Border x:Name="SlidingPanel"
                        Width="900"
                        HorizontalAlignment="Left"
                        Background="{DynamicResource AppBackgroundBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="0,0,1,0"
                        Effect="{StaticResource CardShadow}"
                        RenderTransformOrigin="0,0">
                    <Border.RenderTransform>
                        <TranslateTransform X="-900"/>
                    </Border.RenderTransform>
                    <Border.Style>
                        <Style TargetType="Border">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsCreatePresetPanelOpen}" Value="True">
                                    <DataTrigger.EnterActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(TranslateTransform.X)"
                                                               To="0" Duration="0:0:0.3">
                                                    <DoubleAnimation.EasingFunction>
                                                        <CubicEase EasingMode="EaseOut"/>
                                                    </DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </DataTrigger.EnterActions>
                                    <DataTrigger.ExitActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(TranslateTransform.X)"
                                                               To="-900" Duration="0:0:0.25">
                                                    <DoubleAnimation.EasingFunction>
                                                        <CubicEase EasingMode="EaseIn"/>
                                                    </DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </DataTrigger.ExitActions>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>

                    <Grid DataContext="{Binding CreatePresetViewModel}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>  <!-- Header -->
                            <RowDefinition Height="*"/>     <!-- Content -->
                            <RowDefinition Height="Auto"/>  <!-- Actions -->
                        </Grid.RowDefinitions>

                        <!-- Header -->
                        <Border Grid.Row="0"
                                Background="{DynamicResource SurfaceElevatedBrush}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="0,0,0,1"
                                Padding="20,16"
                                WindowChrome.IsHitTestVisibleInChrome="False">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Margin="0,0,0,4">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock" BasedOn="{StaticResource Win11TextTitle}">
                                                <Setter Property="Text" Value="Crea Nuovo Pacchetto"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsEditMode}" Value="True">
                                                        <Setter Property="Text" Value="Modifica Pacchetto"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <TextBlock>
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock" BasedOn="{StaticResource Win11TextSecondary}">
                                                <Setter Property="Text" Value="Configura un nuovo pacchetto di installazione personalizzato"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsEditMode}" Value="True">
                                                        <Setter Property="Text" Value="Modifica il pacchetto di installazione"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>

                                <Button Grid.Column="1"
                                        Command="{Binding CancelCommand}"
                                        Style="{StaticResource Win11CloseButton}"
                                        Width="36" Height="36"
                                        Padding="0"
                                        Margin="12,0,0,0"
                                        WindowChrome.IsHitTestVisibleInChrome="True"
                                        ToolTip="Chiudi">
                                    <Path Width="18"
                                          Height="18"
                                          Stretch="Uniform"
                                          Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                          Data="M14,7 L9,12 L14,17 L14,14 L20,14 L20,10 L14,10 Z"/>
                                </Button>
                            </Grid>
                        </Border>

                        <!-- Content -->
                        <Grid Grid.Row="1">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0"
                                    Background="{DynamicResource ErrorSurfaceBrush}"
                                    BorderBrush="{DynamicResource ErrorBrush}"
                                    BorderThickness="1"
                                    CornerRadius="{StaticResource CornerRadiusSmall}"
                                    Padding="12,8"
                                    Margin="20,16,20,0"
                                    Panel.ZIndex="100"
                                    Visibility="{Binding ValidationError, Converter={StaticResource StringToVisibilityConverter}}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Image Source="{DynamicResource IconWarning}"
                                           Width="16" Height="16"
                                           VerticalAlignment="Center"
                                           Margin="0,0,8,0"
                                           RenderOptions.BitmapScalingMode="HighQuality"/>
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding ValidationError}"
                                               Foreground="{DynamicResource ErrorBrush}"
                                               TextWrapping="Wrap"
                                               VerticalAlignment="Center"/>
                                </Grid>
                            </Border>

                            <ScrollViewer Grid.Row="1"
                                          VerticalScrollBarVisibility="Auto"
                                          Padding="20,16"
                                          behaviors:ScrollResetBehavior.IsEnabled="True">
                            <StackPanel>

                                <TextBlock Text="Nome *" Style="{StaticResource Win11TextBody}" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                <Grid Margin="0,0,0,16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <Button Grid.Column="0"
                                            Command="{Binding OpenIconPickerCommand}"
                                            Style="{StaticResource Win11Button}"
                                            Width="44" Height="44"
                                            Padding="0"
                                            Margin="0,0,10,0"
                                            ToolTip="Seleziona icona">
                                        <Grid>
                                            <Image Width="22"
                                                   Height="22"
                                                   RenderOptions.BitmapScalingMode="HighQuality"
                                                   Visibility="{Binding HasCustomIcon, Converter={StaticResource BoolToVisibility}}">
                                                <Image.Source>
                                                    <MultiBinding Converter="{StaticResource IconVariantToImageSourceConverter}">
                                                        <Binding Path="CustomIconLightPath"/>
                                                        <Binding Path="CustomIconDarkPath"/>
                                                        <Binding Path="DataContext.IsDarkTheme"
                                                                 RelativeSource="{RelativeSource AncestorType=Window}"/>
                                                    </MultiBinding>
                                                </Image.Source>
                                            </Image>

                                            <TextBlock Text="{Binding Icon}"
                                                       FontSize="18"
                                                       FontFamily="Segoe UI Emoji"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       Visibility="{Binding HasCustomIcon, Converter={StaticResource InverseBoolToVisibility}}"/>
                                        </Grid>
                                    </Button>

                                    <TextBox Grid.Column="1"
                                             Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource Win11TextBox}"/>
                                </Grid>

                                <TextBlock Text="Descrizione" Style="{StaticResource Win11TextBody}" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource Win11TextBox}"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         MinHeight="60"
                                         VerticalScrollBarVisibility="Auto"
                                         Margin="0,0,0,16"/>

                                <!-- Categoria -->
                                <TextBlock Text="Categoria" Style="{StaticResource Win11TextBody}" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                <TextBox Text="{Binding Category, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource Win11TextBox}"
                                         Margin="0,0,0,20"/>

                                <!-- Process Selection Section -->
                                <TextBlock Text="Processi *" Style="{StaticResource Win11TextBody}" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                <TextBlock Text="Trascina o sposta i processi nella colonna di destra per includerli nel pacchetto."
                                           Style="{StaticResource Win11TextSecondary}"
                                           Margin="0,0,0,12"/>

                                <!-- Two Columns Layout for Process Selection -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="16"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Left Column: Available Processes -->
                                    <Border Grid.Column="0" 
                                            Style="{StaticResource Win11Card}" 
                                            Padding="0">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>
                                            
                                            <Border Background="{DynamicResource SurfaceElevatedBrush}" Padding="10,8" CornerRadius="8,8,0,0">
                                                <TextBlock Text="Disponibili"
                                                           FontWeight="SemiBold"
                                                           FontSize="14"
                                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                                            </Border>

                                            <Grid Grid.Row="1" Margin="8">
                                                <TextBox Grid.Column="0"
                                                         Text="{Binding AvailableSearchText, UpdateSourceTrigger=PropertyChanged}"
                                                         Style="{StaticResource Win11TextBox}"
                                                         Padding="28,4,8,4"
                                                         FontSize="14"/>
                                                <Image Source="{DynamicResource IconSearch}"
                                                       Width="14" Height="14"
                                                       HorizontalAlignment="Left"
                                                       VerticalAlignment="Center"
                                                       Margin="10,0,0,0"
                                                       Opacity="0.55"
                                                       IsHitTestVisible="False"
                                                       RenderOptions.BitmapScalingMode="HighQuality"/>
                                            </Grid>

                                            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" MaxHeight="260">
                                                <ScrollViewer.Resources>
                                                    <SolidColorBrush x:Key="ScrollFadeOverlayBrush" Color="{DynamicResource SurfaceColor}"/>
                                                </ScrollViewer.Resources>
                                                <ItemsControl ItemsSource="{Binding FilteredAvailableProcesses}">
                                                    <ItemsControl.ItemContainerStyle>
                                                        <Style TargetType="ContentPresenter">
                                                            <Setter Property="HorizontalAlignment" Value="Stretch"/>
                                                        </Style>
                                                    </ItemsControl.ItemContainerStyle>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <ToggleButton Command="{Binding DataContext.ActivateProcessCommand, RelativeSource={RelativeSource AncestorType=ScrollViewer}}"
                                                                          CommandParameter="{Binding}"
                                                                          Style="{StaticResource ProcessCardToggleButton}"
                                                                          Margin="4" Padding="8,6">
                                                                <Grid>
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="*"/>
                                                                        <ColumnDefinition Width="Auto"/>
                                                                    </Grid.ColumnDefinitions>
                                                                    <StackPanel>
                                                                        <TextBlock Text="{Binding Name}"
                                                                                   FontWeight="SemiBold"
                                                                                   FontSize="14"
                                                                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                                        <TextBlock Text="{Binding Description}"
                                                                                   FontSize="12"
                                                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                                                   TextTrimming="CharacterEllipsis"/>
                                                                    </StackPanel>
                                                                    <TextBlock Grid.Column="1"
                                                                               Text="➜"
                                                                               FontSize="14"
                                                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                                                               VerticalAlignment="Center"
                                                                               Margin="4,0,0,0"/>
                                                                </Grid>
                                                            </ToggleButton>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </ScrollViewer>
                                        </Grid>
                                    </Border>

                                    <!-- Center Arrows -->
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0">
                                        <TextBlock Text="⇄" FontSize="18" Opacity="0.3" HorizontalAlignment="Center"/>
                                    </StackPanel>

                                    <!-- Right Column: Selected Processes -->
                                    <Border Grid.Column="2" 
                                            Style="{StaticResource Win11Card}" 
                                            Padding="0">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>

                                            <Border Background="{DynamicResource SurfaceElevatedBrush}" Padding="10,8" CornerRadius="8,8,0,0">
                                                <TextBlock Text="Selezionati (Coda)"
                                                           FontWeight="SemiBold"
                                                           FontSize="14"
                                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                                            </Border>

                                            <Grid Grid.Row="1" Margin="8">
                                                <TextBox Grid.Column="0"
                                                         Text="{Binding SelectedSearchText, UpdateSourceTrigger=PropertyChanged}"
                                                         Style="{StaticResource Win11TextBox}"
                                                         Padding="28,4,8,4"
                                                         FontSize="14"/>
                                                <Image Source="{DynamicResource IconSearch}"
                                                       Width="14" Height="14"
                                                       HorizontalAlignment="Left"
                                                       VerticalAlignment="Center"
                                                       Margin="10,0,0,0"
                                                       Opacity="0.55"
                                                       IsHitTestVisible="False"
                                                       RenderOptions.BitmapScalingMode="HighQuality"/>
                                            </Grid>

                                            <ListBox Grid.Row="2"
                                                     ItemsSource="{Binding FilteredSelectedProcesses}"
                                                     Background="Transparent"
                                                     BorderThickness="0"
                                                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                                                     MaxHeight="260"
                                                     HorizontalContentAlignment="Stretch"
                                                     behaviors:DragDropReorder.IsEnabled="{Binding IsSelectedReorderEnabled}"
                                                     behaviors:DragDropReorder.ReorderCommand="{Binding ReorderSelectedProcessCommand}">
                                                <ListBox.Resources>
                                                    <SolidColorBrush x:Key="ScrollFadeOverlayBrush" Color="{DynamicResource SurfaceColor}"/>
                                                </ListBox.Resources>
                                                <ListBox.ItemContainerStyle>
                                                    <Style TargetType="ListBoxItem">
                                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                                    </Style>
                                                </ListBox.ItemContainerStyle>
                                                <ListBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Background="{DynamicResource SurfaceBrush}"
                                                                BorderBrush="{DynamicResource BorderBrush}"
                                                                BorderThickness="1"
                                                                CornerRadius="4"
                                                                Margin="4"
                                                                Padding="6"
                                                                HorizontalAlignment="Stretch">
                                                            <Border.Style>
                                                                <Style TargetType="Border">
                                                                    <Setter Property="Opacity" Value="1"/>
                                                                    <Setter Property="Effect" Value="{x:Null}"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=(behaviors:DragDropReorder.IsDropTarget)}" Value="True">
                                                                            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                                                            <Setter Property="BorderThickness" Value="2"/>
                                                                        </DataTrigger>
                                                                    <DataTrigger Binding="{Binding IsDragging}" Value="True">
                                                                        <Setter Property="Opacity" Value="0.35"/>
                                                                        <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                                                    </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Border.Style>
                                                            <Grid>
                                                                <Grid.RowDefinitions>
                                                                    <RowDefinition Height="Auto"/>
                                                                    <RowDefinition Height="Auto"/>
                                                                </Grid.RowDefinitions>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                </Grid.ColumnDefinitions>

                                                                <Button Grid.Column="0"
                                                                        Command="{Binding DataContext.DeactivateProcessCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                                        CommandParameter="{Binding}"
                                                                        Style="{StaticResource Win11Button}"
                                                                        Width="28" Height="28" Padding="0" Margin="0,0,8,0">
                                                                    <TextBlock Text="⬅"
                                                                               FontSize="14"
                                                                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                                </Button>

                                                                <StackPanel Grid.Column="1">
                                                                    <TextBlock Text="{Binding Name}"
                                                                               FontWeight="SemiBold"
                                                                               FontSize="14"
                                                                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                                    <CheckBox IsChecked="{Binding IsRequired}" Margin="0,4,0,0">
                                                                        <TextBlock Text="Richiesto"
                                                                                   FontSize="12"
                                                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                                                   Opacity="0.7"/>
                                                                    </CheckBox>
                                                                </StackPanel>

                                                                <StackPanel Grid.Column="2" Orientation="Horizontal">
                                                                    <Button Command="{Binding DataContext.MoveProcessUpCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                                            CommandParameter="{Binding}"
                                                                            Style="{StaticResource Win11Button}"
                                                                            Width="28" Height="28" Padding="0" Margin="0,0,4,0">
                                                                        <TextBlock Text="▲"
                                                                                   FontSize="14"
                                                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                                                   VerticalAlignment="Center"
                                                                                   HorizontalAlignment="Center"/>
                                                                    </Button>
                                                                    <Button Command="{Binding DataContext.MoveProcessDownCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                                            CommandParameter="{Binding}"
                                                                            Style="{StaticResource Win11Button}"
                                                                            Width="28" Height="28" Padding="0">
                                                                        <TextBlock Text="▼"
                                                                                   FontSize="14"
                                                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                                                   VerticalAlignment="Center"
                                                                                   HorizontalAlignment="Center"/>
                                                                    </Button>
                                                                </StackPanel>
                                                            </Grid>
                                                        </Border>
                                                    </DataTemplate>
                                                </ListBox.ItemTemplate>
                                            </ListBox>
                                        </Grid>
                                    </Border>
                                </Grid>

                                <Border Background="{DynamicResource WarningSurfaceBrush}"
                                        BorderBrush="{DynamicResource WarningBrush}"
                                        BorderThickness="1"
                                        CornerRadius="{StaticResource CornerRadiusSmall}"
                                        Padding="12"
                                        Margin="0,16,0,0"
                                        Visibility="{Binding HasMissingProcesses, Converter={StaticResource BoolToVisibility}}">
                                    <StackPanel>
                                        <TextBlock Text="Riferimenti a processi mancanti"
                                                   Style="{StaticResource Win11TextBody}"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource WarningBrush}"/>
                                        <TextBlock Text="Questi step restano nel pacchetto come riferimento testuale e vengono ignorati in esecuzione finché non li associ a un processo esistente."
                                                   Style="{StaticResource Win11TextSecondary}"
                                                   TextWrapping="Wrap"
                                                   Margin="0,4,0,10"/>

                                        <ItemsControl ItemsSource="{Binding MissingProcesses}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="{DynamicResource SurfaceBrush}"
                                                            BorderBrush="{DynamicResource BorderBrush}"
                                                            BorderThickness="1"
                                                            CornerRadius="{StaticResource CornerRadiusSmall}"
                                                            Padding="10"
                                                            Margin="0,0,0,8">
                                                        <Grid>
                                                            <Grid.RowDefinitions>
                                                                <RowDefinition Height="Auto"/>
                                                                <RowDefinition Height="Auto"/>
                                                            </Grid.RowDefinitions>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>

                                                            <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,12,8">
                                                                <TextBlock Text="{Binding ProcessId}"
                                                                           Style="{StaticResource Win11TextBody}"
                                                                           FontWeight="SemiBold"/>
                                                                <TextBlock Style="{StaticResource Win11TextSecondary}">
                                                                    <Run Text="Ordine: "/>
                                                                    <Run Text="{Binding Order, Mode=OneWay}"/>
                                                                    <Run Text=" · "/>
                                                                </TextBlock>
                                                                <TextBlock Text="Step richiesto"
                                                                           Style="{StaticResource Win11TextSecondary}"
                                                                           Margin="0,2,0,0"
                                                                           Visibility="{Binding IsRequired, Converter={StaticResource BoolToVisibility}}"/>
                                                                <TextBlock Text="Step opzionale"
                                                                           Style="{StaticResource Win11TextSecondary}"
                                                                           Margin="0,2,0,0"
                                                                           Visibility="{Binding IsRequired, Converter={StaticResource InverseBoolToVisibility}}"/>
                                                            </StackPanel>

                                                            <Border Grid.Row="0" Grid.Column="1"
                                                                    Background="{DynamicResource WarningSurfaceBrush}"
                                                                    Style="{StaticResource Win11Badge}"
                                                                    VerticalAlignment="Top">
                                                                <TextBlock Text="Non risolto"
                                                                           Style="{StaticResource Win11BadgeText}"
                                                                           Foreground="{DynamicResource WarningBrush}"/>
                                                            </Border>

                                                            <Grid Grid.Row="1" Grid.ColumnSpan="2">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                </Grid.ColumnDefinitions>

                                                                <ComboBox Grid.Column="0"
                                                                          ItemsSource="{Binding DataContext.ReplacementProcesses, RelativeSource={RelativeSource AncestorType=ScrollViewer}}"
                                                                          SelectedValue="{Binding SelectedReplacementProcessId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                          SelectedValuePath="Id"
                                                                          DisplayMemberPath="Name"
                                                                          Style="{StaticResource Win11ComboBox}"
                                                                          MinHeight="36"/>

                                                                <Button Grid.Column="1"
                                                                        Content="Associa"
                                                                        Command="{Binding DataContext.ResolveMissingProcessCommand, RelativeSource={RelativeSource AncestorType=ScrollViewer}}"
                                                                        CommandParameter="{Binding}"
                                                                        Style="{StaticResource Win11Button}"
                                                                        Height="36"
                                                                        MinWidth="110"
                                                                        Margin="10,0,0,0"/>
                                                            </Grid>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                            </ScrollViewer>

                            <Grid Background="#80000000"
                                  Visibility="{Binding IsIconPickerOpen, Converter={StaticResource BoolToVisibility}}">
                                <Border Style="{StaticResource Win11Card}"
                                        Padding="16"
                                        Width="620"
                                        MaxHeight="680"
                                        VerticalAlignment="Center"
                                        HorizontalAlignment="Center">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <Grid Grid.Row="0" Margin="0,0,0,12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Text="Seleziona icona"
                                                       Style="{StaticResource Win11TextSubtitle}"
                                                       FontWeight="SemiBold"/>

                                            <Button Grid.Column="1"
                                                    Command="{Binding CloseIconPickerCommand}"
                                                    Style="{StaticResource Win11CloseButton}"
                                                    Width="32"
                                                    Height="32"
                                                    Padding="0">
                                                <TextBlock Text="✕" FontSize="14"/>
                                            </Button>
                                        </Grid>

                                        <ScrollViewer Grid.Row="1"
                                                      VerticalScrollBarVisibility="Auto">
                                            <StackPanel>
                                                <TextBlock Text="Emoji"
                                                           Style="{StaticResource Win11TextBody}"
                                                           FontWeight="SemiBold"
                                                           Margin="0,0,0,8"/>

                                                <ItemsControl ItemsSource="{Binding AvailableIcons}"
                                                              Margin="0,0,0,16">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <WrapPanel/>
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Button Command="{Binding DataContext.SelectEmojiIconCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                    CommandParameter="{Binding}"
                                                                    Style="{StaticResource Win11Button}"
                                                                    Width="44"
                                                                    Height="44"
                                                                    Padding="0"
                                                                    Margin="0,0,8,8">
                                                                <TextBlock Text="{Binding}"
                                                                           FontSize="20"
                                                                           FontFamily="Segoe UI Emoji"
                                                                           HorizontalAlignment="Center"
                                                                           VerticalAlignment="Center"/>
                                                            </Button>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>

                                                <TextBlock Text="Icone caricate"
                                                           Style="{StaticResource Win11TextBody}"
                                                           FontWeight="SemiBold"
                                                           Margin="0,0,0,8"/>

                                                <Border Background="{DynamicResource SurfaceElevatedBrush}"
                                                        BorderBrush="{DynamicResource BorderBrush}"
                                                        BorderThickness="1"
                                                        CornerRadius="{StaticResource CornerRadiusSmall}"
                                                        Padding="12"
                                                        Margin="0,0,0,12">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>

                                                        <Border Width="40"
                                                                Height="40"
                                                                CornerRadius="{StaticResource CornerRadiusSmall}"
                                                                Background="{DynamicResource SurfaceBrush}"
                                                                BorderBrush="{DynamicResource BorderBrush}"
                                                                BorderThickness="1"
                                                                VerticalAlignment="Center"
                                                                Margin="0,0,12,0">
                                                            <Grid>
                                                                <Image Width="22"
                                                                       Height="22"
                                                                       RenderOptions.BitmapScalingMode="HighQuality"
                                                                       Visibility="{Binding HasCustomIcon, Converter={StaticResource BoolToVisibility}}">
                                                                    <Image.Source>
                                                                        <MultiBinding Converter="{StaticResource IconVariantToImageSourceConverter}">
                                                                            <Binding Path="CustomIconLightPath"/>
                                                                            <Binding Path="CustomIconDarkPath"/>
                                                                            <Binding Path="DataContext.IsDarkTheme"
                                                                                     RelativeSource="{RelativeSource AncestorType=Window}"/>
                                                                        </MultiBinding>
                                                                    </Image.Source>
                                                                </Image>

                                                                <TextBlock Text="{Binding Icon}"
                                                                           FontSize="18"
                                                                           FontFamily="Segoe UI Emoji"
                                                                           HorizontalAlignment="Center"
                                                                           VerticalAlignment="Center"
                                                                           Visibility="{Binding HasCustomIcon, Converter={StaticResource InverseBoolToVisibility}}"/>
                                                            </Grid>
                                                        </Border>

                                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                            <CheckBox Content="Scegli icona diversa per tema"
                                                                      IsChecked="{Binding UseSeparateThemeIcons}"
                                                                      Style="{StaticResource Win11ToggleSwitch}"/>
                                                            <TextBlock Text="Se attivo, puoi scegliere un’icona per tema chiaro e una per tema scuro."
                                                                       Style="{StaticResource Win11TextSecondary}"
                                                                       FontSize="11"
                                                                       Margin="0,4,0,0"/>
                                                        </StackPanel>

                                                        <Button Grid.Column="2"
                                                                Content="Importa"
                                                                Command="{Binding ImportLibraryIconCommand}"
                                                                Style="{StaticResource Win11Button}"
                                                                Height="36"
                                                                MinWidth="120"
                                                                VerticalAlignment="Center"/>
                                                    </Grid>
                                                </Border>

                                                <StackPanel Orientation="Horizontal"
                                                            Margin="0,0,0,12"
                                                            Visibility="{Binding UseSeparateThemeIcons, Converter={StaticResource BoolToVisibility}}">
                                                    <Button Content="Chiaro"
                                                            Command="{Binding SetIconPickerTargetLightCommand}"
                                                            Height="32"
                                                            MinWidth="120">
                                                        <Button.Style>
                                                            <Style TargetType="Button" BasedOn="{StaticResource Win11Button}">
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsIconPickerTargetDark}" Value="False">
                                                                        <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                                                                        <Setter Property="Foreground" Value="White"/>
                                                                        <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Button.Style>
                                                    </Button>
                                                    <Button Content="Scuro"
                                                            Command="{Binding SetIconPickerTargetDarkCommand}"
                                                            Height="32"
                                                            MinWidth="120"
                                                            Margin="8,0,0,0">
                                                        <Button.Style>
                                                            <Style TargetType="Button" BasedOn="{StaticResource Win11Button}">
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsIconPickerTargetDark}" Value="True">
                                                                        <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                                                                        <Setter Property="Foreground" Value="White"/>
                                                                        <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Button.Style>
                                                    </Button>
                                                </StackPanel>

                                                <ItemsControl ItemsSource="{Binding LibraryIcons}"
                                                              Margin="0,0,0,16">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <WrapPanel/>
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Button Command="{Binding DataContext.SelectLibraryIconCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                    CommandParameter="{Binding}"
                                                                    Style="{StaticResource Win11Button}"
                                                                    Width="56"
                                                                    Height="56"
                                                                    Padding="0"
                                                                    Margin="0,0,8,8">
                                                                <Image Stretch="Uniform"
                                                                       RenderOptions.BitmapScalingMode="HighQuality"
                                                                       Width="28"
                                                                       Height="28">
                                                                    <Image.Source>
                                                                        <MultiBinding Converter="{StaticResource IconVariantToImageSourceConverter}">
                                                                            <Binding Path="LightPath"/>
                                                                            <Binding Path="DarkPath"/>
                                                                            <Binding Path="DataContext.IsDarkTheme"
                                                                                     RelativeSource="{RelativeSource AncestorType=Window}"/>
                                                                        </MultiBinding>
                                                                    </Image.Source>
                                                                </Image>
                                                            </Button>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>

                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="12"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>

                                                    <StackPanel Grid.Column="0">
                                                        <TextBlock Text="Chiaro"
                                                                   Style="{StaticResource Win11TextSecondary}"
                                                                   Margin="0,0,0,6"/>
                                                        <Border Background="{DynamicResource SurfaceElevatedBrush}"
                                                                BorderBrush="{DynamicResource BorderBrush}"
                                                                BorderThickness="1"
                                                                CornerRadius="{StaticResource CornerRadiusSmall}"
                                                                Width="96"
                                                                Height="96"
                                                                HorizontalAlignment="Left">
                                                            <Image Stretch="Uniform"
                                                                   RenderOptions.BitmapScalingMode="HighQuality">
                                                                <Image.Source>
                                                                    <MultiBinding Converter="{StaticResource IconVariantToImageSourceConverter}">
                                                                        <Binding Path="CustomIconLightPath"/>
                                                                        <Binding Path="CustomIconDarkPath"/>
                                                                        <Binding Source="False"/>
                                                                    </MultiBinding>
                                                                </Image.Source>
                                                            </Image>
                                                        </Border>
                                                    </StackPanel>

                                                    <StackPanel Grid.Column="2">
                                                        <TextBlock Text="Scuro"
                                                                   Style="{StaticResource Win11TextSecondary}"
                                                                   Margin="0,0,0,6"/>
                                                        <Border Background="{DynamicResource SurfaceElevatedBrush}"
                                                                BorderBrush="{DynamicResource BorderBrush}"
                                                                BorderThickness="1"
                                                                CornerRadius="{StaticResource CornerRadiusSmall}"
                                                                Width="96"
                                                                Height="96"
                                                                HorizontalAlignment="Left">
                                                            <Image Stretch="Uniform"
                                                                   RenderOptions.BitmapScalingMode="HighQuality">
                                                                <Image.Source>
                                                                    <MultiBinding Converter="{StaticResource IconVariantToImageSourceConverter}">
                                                                        <Binding Path="CustomIconLightPath"/>
                                                                        <Binding Path="CustomIconDarkPath"/>
                                                                        <Binding Source="True"/>
                                                                    </MultiBinding>
                                                                </Image.Source>
                                                            </Image>
                                                        </Border>
                                                    </StackPanel>
                                                </Grid>
                                            </StackPanel>
                                        </ScrollViewer>

                                        <Grid Grid.Row="2" Margin="0,12,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <Button Content="Rimuovi"
                                                    Command="{Binding RemoveCustomIconCommand}"
                                                    Style="{StaticResource Win11Button}"
                                                    Height="36"
                                                    Visibility="{Binding HasCustomIcon, Converter={StaticResource BoolToVisibility}}"
                                                    HorizontalAlignment="Left"/>

                                            <Button Grid.Column="1"
                                                    Content="Chiudi"
                                                    Command="{Binding CloseIconPickerCommand}"
                                                    Style="{StaticResource Win11AccentButton}"
                                                    Height="36"
                                                    MinWidth="120"/>
                                        </Grid>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Grid>

                        <!-- Action buttons -->
                        <Border Grid.Row="2"
                                Background="{DynamicResource SurfaceElevatedBrush}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="0,1,0,0"
                                Padding="20,16">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="0,0,8,0">
                                    <Button Content="Elimina"
                                            Command="{Binding DeleteCommand}"
                                            Height="40"
                                            MinWidth="100"
                                            Margin="0,0,8,0"
                                            Visibility="{Binding IsEditMode, Converter={StaticResource BoolToVisibility}}">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource Win11Button}">
                                                <Setter Property="Foreground" Value="{DynamicResource ErrorBrush}"/>
                                            </Style>
                                        </Button.Style>
                                    </Button>

                                    <Button Content="Annulla"
                                            Command="{Binding CancelCommand}"
                                            Style="{StaticResource Win11Button}"
                                            Height="40"
                                            MinWidth="100"/>

                                    <Button Content="Importa"
                                            Command="{Binding DataContext.ImportPackageIntoEditorCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            Style="{StaticResource Win11Button}"
                                            Height="40"
                                            MinWidth="100"
                                            Margin="8,0,0,0"/>

                                    <Button Content="Esporta"
                                            Command="{Binding DataContext.ExportPackageFromEditorCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            Style="{StaticResource Win11Button}"
                                            Height="40"
                                            MinWidth="100"
                                            Margin="8,0,0,0"/>
                                </StackPanel>

                                <Button Grid.Column="1"
                                        Command="{Binding SaveCommand}"
                                        Height="40"
                                        MinWidth="140">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource Win11AccentButton}">
                                            <Setter Property="Content" Value="Salva Pacchetto"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsEditMode}" Value="True">
                                                    <Setter Property="Content" Value="Salva Modifiche"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>
            </Grid>

            <Grid Grid.Row="0" Grid.RowSpan="4"
                  Visibility="{Binding IsCreateProcessPanelOpen, Converter={StaticResource BoolToVisibility}}"
                  x:Name="CreateProcessOverlay">

                <Border Background="#80000000">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Opacity" Value="0"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsCreateProcessPanelOpen}" Value="True">
                                    <DataTrigger.EnterActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                               To="1" Duration="0:0:0.2"
                                                               EasingFunction="{StaticResource EaseOut}"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </DataTrigger.EnterActions>
                                    <DataTrigger.ExitActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                               To="0" Duration="0:0:0.15"
                                                               EasingFunction="{StaticResource EaseIn}"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </DataTrigger.ExitActions>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                </Border>

                <Border Width="700"
                        HorizontalAlignment="Right"
                        Background="{DynamicResource AppBackgroundBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1,0,0,0"
                        Effect="{StaticResource CardShadow}"
                        RenderTransformOrigin="1,0">
                    <Border.RenderTransform>
                        <TranslateTransform X="700"/>
                    </Border.RenderTransform>
                    <Border.Style>
                        <Style TargetType="Border">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsCreateProcessPanelOpen}" Value="True">
                                    <DataTrigger.EnterActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(TranslateTransform.X)"
                                                               To="0" Duration="0:0:0.3">
                                                    <DoubleAnimation.EasingFunction>
                                                        <CubicEase EasingMode="EaseOut"/>
                                                    </DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </DataTrigger.EnterActions>
                                    <DataTrigger.ExitActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(TranslateTransform.X)"
                                                               To="700" Duration="0:0:0.25">
                                                    <DoubleAnimation.EasingFunction>
                                                        <CubicEase EasingMode="EaseIn"/>
                                                    </DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </DataTrigger.ExitActions>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>

                    <Grid DataContext="{Binding CreateProcessViewModel}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0"
                                Background="{DynamicResource SurfaceElevatedBrush}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="0,0,0,1"
                                Padding="20,16"
                                WindowChrome.IsHitTestVisibleInChrome="False">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Button Grid.Column="0"
                                        Command="{Binding CancelCommand}"
                                        Style="{StaticResource Win11CloseButton}"
                                        Width="36" Height="36"
                                        Padding="0"
                                        Margin="0,0,12,0"
                                        WindowChrome.IsHitTestVisibleInChrome="True"
                                        ToolTip="Chiudi">
                                    <Path Width="18"
                                          Height="18"
                                          Stretch="Uniform"
                                          Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                          Data="M10,7 L15,12 L10,17 L10,14 L4,14 L4,10 L10,10 Z"/>
                                </Button>

                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                    <Image Source="{DynamicResource IconSettings}"
                                           Width="18" Height="18"
                                           VerticalAlignment="Center"
                                           Margin="0,0,10,0"
                                           RenderOptions.BitmapScalingMode="HighQuality"/>
                                    <TextBlock Text="{Binding Title}"
                                               Style="{StaticResource Win11TextTitle}"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Grid Grid.Row="1">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0"
                                    Background="{DynamicResource ErrorSurfaceBrush}"
                                    BorderBrush="{DynamicResource ErrorBrush}"
                                    BorderThickness="1"
                                    CornerRadius="{StaticResource CornerRadiusSmall}"
                                    Padding="12,8"
                                    Margin="20,16,20,0"
                                    Panel.ZIndex="100"
                                    Visibility="{Binding ValidationError, Converter={StaticResource StringToVisibilityConverter}}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Image Source="{DynamicResource IconError}"
                                           Width="16" Height="16"
                                           VerticalAlignment="Center"
                                           Margin="0,0,8,0"
                                           RenderOptions.BitmapScalingMode="HighQuality"/>
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding ValidationError}"
                                               Foreground="{DynamicResource ErrorBrush}"
                                               TextWrapping="Wrap"
                                               VerticalAlignment="Center"/>
                                </Grid>
                            </Border>

                            <ScrollViewer Grid.Row="1"
                                          VerticalScrollBarVisibility="Auto"
                                          Padding="20,16"
                                          behaviors:ScrollResetBehavior.IsEnabled="True">
                                <StackPanel>
                                    <TextBlock Text="Nome Processo *"
                                               Style="{StaticResource Win11TextBody}"
                                               FontWeight="SemiBold"
                                               Margin="0,0,0,6"/>
                                    <Grid Margin="0,0,0,16">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <Button Grid.Column="0"
                                                Command="{Binding OpenIconPickerCommand}"
                                                Style="{StaticResource Win11Button}"
                                                Width="44"
                                                Height="44"
                                                Padding="0"
                                                Margin="0,0,10,0"
                                                ToolTip="Seleziona icona">
                                            <Grid>
                                                <Image Width="22"
                                                       Height="22"
                                                       RenderOptions.BitmapScalingMode="HighQuality"
                                                       Visibility="{Binding HasCustomIcon, Converter={StaticResource BoolToVisibility}}">
                                                    <Image.Source>
                                                        <MultiBinding Converter="{StaticResource IconVariantToImageSourceConverter}">
                                                            <Binding Path="CustomIconLightPath"/>
                                                            <Binding Path="CustomIconDarkPath"/>
                                                            <Binding Path="DataContext.IsDarkTheme"
                                                                     RelativeSource="{RelativeSource AncestorType=Window}"/>
                                                        </MultiBinding>
                                                    </Image.Source>
                                                </Image>

                                                <TextBlock Text="{Binding Icon}"
                                                           FontSize="18"
                                                           FontFamily="Segoe UI Emoji"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           Visibility="{Binding HasCustomIcon, Converter={StaticResource InverseBoolToVisibility}}"/>
                                            </Grid>
                                        </Button>

                                        <TextBox Grid.Column="1"
                                                 Text="{Binding ProcessName, UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{StaticResource Win11TextBox}"/>
                                    </Grid>

                                    <TextBlock Text="Descrizione"
                                               Style="{StaticResource Win11TextBody}"
                                               FontWeight="SemiBold"
                                               Margin="0,0,0,6"/>
                                    <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource Win11TextBox}"
                                             Margin="0,0,0,16"/>

                                    <TextBlock Text="Tipo di Processo *"
                                               Style="{StaticResource Win11TextBody}"
                                               FontWeight="SemiBold"
                                               Margin="0,0,0,6"/>
                                    <ComboBox ItemsSource="{Binding AvailableProcessKinds}"
                                              SelectedItem="{Binding SelectedProcessKind}"
                                              Style="{StaticResource Win11ComboBox}"
                                              Margin="0,0,0,16">
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock>
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Text" Value="{Binding}"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding}" Value="{x:Static models:ProcessKind.Installer}">
                                                                    <Setter Property="Text" Value="Installer (.exe, .msi, .zip)"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding}" Value="{x:Static models:ProcessKind.PowerShellScript}">
                                                                    <Setter Property="Text" Value="PowerShell Script"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding}" Value="{x:Static models:ProcessKind.BatchScript}">
                                                                    <Setter Property="Text" Value="Batch/CMD Script"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>

                                    <StackPanel Visibility="{Binding IsInstallerMode, Converter={StaticResource BoolToVisibility}}">
                                        <TextBlock Text="Sorgente Installer *"
                                                   Style="{StaticResource Win11TextBody}"
                                                   FontWeight="SemiBold"
                                                   Margin="0,0,0,6"/>

                                        <Border Background="{DynamicResource SurfaceBrush}"
                                                BorderBrush="{DynamicResource BorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="12"
                                                Padding="3"
                                                Height="48"
                                                Width="480"
                                                Margin="0,0,0,8">
                                            <Grid Width="474"
                                                  Height="42"
                                                  ClipToBounds="True">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>

                                                <Border x:Name="InstallerSourceIndicator"
                                                        Background="{DynamicResource AccentBrush}"
                                                        BorderBrush="{DynamicResource AccentBrush}"
                                                        BorderThickness="1"
                                                        Opacity="0.20"
                                                        CornerRadius="10"
                                                        IsHitTestVisible="False"
                                                        Panel.ZIndex="0">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Grid.Column" Value="0"/>
                                                            <Setter Property="CornerRadius" Value="10,0,0,10"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding InstallerSourceMode}" Value="{x:Static models:InstallerSourceMode.StaticWeb}">
                                                                    <Setter Property="Grid.Column" Value="1"/>
                                                                    <Setter Property="CornerRadius" Value="0"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding InstallerSourceMode}" Value="{x:Static models:InstallerSourceMode.DynamicWeb}">
                                                                    <Setter Property="Grid.Column" Value="2"/>
                                                                    <Setter Property="CornerRadius" Value="0,10,10,0"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                </Border>

                                                <RadioButton Grid.Column="0"
                                                             GroupName="InstallerSourceMode"
                                                             IsChecked="{Binding IsInstallerSourceLocal, Mode=TwoWay}"
                                                             Cursor="Hand"
                                                             Style="{StaticResource Win11SegmentRadioButton}"
                                                             Panel.ZIndex="1">
                                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                        <Viewbox Width="18" Height="18" Margin="0,0,8,0">
                                                            <Path Data="M10 4H4C2.9 4 2 4.9 2 6V18C2 19.1 2.9 20 4 20H16C17.1 20 18 19.1 18 18V12H16V18H4V6H10V4ZM20 4H14V6H20V4ZM20 8H14V10H20V8ZM20 12H14V14H20V12ZM20 16H14V18H20V16Z"
                                                                  Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"/>
                                                        </Viewbox>
                                                        <TextBlock Text="Statico (Locale)"
                                                                   FontSize="13"
                                                                   FontWeight="SemiBold"
                                                                   VerticalAlignment="Center"
                                                                   Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"/>
                                                    </StackPanel>
                                                </RadioButton>

                                                <RadioButton Grid.Column="1"
                                                             GroupName="InstallerSourceMode"
                                                             IsChecked="{Binding IsInstallerSourceStaticWeb, Mode=TwoWay}"
                                                             Cursor="Hand"
                                                             Style="{StaticResource Win11SegmentRadioButton}"
                                                             Panel.ZIndex="1">
                                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                        <Viewbox Width="18" Height="18" Margin="0,0,8,0">
                                                            <Path Data="M5 20H19V18H5V20ZM12 2C8.13 2 5 5.13 5 9C5 11.38 6.19 13.47 8 14.74V17C8 17.55 8.45 18 9 18H15C15.55 18 16 17.55 16 17V14.74C17.81 13.47 19 11.38 19 9C19 5.13 15.87 2 12 2ZM14 14H10V13.5C10 12.95 9.55 12.5 9 12.5C7.62 11.66 6.75 10.23 6.75 9C6.75 6.66 8.66 4.75 11 4.75H13C15.34 4.75 17.25 6.66 17.25 9C17.25 10.23 16.38 11.66 15 12.5C14.45 12.5 14 12.95 14 13.5V14Z"
                                                                  Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"/>
                                                        </Viewbox>
                                                        <TextBlock Text="Statico (Web)"
                                                                   FontSize="13"
                                                                   FontWeight="SemiBold"
                                                                   VerticalAlignment="Center"
                                                                   Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"/>
                                                    </StackPanel>
                                                </RadioButton>

                                                <RadioButton Grid.Column="2"
                                                             GroupName="InstallerSourceMode"
                                                             IsChecked="{Binding IsInstallerSourceDynamicWeb, Mode=TwoWay}"
                                                             Cursor="Hand"
                                                             Style="{StaticResource Win11SegmentRadioButton}"
                                                             Panel.ZIndex="1">
                                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                        <Viewbox Width="18" Height="18" Margin="0,0,8,0">
                                                            <Path Data="M10 4H2V6H10V4ZM10 8H2V10H10V8ZM2 12H10V14H2V12ZM12 20H22V18H12V20ZM16 4H22V10H16V4ZM18 6V8H20V6H18ZM12 12H22V14H12V12ZM12 16H22V18H12V16Z"
                                                                  Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"/>
                                                        </Viewbox>
                                                        <TextBlock Text="Dinamico (Web)"
                                                                   FontSize="13"
                                                                   FontWeight="SemiBold"
                                                                   VerticalAlignment="Center"
                                                                   Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"/>
                                                    </StackPanel>
                                                </RadioButton>
                                            </Grid>
                                        </Border>

                                        <TextBlock FontSize="12"
                                                   TextWrapping="Wrap"
                                                   Margin="0,0,0,16">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock" BasedOn="{StaticResource Win11TextSecondary}">
                                                    <Setter Property="Text" Value="Scegli come ottenere l'installer."/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding InstallerSourceMode}" Value="{x:Static models:InstallerSourceMode.StaticLocal}">
                                                            <Setter Property="Text" Value="Usa un file installer già presente sul PC (nessun download)."/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding InstallerSourceMode}" Value="{x:Static models:InstallerSourceMode.StaticWeb}">
                                                            <Setter Property="Text" Value="Scarica un file .exe da un link diretto. Se il file è già stato scaricato, verrà usato come fallback finché non premi “Riscarica installer”."/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding InstallerSourceMode}" Value="{x:Static models:InstallerSourceMode.DynamicWeb}">
                                                            <Setter Property="Text" Value="Inserisci una cartella web (es. Passepartout). Puoi scegliere la versione e poi selezionare quale .exe scaricare."/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>

                                        <StackPanel Visibility="{Binding IsInstallerSourceLocal, Converter={StaticResource BoolToVisibility}}">
                                            <TextBlock Text="Percorso File Installer *"
                                                       Style="{StaticResource Win11TextBody}"
                                                       FontWeight="SemiBold"
                                                       Margin="0,0,0,6"/>
                                            <Grid Margin="0,0,0,16">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBox Grid.Column="0"
                                                         Text="{Binding FilePath, UpdateSourceTrigger=PropertyChanged}"
                                                         Style="{StaticResource Win11TextBox}"
                                                         Margin="0,0,8,0"/>
                                                <Button Grid.Column="1"
                                                        Content="Sfoglia..."
                                                        Command="{Binding BrowseFileCommand}"
                                                        Style="{StaticResource Win11Button}"
                                                        Padding="12,6"/>
                                            </Grid>
                                        </StackPanel>

                                        <StackPanel Visibility="{Binding IsInstallerSourceStaticWeb, Converter={StaticResource BoolToVisibility}}">
                                            <TextBlock Text="Link Diretto Installer (Web) *"
                                                       Style="{StaticResource Win11TextBody}"
                                                       FontWeight="SemiBold"
                                                       Margin="0,0,0,6"/>
                                            <TextBox Text="{Binding DownloadUrl, UpdateSourceTrigger=PropertyChanged}"
                                                     Style="{StaticResource Win11TextBox}"
                                                     Margin="0,0,0,16"/>
                                        </StackPanel>

                                        <StackPanel Visibility="{Binding IsInstallerSourceDynamicWeb, Converter={StaticResource BoolToVisibility}}">
                                            <TextBlock Text="Cartella Download (Web) *"
                                                       Style="{StaticResource Win11TextBody}"
                                                       FontWeight="SemiBold"
                                                       Margin="0,0,0,6"/>
                                            <Grid Margin="0,0,0,8">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBox Grid.Column="0"
                                                         Text="{Binding DownloadBaseFolderUrl, UpdateSourceTrigger=PropertyChanged}"
                                                         Style="{StaticResource Win11TextBox}"
                                                         Margin="0,0,8,0"/>
                                                <Button Grid.Column="1"
                                                        Content="Su"
                                                        Command="{Binding NavigateUpRemoteFolderCommand}"
                                                        Style="{StaticResource Win11Button}"
                                                        Padding="12,6"
                                                        Visibility="{Binding IsRemoteFolderNavigationMode, Converter={StaticResource BoolToVisibility}}"/>
                                            </Grid>

                                            <Grid Margin="0,0,0,16">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="12"/>
                                                    <ColumnDefinition Width="3*"/>
                                                </Grid.ColumnDefinitions>

                                                <StackPanel Grid.Column="0"
                                                            Visibility="{Binding HasRemoteInstallerVersions, Converter={StaticResource BoolToVisibility}}">
                                                    <TextBlock Text="{Binding RemoteFolderPickerLabel}"
                                                               Style="{StaticResource Win11TextBody}"
                                                               FontWeight="SemiBold"
                                                               Margin="0,0,0,6"/>
                                                    <ComboBox ItemsSource="{Binding RemoteInstallerVersions}"
                                                              SelectedItem="{Binding DownloadSelectedVersion, Mode=TwoWay}"
                                                              Style="{StaticResource Win11ComboBox}"
                                                              IsEnabled="{Binding IsInstallerAutoUpdateEnabled, Converter={StaticResource InverseBoolConverter}}"
                                                              MaxDropDownHeight="260"/>

                                                    <Grid Margin="0,8,0,0"
                                                          Visibility="{Binding IsRemoteVersionPickerMode, Converter={StaticResource BoolToVisibility}}">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Text="Aggiornamento Automatico Installer"
                                                                   Style="{StaticResource Win11TextSecondary}"
                                                                   VerticalAlignment="Center"
                                                                   Margin="0,0,10,0"/>
                                                        <CheckBox Grid.Column="1"
                                                                  IsChecked="{Binding IsInstallerAutoUpdateEnabled, Mode=TwoWay}"
                                                                  Style="{StaticResource Win11ToggleSwitch}"/>
                                                    </Grid>

                                                    <Button Content="Apri"
                                                            Command="{Binding OpenSelectedRemoteFolderCommand}"
                                                            Style="{StaticResource Win11Button}"
                                                            Height="36"
                                                            Margin="0,8,0,0"
                                                            Visibility="{Binding IsRemoteFolderNavigationMode, Converter={StaticResource BoolToVisibility}}"/>
                                                </StackPanel>

                                                <StackPanel Grid.Column="2">
                                                    <TextBlock Text="Installer da Scaricare"
                                                               Style="{StaticResource Win11TextBody}"
                                                               FontWeight="SemiBold"
                                                               Margin="0,0,0,6"/>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <ComboBox Grid.Column="0"
                                                                  ItemsSource="{Binding RemoteInstallerFiles}"
                                                                  SelectedItem="{Binding DownloadSelectedFileName, Mode=TwoWay}"
                                                                  Style="{StaticResource Win11ComboBox}"
                                                                  Margin="0,0,8,0"/>
                                                        <Button Grid.Column="1"
                                                                Content="Aggiorna elenco"
                                                                Command="{Binding RefreshRemoteInstallerFilesCommand}"
                                                                Style="{StaticResource Win11Button}"
                                                                Padding="12,6"/>
                                                    </Grid>
                                                </StackPanel>
                                            </Grid>
                                        </StackPanel>

                                        <Grid Margin="0,0,0,6">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0"
                                                       Text="Modalità Installer EXE"
                                                       Style="{StaticResource Win11TextBody}"
                                                       FontWeight="SemiBold"
                                                       VerticalAlignment="Center"/>
                                            <Button Grid.Column="1"
                                                    Content="Auto-genera"
                                                    Command="{Binding AutoGenerateInstallerFlowCommand}"
                                                    Style="{StaticResource Win11Button}"
                                                    Height="32"
                                                    Padding="12,4"
                                                    Margin="10,0,0,0"/>
                                        </Grid>
                                        <ComboBox ItemsSource="{Binding AvailableExeInstallerModes}"
                                                  SelectedItem="{Binding SelectedExeInstallerMode, Mode=TwoWay}"
                                                  Style="{StaticResource Win11ComboBox}"
                                                  behaviors:ComboBoxMouseWheelToScrollViewerBehavior.IsEnabled="True"
                                                  Margin="0,0,0,6">
                                            <ComboBox.ItemTemplate>
                                                <DataTemplate>
                                                    <StackPanel>
                                                        <TextBlock x:Name="ModeTitle"
                                                                   Style="{StaticResource Win11TextBody}"
                                                                   FontWeight="SemiBold"
                                                                   Text="Manuale"/>
                                                        <TextBlock x:Name="ModeSubtitle"
                                                                   Style="{StaticResource Win11TextSecondary}"
                                                                   TextWrapping="Wrap"
                                                                   Margin="0,2,0,0"
                                                                   Text="Esegue l’EXE così com’è. Se non hai parametri silent può aprire finestre."/>
                                                    </StackPanel>

                                                    <DataTemplate.Triggers>
                                                        <DataTrigger Binding="{Binding}" Value="{x:Static models:ExeInstallerMode.Manual}">
                                                            <Setter TargetName="ModeTitle" Property="Text" Value="Manuale"/>
                                                            <Setter TargetName="ModeSubtitle" Property="Text" Value="Esegue l’EXE così com’è. Se non hai parametri silent può aprire finestre."/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding}" Value="{x:Static models:ExeInstallerMode.Auto}">
                                                            <Setter TargetName="ModeTitle" Property="Text" Value="Auto ({AUTO})"/>
                                                            <Setter TargetName="ModeSubtitle" Property="Text" Value="Decide automaticamente: se trova MSI dentro → AutoExtract; altrimenti prova silent; se non riconosce → manuale."/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding}" Value="{x:Static models:ExeInstallerMode.Silent}">
                                                            <Setter TargetName="ModeTitle" Property="Text" Value="Silent ({SILENT})"/>
                                                            <Setter TargetName="ModeSubtitle" Property="Text" Value="Inserisce {SILENT}: tenta di riconoscere l’installer (Inno/NSIS/…) e aggiunge i flag quiet."/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding}" Value="{x:Static models:ExeInstallerMode.AutoExtractMainMsi}">
                                                            <Setter TargetName="ModeTitle" Property="Text" Value="AutoExtract (MSI principale)"/>
                                                            <Setter TargetName="ModeSubtitle" Property="Text" Value="Estrae l’EXE e installa l’MSI principale (e prerequisiti), in silent."/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding}" Value="{x:Static models:ExeInstallerMode.AutoExtractAllMsis}">
                                                            <Setter TargetName="ModeTitle" Property="Text" Value="AutoExtract (tutti gli MSI)"/>
                                                            <Setter TargetName="ModeSubtitle" Property="Text" Value="Estrae e installa tutti gli MSI trovati. Utile per bundle che contengono più componenti."/>
                                                        </DataTrigger>
                                                    </DataTemplate.Triggers>
                                                </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                        </ComboBox>
                                        <TextBlock Text="Questa opzione modifica automaticamente gli argomenti inserendo/rimuovendo i marker {AUTO}, {SILENT} o {AUTOEXTRACT_*} (solo .exe). I file .msi vengono già eseguiti senza UI."
                                                   Style="{StaticResource Win11TextSecondary}"
                                                   TextWrapping="Wrap"
                                                   Margin="0,0,0,12"/>

                                        <TextBlock Text="Argomenti Riga di Comando"
                                                   Style="{StaticResource Win11TextBody}"
                                                   FontWeight="SemiBold"
                                                   Margin="0,0,0,6"/>
                                        <TextBox Text="{Binding Arguments, UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{StaticResource Win11TextBox}"
                                                 Margin="0,0,0,16"/>

                                        <TextBlock Text="Cartella Installazione (opzionale)"
                                                   Style="{StaticResource Win11TextBody}"
                                                   FontWeight="SemiBold"
                                                   Margin="0,0,0,6"/>
                                        <TextBox Text="{Binding InstallDirectory, UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{StaticResource Win11TextBox}"
                                                 Margin="0,0,0,16"/>
                                    </StackPanel>

                                    <StackPanel Visibility="{Binding IsScriptMode, Converter={StaticResource BoolToVisibility}}">
                                        <Grid Margin="0,0,0,6">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="Comando Inline"
                                                       Style="{StaticResource Win11TextBody}"
                                                       FontWeight="SemiBold"
                                                       VerticalAlignment="Center"/>
                                            <Button Grid.Column="1"
                                                    Content="Open Editor"
                                                    Click="OpenScriptEditorFromEditor_Click"
                                                    Style="{StaticResource Win11Button}"
                                                    Padding="12,6"/>
                                        </Grid>
                                        <TextBox Text="{Binding InlineScriptCommand, UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{StaticResource Win11TextBox}"
                                                 Margin="0,0,0,8"
                                                 Visibility="{Binding HasMultiLineScriptContent, Converter={StaticResource InverseBoolToVisibility}}"/>
                                        <Border Style="{StaticResource Win11Card}"
                                                Padding="10"
                                                Margin="0,0,0,8"
                                                Visibility="{Binding HasMultiLineScriptContent, Converter={StaticResource BoolToVisibility}}">
                                            <StackPanel>
                                                <TextBlock Text="Multi-line script preview"
                                                           Style="{StaticResource Win11TextBody}"
                                                           FontWeight="SemiBold"
                                                           Margin="0,0,0,6"/>
                                                <TextBox Text="{Binding ScriptPreview, Mode=OneWay}"
                                                         Style="{StaticResource Win11TextBox}"
                                                         IsReadOnly="True"
                                                         AcceptsReturn="True"
                                                         TextWrapping="Wrap"
                                                         Height="120"
                                                         VerticalScrollBarVisibility="Auto"
                                                         FontFamily="Cascadia Code, Consolas, monospace"
                                                         FontSize="11"/>
                                            </StackPanel>
                                        </Border>
                                        <TextBlock Text="{Binding ScriptEditorHint}"
                                                   Style="{StaticResource Win11TextSecondary}"
                                                   TextWrapping="Wrap"
                                                   Margin="0,0,0,8"/>
                                        <TextBlock Text="— OPPURE —"
                                                   Style="{StaticResource Win11TextSecondary}"
                                                   HorizontalAlignment="Center"
                                                   Margin="0,0,0,8"/>

                                        <TextBlock Text="Percorso File Script"
                                                   Style="{StaticResource Win11TextBody}"
                                                   FontWeight="SemiBold"
                                                   Margin="0,0,0,6"/>
                                        <Grid Margin="0,0,0,16">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBox Grid.Column="0"
                                                     Text="{Binding FilePath, UpdateSourceTrigger=PropertyChanged}"
                                                     Style="{StaticResource Win11TextBox}"
                                                     Margin="0,0,8,0"/>
                                            <Button Grid.Column="1"
                                                    Content="Sfoglia..."
                                                    Command="{Binding BrowseFileCommand}"
                                                    Style="{StaticResource Win11Button}"
                                                    Padding="12,6"/>
                                        </Grid>
                                    </StackPanel>

                                    <Border Style="{StaticResource Win11Card}"
                                            Padding="0"
                                            Margin="0,0,0,16">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <Border Background="{DynamicResource SurfaceElevatedBrush}"
                                                    Padding="10,8"
                                                    CornerRadius="8,8,0,0">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="Sottoprocessi"
                                                               FontWeight="SemiBold"
                                                               FontSize="14"
                                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                                               VerticalAlignment="Center"/>
                                                    <Button Grid.Column="1"
                                                            Content="Crea sottoprocesso..."
                                                            Click="CreateSubProcessFromEditor_Click"
                                                            Style="{StaticResource Win11Button}"
                                                            Padding="12,6"/>
                                                </Grid>
                                            </Border>

                                            <Border Grid.Row="1"
                                                    Padding="12">
                                                <StackPanel>
                                                    <TextBlock Text="Nessun sottoprocesso."
                                                               Style="{StaticResource Win11TextSecondary}"
                                                               Margin="0,0,0,8"
                                                               Visibility="{Binding HasSubProcesses, Converter={StaticResource InverseBoolToVisibility}}"/>

                                                    <ScrollViewer MaxHeight="260"
                                                                  VerticalScrollBarVisibility="Auto"
                                                                  Visibility="{Binding HasSubProcesses, Converter={StaticResource BoolToVisibility}}">
                                                        <ItemsControl ItemsSource="{Binding SubProcesses}">
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate>
                                                                    <Button Style="{StaticResource ProcessCardButton}"
                                                                            Click="EditSubProcessFromEditor_Click"
                                                                            Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Window}}">
                                                                        <Grid>
                                                                            <Grid.ColumnDefinitions>
                                                                                <ColumnDefinition Width="Auto"/>
                                                                                <ColumnDefinition Width="*"/>
                                                                                <ColumnDefinition Width="Auto"/>
                                                                            </Grid.ColumnDefinitions>

                                                                            <Border Width="34"
                                                                                    Height="34"
                                                                                    CornerRadius="6"
                                                                                    Background="{DynamicResource SurfaceElevatedBrush}"
                                                                                    BorderBrush="{DynamicResource BorderBrush}"
                                                                                    BorderThickness="1"
                                                                                    VerticalAlignment="Center"
                                                                                    Margin="0,0,10,0">
                                                                                <Grid>
                                                                                    <Image Width="18"
                                                                                           Height="18"
                                                                                           RenderOptions.BitmapScalingMode="HighQuality"
                                                                                           Visibility="{Binding HasCustomIcon, Converter={StaticResource BoolToVisibility}}">
                                                                                        <Image.Source>
                                                                                            <MultiBinding Converter="{StaticResource IconVariantToImageSourceConverter}">
                                                                                                <Binding Path="CustomIconLightPath"/>
                                                                                                <Binding Path="CustomIconDarkPath"/>
                                                                                                <Binding Path="DataContext.IsDarkTheme"
                                                                                                         RelativeSource="{RelativeSource AncestorType=Window}"/>
                                                                                            </MultiBinding>
                                                                                        </Image.Source>
                                                                                    </Image>
                                                                                    <TextBlock Text="{Binding DisplayIcon}"
                                                                                               FontSize="16"
                                                                                               FontFamily="Segoe UI Emoji"
                                                                                               HorizontalAlignment="Center"
                                                                                               VerticalAlignment="Center"
                                                                                               Visibility="{Binding HasCustomIcon, Converter={StaticResource InverseBoolToVisibility}}"/>
                                                                                </Grid>
                                                                            </Border>

                                                                            <Grid Grid.Column="1">
                                                                                <Grid.RowDefinitions>
                                                                                    <RowDefinition Height="Auto"/>
                                                                                    <RowDefinition Height="Auto"/>
                                                                                    <RowDefinition Height="Auto"/>
                                                                                </Grid.RowDefinitions>
                                                                                <Grid Grid.Row="0">
                                                                                    <Grid.ColumnDefinitions>
                                                                                        <ColumnDefinition Width="*"/>
                                                                                        <ColumnDefinition Width="Auto"/>
                                                                                    </Grid.ColumnDefinitions>
                                                                                    <TextBlock Text="{Binding Name}"
                                                                                               Style="{StaticResource Win11TextBody}"
                                                                                               FontWeight="SemiBold"
                                                                                               TextTrimming="CharacterEllipsis"
                                                                                               VerticalAlignment="Center"/>
                                                                                    <Border Grid.Column="1"
                                                                                            Background="{DynamicResource SurfaceElevatedBrush}"
                                                                                            Style="{StaticResource Win11Badge}"
                                                                                            Margin="8,0,0,0"
                                                                                            VerticalAlignment="Center">
                                                                                        <TextBlock Text="{Binding KindLabel}"
                                                                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                                                                   FontSize="9"
                                                                                                   VerticalAlignment="Center"/>
                                                                                    </Border>
                                                                                </Grid>

                                                                                <TextBlock Grid.Row="1"
                                                                                           Text="{Binding RelativePath}"
                                                                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                                                                           TextTrimming="CharacterEllipsis"
                                                                                           Margin="0,4,0,0"/>

                                                                                <TextBlock Grid.Row="2"
                                                                                           Text="{Binding Arguments}"
                                                                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                                                                           TextTrimming="CharacterEllipsis"
                                                                                           Margin="0,2,0,0"
                                                                                           Visibility="{Binding Arguments, Converter={StaticResource StringToVisibilityConverter}}"/>
                                                                            </Grid>

                                                                            <Button Grid.Column="2"
                                                                                    Style="{StaticResource Win11IconButton}"
                                                                                    Click="SubProcessMenuButton_Click"
                                                                                    Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                                    Margin="8,0,0,0"
                                                                                    VerticalAlignment="Center"
                                                                                    ToolTip="Azioni">
                                                                                <Button.Content>
                                                                                    <Image Source="{DynamicResource IconMoreHorizontal}"
                                                                                           Width="{StaticResource IconSizeMd}"
                                                                                           Height="{StaticResource IconSizeMd}"
                                                                                           RenderOptions.BitmapScalingMode="HighQuality"/>
                                                                                </Button.Content>
                                                                                <Button.ContextMenu>
                                                                                    <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}"
                                                                                                 Style="{StaticResource Win11ContextMenu}"
                                                                                                 ItemContainerStyle="{StaticResource Win11ContextMenuItem}">
                                                                                        <MenuItem Header="Modifica..."
                                                                                                  Click="EditSubProcessFromEditor_Click">
                                                                                            <MenuItem.Icon>
                                                                                                <Image Source="{DynamicResource IconEdit}"
                                                                                                       Width="{StaticResource IconSizeMd}"
                                                                                                       Height="{StaticResource IconSizeMd}"
                                                                                                       RenderOptions.BitmapScalingMode="HighQuality"/>
                                                                                            </MenuItem.Icon>
                                                                                        </MenuItem>
                                                                                        <MenuItem Style="{StaticResource Win11ContextMenuSeparatorItem}"/>
                                                                                        <MenuItem Header="Sposta su"
                                                                                                  Command="{Binding PlacementTarget.Tag.MoveSubProcessUpCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                                                  CommandParameter="{Binding}"/>
                                                                                        <MenuItem Header="Sposta giù"
                                                                                                  Command="{Binding PlacementTarget.Tag.MoveSubProcessDownCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                                                  CommandParameter="{Binding}"/>
                                                                                        <MenuItem Style="{StaticResource Win11ContextMenuSeparatorItem}"/>
                                                                                        <MenuItem Header="Elimina"
                                                                                                  Command="{Binding PlacementTarget.Tag.RemoveSubProcessCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                                                  CommandParameter="{Binding}">
                                                                                            <MenuItem.Icon>
                                                                                                <Image Source="{DynamicResource IconDelete}"
                                                                                                       Width="{StaticResource IconSizeMd}"
                                                                                                       Height="{StaticResource IconSizeMd}"
                                                                                                       RenderOptions.BitmapScalingMode="HighQuality"/>
                                                                                            </MenuItem.Icon>
                                                                                        </MenuItem>
                                                                                    </ContextMenu>
                                                                                </Button.ContextMenu>
                                                                            </Button>
                                                                        </Grid>
                                                                    </Button>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                    </ScrollViewer>
                                                </StackPanel>
                                            </Border>
                                        </Grid>
                                    </Border>

                                    <StackPanel Margin="0,0,0,16">
                                        <CheckBox IsChecked="{Binding RunAsAdmin}"
                                                  Style="{StaticResource Win11CheckBox}"
                                                  Margin="0,0,0,8">
                                            <TextBlock Text="Esegui come Amministratore"
                                                       Style="{StaticResource Win11TextBody}"/>
                                        </CheckBox>

                                        <CheckBox IsChecked="{Binding RequiresInternet}"
                                                  Style="{StaticResource Win11CheckBox}"
                                                  IsEnabled="{Binding IsRequiresInternetUserEditable}">
                                            <TextBlock Text="Richiede Connessione Internet"
                                                       Style="{StaticResource Win11TextBody}"/>
                                        </CheckBox>

                                        <CheckBox IsChecked="{Binding PortalAccessEnabled}"
                                                  Style="{StaticResource Win11CheckBox}"
                                                  Margin="0,8,0,0">
                                            <TextBlock Text="Portal login"
                                                       Style="{StaticResource Win11TextBody}"/>
                                        </CheckBox>

                                        <StackPanel Margin="24,8,0,0"
                                                    Visibility="{Binding IsPortalPickerVisible, Converter={StaticResource BoolToVisibility}}">
                                            <TextBlock Text="Portal"
                                                       Style="{StaticResource Win11TextBody}"
                                                       FontWeight="SemiBold"
                                                       Margin="0,0,0,6"/>
                                            <ComboBox ItemsSource="{Binding AvailablePortals}"
                                                      SelectedValue="{Binding SelectedPortalId}"
                                                      SelectedValuePath="Id"
                                                      DisplayMemberPath="Name"
                                                      Style="{StaticResource Win11ComboBox}"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <Border Background="#1A0078D4"
                                            BorderBrush="{DynamicResource AccentBrush}"
                                            BorderThickness="1"
                                            CornerRadius="{StaticResource CornerRadiusSmall}"
                                            Padding="12,8"
                                            Margin="0,0,0,16"
                                            Visibility="{Binding IsEditMode, Converter={StaticResource BoolToVisibility}}">
                                        <StackPanel Orientation="Horizontal">
                                            <Image Source="{DynamicResource IconWarning}"
                                                   Width="16" Height="16"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,8,0"
                                                   RenderOptions.BitmapScalingMode="HighQuality"/>
                                            <TextBlock Text="Attenzione: la modifica di questo processo influirà su tutti i pacchetti che lo utilizzano."
                                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                                       FontSize="11"
                                                       TextWrapping="Wrap"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </ScrollViewer>
                        </Grid>

                        <Border Grid.Row="2"
                                Background="{DynamicResource SurfaceElevatedBrush}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="0,1,0,0"
                                Padding="20,16">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="0,0,8,0">
                                    <Button Content="Elimina"
                                            Command="{Binding DeleteCommand}"
                                            Height="40"
                                            MinWidth="100"
                                            Margin="0,0,8,0"
                                            Visibility="{Binding IsEditMode, Converter={StaticResource BoolToVisibility}}">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource Win11Button}">
                                                <Setter Property="Foreground" Value="{DynamicResource ErrorBrush}"/>
                                            </Style>
                                        </Button.Style>
                                    </Button>

                                    <Button Content="Annulla"
                                            Command="{Binding CancelCommand}"
                                            Style="{StaticResource Win11Button}"
                                            Height="40"
                                            MinWidth="100"/>

                                    <Button Content="Importa"
                                            Command="{Binding ImportProcessCommand}"
                                            Style="{StaticResource Win11Button}"
                                            Height="40"
                                            MinWidth="100"
                                            Margin="8,0,0,0"
                                            Visibility="{Binding IsSubProcessEditor, Converter={StaticResource InverseBoolToVisibility}}"/>

                                    <Button Content="Esporta"
                                            Command="{Binding ExportProcessCommand}"
                                            Style="{StaticResource Win11Button}"
                                            Height="40"
                                            MinWidth="100"
                                            Margin="8,0,0,0"
                                            Visibility="{Binding IsSubProcessEditor, Converter={StaticResource InverseBoolToVisibility}}"/>
                                </StackPanel>

                                <Button Grid.Column="1"
                                        Command="{Binding SaveCommand}"
                                        Height="40"
                                        MinWidth="160">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource Win11AccentButton}">
                                            <Setter Property="Content" Value="Crea Processo"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsEditMode}" Value="True">
                                                    <Setter Property="Content" Value="Salva Modifiche"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </Grid>
                        </Border>

                        <Grid Grid.RowSpan="3"
                              Panel.ZIndex="180"
                              Background="#80000000"
                              Visibility="{Binding IsSubProcessChangesPromptOpen, Converter={StaticResource BoolToVisibility}}">
                            <Border Style="{StaticResource Win11Card}"
                                    Padding="16"
                                    Width="560"
                                    VerticalAlignment="Center"
                                    HorizontalAlignment="Center">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="12"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="16"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0"
                                               Text="Modifiche non salvate"
                                               Style="{StaticResource Win11TextSubtitle}"
                                               FontWeight="SemiBold"/>

                                    <TextBlock Grid.Row="2"
                                               Text="{Binding SubProcessChangesPromptMessage}"
                                               TextWrapping="Wrap"
                                               Style="{StaticResource Win11TextBody}"
                                               Foreground="{DynamicResource TextSecondaryBrush}"/>

                                    <StackPanel Grid.Row="4"
                                                Orientation="Horizontal"
                                                HorizontalAlignment="Right">
                                        <Button Content="Chiudi"
                                                Command="{Binding DiscardSubProcessChangesAndCloseCommand}"
                                                Style="{StaticResource Win11DangerButton}"
                                                Height="36"
                                                MinWidth="110"
                                                Margin="0,0,8,0"/>
                                        <Button Content="Annulla"
                                                Command="{Binding DismissSubProcessChangesPromptCommand}"
                                                Style="{StaticResource Win11Button}"
                                                Height="36"
                                                MinWidth="110"
                                                Margin="0,0,8,0"/>
                                        <Button Content="Salva"
                                                Command="{Binding SaveFromSubProcessChangesPromptCommand}"
                                                Style="{StaticResource Win11AccentButton}"
                                                Height="36"
                                                MinWidth="110"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </Grid>

                        <Grid Grid.RowSpan="3"
                              Panel.ZIndex="200"
                              Background="#80000000"
                              Visibility="{Binding IsIconPickerOpen, Converter={StaticResource BoolToVisibility}}">
                            <Border Style="{StaticResource Win11Card}"
                                    Padding="16"
                                    Width="620"
                                    MaxHeight="680"
                                    VerticalAlignment="Center"
                                    HorizontalAlignment="Center">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <Grid Grid.Row="0" Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Text="Seleziona icona"
                                                   Style="{StaticResource Win11TextSubtitle}"
                                                   FontWeight="SemiBold"/>

                                        <Button Grid.Column="1"
                                                Command="{Binding CloseIconPickerCommand}"
                                                Style="{StaticResource Win11CloseButton}"
                                                Width="32"
                                                Height="32"
                                                Padding="0">
                                            <TextBlock Text="✕" FontSize="14"/>
                                        </Button>
                                    </Grid>

                                    <ScrollViewer Grid.Row="1"
                                                  VerticalScrollBarVisibility="Auto">
                                        <StackPanel>
                                            <TextBlock Text="Emoji"
                                                       Style="{StaticResource Win11TextBody}"
                                                       FontWeight="SemiBold"
                                                       Margin="0,0,0,8"/>

                                            <ItemsControl ItemsSource="{Binding AvailableEmojiIcons}"
                                                          Margin="0,0,0,16">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <WrapPanel/>
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Button Command="{Binding DataContext.SelectEmojiIconCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                CommandParameter="{Binding}"
                                                                Style="{StaticResource Win11Button}"
                                                                Width="44"
                                                                Height="44"
                                                                Padding="0"
                                                                Margin="0,0,8,8">
                                                            <TextBlock Text="{Binding}"
                                                                       FontSize="20"
                                                                       FontFamily="Segoe UI Emoji"
                                                                       HorizontalAlignment="Center"
                                                                       VerticalAlignment="Center"/>
                                                        </Button>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>

                                            <TextBlock Text="Icone caricate"
                                                       Style="{StaticResource Win11TextBody}"
                                                       FontWeight="SemiBold"
                                                       Margin="0,0,0,8"/>

                                            <Border Background="{DynamicResource SurfaceElevatedBrush}"
                                                    BorderBrush="{DynamicResource BorderBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="{StaticResource CornerRadiusSmall}"
                                                    Padding="12"
                                                    Margin="0,0,0,12">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>

                                                    <Border Width="40"
                                                            Height="40"
                                                            CornerRadius="{StaticResource CornerRadiusSmall}"
                                                            Background="{DynamicResource SurfaceBrush}"
                                                            BorderBrush="{DynamicResource BorderBrush}"
                                                            BorderThickness="1"
                                                            VerticalAlignment="Center"
                                                            Margin="0,0,12,0">
                                                        <Grid>
                                                            <Image Width="22"
                                                                   Height="22"
                                                                   RenderOptions.BitmapScalingMode="HighQuality"
                                                                   Visibility="{Binding HasCustomIcon, Converter={StaticResource BoolToVisibility}}">
                                                                <Image.Source>
                                                                    <MultiBinding Converter="{StaticResource IconVariantToImageSourceConverter}">
                                                                        <Binding Path="CustomIconLightPath"/>
                                                                        <Binding Path="CustomIconDarkPath"/>
                                                                        <Binding Path="DataContext.IsDarkTheme"
                                                                                 RelativeSource="{RelativeSource AncestorType=Window}"/>
                                                                    </MultiBinding>
                                                                </Image.Source>
                                                            </Image>

                                                            <TextBlock Text="{Binding Icon}"
                                                                       FontSize="18"
                                                                       FontFamily="Segoe UI Emoji"
                                                                       HorizontalAlignment="Center"
                                                                       VerticalAlignment="Center"
                                                                       Visibility="{Binding HasCustomIcon, Converter={StaticResource InverseBoolToVisibility}}"/>
                                                        </Grid>
                                                    </Border>

                                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                        <CheckBox Content="Scegli icona diversa per tema"
                                                                  IsChecked="{Binding UseSeparateThemeIcons}"
                                                                  Style="{StaticResource Win11ToggleSwitch}"/>
                                                        <TextBlock Text="Se attivo, puoi scegliere un’icona per tema chiaro e una per tema scuro."
                                                                   Style="{StaticResource Win11TextSecondary}"
                                                                   FontSize="11"
                                                                   Margin="0,4,0,0"/>
                                                    </StackPanel>

                                                    <Button Grid.Column="2"
                                                            Content="Importa"
                                                            Command="{Binding ImportLibraryIconCommand}"
                                                            Style="{StaticResource Win11Button}"
                                                            Height="36"
                                                            MinWidth="120"
                                                            VerticalAlignment="Center"/>
                                                </Grid>
                                            </Border>

                                            <StackPanel Orientation="Horizontal"
                                                        Margin="0,0,0,12"
                                                        Visibility="{Binding UseSeparateThemeIcons, Converter={StaticResource BoolToVisibility}}">
                                                <Button Content="Chiaro"
                                                        Command="{Binding SetIconPickerTargetLightCommand}"
                                                        Height="32"
                                                        MinWidth="120">
                                                    <Button.Style>
                                                        <Style TargetType="Button" BasedOn="{StaticResource Win11Button}">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsIconPickerTargetDark}" Value="False">
                                                                    <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                                                                    <Setter Property="Foreground" Value="White"/>
                                                                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Button.Style>
                                                </Button>
                                                <Button Content="Scuro"
                                                        Command="{Binding SetIconPickerTargetDarkCommand}"
                                                        Height="32"
                                                        MinWidth="120"
                                                        Margin="8,0,0,0">
                                                    <Button.Style>
                                                        <Style TargetType="Button" BasedOn="{StaticResource Win11Button}">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsIconPickerTargetDark}" Value="True">
                                                                    <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                                                                    <Setter Property="Foreground" Value="White"/>
                                                                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Button.Style>
                                                </Button>
                                            </StackPanel>

                                            <ItemsControl ItemsSource="{Binding LibraryIcons}"
                                                          Margin="0,0,0,16">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <WrapPanel/>
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Button Command="{Binding DataContext.SelectLibraryIconCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                CommandParameter="{Binding}"
                                                                Style="{StaticResource Win11Button}"
                                                                Width="56"
                                                                Height="56"
                                                                Padding="0"
                                                                Margin="0,0,8,8">
                                                            <Image Stretch="Uniform"
                                                                   RenderOptions.BitmapScalingMode="HighQuality"
                                                                   Width="28"
                                                                   Height="28">
                                                                <Image.Source>
                                                                    <MultiBinding Converter="{StaticResource IconVariantToImageSourceConverter}">
                                                                        <Binding Path="LightPath"/>
                                                                        <Binding Path="DarkPath"/>
                                                                        <Binding Path="DataContext.IsDarkTheme"
                                                                                 RelativeSource="{RelativeSource AncestorType=Window}"/>
                                                                    </MultiBinding>
                                                                </Image.Source>
                                                            </Image>
                                                        </Button>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>

                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="12"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>

                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="Chiaro"
                                                               Style="{StaticResource Win11TextSecondary}"
                                                               Margin="0,0,0,6"/>
                                                    <Border Background="{DynamicResource SurfaceElevatedBrush}"
                                                            BorderBrush="{DynamicResource BorderBrush}"
                                                            BorderThickness="1"
                                                            CornerRadius="{StaticResource CornerRadiusSmall}"
                                                            Width="96"
                                                            Height="96"
                                                            HorizontalAlignment="Left">
                                                        <Image Stretch="Uniform"
                                                               RenderOptions.BitmapScalingMode="HighQuality">
                                                            <Image.Source>
                                                                <MultiBinding Converter="{StaticResource IconVariantToImageSourceConverter}">
                                                                    <Binding Path="CustomIconLightPath"/>
                                                                    <Binding Path="CustomIconDarkPath"/>
                                                                    <Binding Source="False"/>
                                                                </MultiBinding>
                                                            </Image.Source>
                                                        </Image>
                                                    </Border>
                                                </StackPanel>

                                                <StackPanel Grid.Column="2">
                                                    <TextBlock Text="Scuro"
                                                               Style="{StaticResource Win11TextSecondary}"
                                                               Margin="0,0,0,6"/>
                                                    <Border Background="{DynamicResource SurfaceElevatedBrush}"
                                                            BorderBrush="{DynamicResource BorderBrush}"
                                                            BorderThickness="1"
                                                            CornerRadius="{StaticResource CornerRadiusSmall}"
                                                            Width="96"
                                                            Height="96"
                                                            HorizontalAlignment="Left">
                                                        <Image Stretch="Uniform"
                                                               RenderOptions.BitmapScalingMode="HighQuality">
                                                            <Image.Source>
                                                                <MultiBinding Converter="{StaticResource IconVariantToImageSourceConverter}">
                                                                    <Binding Path="CustomIconLightPath"/>
                                                                    <Binding Path="CustomIconDarkPath"/>
                                                                    <Binding Source="True"/>
                                                                </MultiBinding>
                                                            </Image.Source>
                                                        </Image>
                                                    </Border>
                                                </StackPanel>
                                            </Grid>
                                        </StackPanel>
                                    </ScrollViewer>

                                    <Grid Grid.Row="2" Margin="0,12,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <Button Content="Rimuovi"
                                                Command="{Binding RemoveCustomIconCommand}"
                                                Style="{StaticResource Win11Button}"
                                                Height="36"
                                                Visibility="{Binding HasCustomIcon, Converter={StaticResource BoolToVisibility}}"
                                                HorizontalAlignment="Left"/>

                                        <Button Grid.Column="1"
                                                Content="Chiudi"
                                                Command="{Binding CloseIconPickerCommand}"
                                                Style="{StaticResource Win11AccentButton}"
                                                Height="36"
                                                MinWidth="120"/>
                                    </Grid>
                                </Grid>
                            </Border>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>
