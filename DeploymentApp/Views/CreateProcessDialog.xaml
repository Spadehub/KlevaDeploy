<Window x:Class="DeploymentApp.Views.CreateProcessDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:models="clr-namespace:DeploymentApp.Models"
        mc:Ignorable="d"
        Title="Create Custom Process"
        Width="600" Height="650"
        MinWidth="500" MinHeight="550"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="False"
        ResizeMode="NoResize"
        Background="{DynamicResource AppBackgroundBrush}"
        FontFamily="Segoe UI Variable, Segoe UI, sans-serif">

    <Window.Resources>
        <!-- Converter for conditional visibility -->
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Border BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="8">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>  <!-- Title bar -->
                <RowDefinition Height="*"/>     <!-- Content -->
                <RowDefinition Height="Auto"/>  <!-- Buttons -->
            </Grid.RowDefinitions>

            <!-- Title Bar -->
            <Border Grid.Row="0"
                    Background="{DynamicResource SurfaceElevatedBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="0,0,0,1"
                    CornerRadius="8,8,0,0"
                    Padding="20,16">
                <Grid>
                    <StackPanel Orientation="Horizontal">
                        <Image Source="{DynamicResource IconSettings}"
                               Width="20" Height="20"
                               VerticalAlignment="Center"
                               Margin="0,0,10,0"
                               RenderOptions.BitmapScalingMode="HighQuality"/>
                        <TextBlock Text="Create Custom Process"
                                   Style="{StaticResource Win11TextSubtitle}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    <Button Content="✕"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Width="32" Height="32"
                            Style="{StaticResource Win11Button}"
                            Click="CloseButton_Click"
                            FontSize="16"
                            Padding="0"/>
                </Grid>
            </Border>

            <!-- Content -->
            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto"
                          Padding="20,16">
                <StackPanel>
                    <!-- Process Name -->
                    <TextBlock Text="Process Name *"
                               Style="{StaticResource Win11TextBody}"
                               FontWeight="SemiBold"
                               Margin="0,0,0,6"/>
                    <TextBox Text="{Binding ProcessName, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource Win11TextBox}"
                             Margin="0,0,0,16"/>

                    <!-- Description -->
                    <TextBlock Text="Description"
                               Style="{StaticResource Win11TextBody}"
                               FontWeight="SemiBold"
                               Margin="0,0,0,6"/>
                    <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource Win11TextBox}"
                             Margin="0,0,0,16"/>

                    <!-- Process Type -->
                    <TextBlock Text="Process Type *"
                               Style="{StaticResource Win11TextBody}"
                               FontWeight="SemiBold"
                               Margin="0,0,0,6"/>
                    <ComboBox ItemsSource="{Binding AvailableProcessKinds}"
                              SelectedItem="{Binding SelectedProcessKind}"
                              Style="{StaticResource Win11ComboBox}"
                              Margin="0,0,0,16">
                        <ComboBox.ItemTemplate>
                            <DataTemplate DataType="models:ProcessKind">
                                <TextBlock>
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="{Binding}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding}" Value="{x:Static models:ProcessKind.Installer}">
                                                    <Setter Property="Text" Value="Installer (.exe, .msi, .zip)"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding}" Value="{x:Static models:ProcessKind.PowerShellScript}">
                                                    <Setter Property="Text" Value="PowerShell Script"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding}" Value="{x:Static models:ProcessKind.BatchScript}">
                                                    <Setter Property="Text" Value="Batch/CMD Script"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <!-- Installer Mode Fields -->
                    <StackPanel Visibility="{Binding IsInstallerMode, Converter={StaticResource BoolToVis}}">
                        <!-- File Path -->
                        <TextBlock Text="Installer File Path *"
                                   Style="{StaticResource Win11TextBody}"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,6"/>
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0"
                                     Text="{Binding FilePath, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource Win11TextBox}"
                                     Margin="0,0,8,0"/>
                            <Button Grid.Column="1"
                                    Content="Browse..."
                                    Command="{Binding BrowseFileCommand}"
                                    Style="{StaticResource Win11Button}"
                                    Padding="12,6"/>
                        </Grid>

                        <!-- Arguments -->
                        <TextBlock Text="Command-Line Arguments"
                                   Style="{StaticResource Win11TextBody}"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,6"/>
                        <TextBox Text="{Binding Arguments, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource Win11TextBox}"
                                 Margin="0,0,0,16"/>
                    </StackPanel>

                    <!-- Script Mode Fields -->
                    <StackPanel Visibility="{Binding IsScriptMode, Converter={StaticResource BoolToVis}}">
                        <!-- Script Content -->
                        <TextBlock Text="Script Content (inline)"
                                   Style="{StaticResource Win11TextBody}"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,6"/>
                        <TextBox Text="{Binding ScriptContent, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource Win11TextBox}"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 Height="120"
                                 VerticalScrollBarVisibility="Auto"
                                 FontFamily="Cascadia Code, Consolas, monospace"
                                 FontSize="11"
                                 Margin="0,0,0,8"/>
                        <TextBlock Text="— OR —"
                                   Style="{StaticResource Win11TextSecondary}"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,8"/>

                        <!-- Script File Path -->
                        <TextBlock Text="Script File Path"
                                   Style="{StaticResource Win11TextBody}"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,6"/>
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0"
                                     Text="{Binding FilePath, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource Win11TextBox}"
                                     Margin="0,0,8,0"/>
                            <Button Grid.Column="1"
                                    Content="Browse..."
                                    Command="{Binding BrowseFileCommand}"
                                    Style="{StaticResource Win11Button}"
                                    Padding="12,6"/>
                        </Grid>
                    </StackPanel>

                    <!-- Icon Picker -->
                    <TextBlock Text="Icon"
                               Style="{StaticResource Win11TextBody}"
                               FontWeight="SemiBold"
                               Margin="0,0,0,6"/>
                    <ComboBox ItemsSource="{Binding AvailableIcons}"
                              SelectedValue="{Binding SelectedIconKey}"
                              SelectedValuePath="Key"
                              DisplayMemberPath="DisplayName"
                              Style="{StaticResource Win11ComboBox}"
                              Margin="0,0,0,16"/>

                    <!-- Checkboxes -->
                    <CheckBox IsChecked="{Binding RunAsAdmin}"
                              Style="{StaticResource Win11CheckBox}"
                              Margin="0,0,0,8">
                        <TextBlock Text="Run as Administrator"
                                   Style="{StaticResource Win11TextBody}"/>
                    </CheckBox>

                    <CheckBox IsChecked="{Binding IsRequired}"
                              Style="{StaticResource Win11CheckBox}"
                              Margin="0,0,0,16">
                        <TextBlock Text="Required (cannot be disabled)"
                                   Style="{StaticResource Win11TextBody}"/>
                    </CheckBox>

                    <!-- Validation Error -->
                    <Border Background="#1AFF3333"
                            BorderBrush="{DynamicResource ErrorBrush}"
                            BorderThickness="1"
                            CornerRadius="4"
                            Padding="12,8"
                            Visibility="{Binding ValidationError, Converter={StaticResource StringToVisibilityConverter}}">
                        <StackPanel Orientation="Horizontal">
                            <Image Source="{DynamicResource IconError}"
                                   Width="16" Height="16"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0"
                                   RenderOptions.BitmapScalingMode="HighQuality"/>
                            <TextBlock Text="{Binding ValidationError}"
                                       Foreground="{DynamicResource ErrorBrush}"
                                       TextWrapping="Wrap"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- Action Buttons -->
            <Border Grid.Row="2"
                    Background="{DynamicResource SurfaceElevatedBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="0,1,0,0"
                    CornerRadius="0,0,8,8"
                    Padding="20,16">
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <Button Content="Cancel"
                            Command="{Binding CancelCommand}"
                            Style="{StaticResource Win11Button}"
                            Padding="20,8"
                            Margin="0,0,8,0"
                            MinWidth="100"/>
                    <Button Content="Create Process"
                            Command="{Binding SaveCommand}"
                            Style="{StaticResource Win11AccentButton}"
                            Padding="20,8"
                            MinWidth="140"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
