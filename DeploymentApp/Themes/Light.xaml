<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!-- ═══════════════════════════════════════════════════════════
         LIGHT THEME — Windows 11 Light
    ═══════════════════════════════════════════════════════════ -->

    <!-- Base colors -->
    <Color x:Key="AppBackgroundColor">#FFF3F3F3</Color>
    <Color x:Key="SurfaceColor">#FFFFFFFF</Color>
    <Color x:Key="SurfaceElevatedColor">#FFEBEBEB</Color>
    <Color x:Key="BorderColor">#FFD0D0D0</Color>
    <Color x:Key="AccentColor">#FF0078D4</Color>
    <Color x:Key="AccentHoverColor">#FF1A8FE3</Color>
    <Color x:Key="AccentPressedColor">#FF006CBE</Color>
    <Color x:Key="TextPrimaryColor">#FF1A1A1A</Color>
    <Color x:Key="TextSecondaryColor">#FF5A5A5A</Color>
    <Color x:Key="TextDisabledColor">#FFAAAAAA</Color>
    <Color x:Key="SidebarColor">#FFE8E8E8</Color>
    <Color x:Key="LogBackgroundColor">#FF1E1E1E</Color>
    <Color x:Key="LogTextColor">#FFCCCCCC</Color>
    <Color x:Key="SuccessColor">#FF2E7D32</Color>
    <Color x:Key="WarningColor">#FFE65100</Color>
    <Color x:Key="ErrorColor">#FFC62828</Color>
    <Color x:Key="SelectionColor">#FF0078D4</Color>
    <Color x:Key="HoverColor">#FFE0E0E0</Color>
    <Color x:Key="ToolbarColor">#FFEEEEEE</Color>

    <!-- Brushes -->
    <SolidColorBrush x:Key="AppBackgroundBrush" Color="{StaticResource AppBackgroundColor}"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SurfaceColor}"/>
    <SolidColorBrush x:Key="SurfaceElevatedBrush" Color="{StaticResource SurfaceElevatedColor}"/>
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}"/>
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}"/>
    <SolidColorBrush x:Key="AccentHoverBrush" Color="{StaticResource AccentHoverColor}"/>
    <SolidColorBrush x:Key="AccentPressedBrush" Color="{StaticResource AccentPressedColor}"/>
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimaryColor}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}"/>
    <SolidColorBrush x:Key="TextDisabledBrush" Color="{StaticResource TextDisabledColor}"/>
    <SolidColorBrush x:Key="SidebarBrush" Color="{StaticResource SidebarColor}"/>
    <SolidColorBrush x:Key="LogBackgroundBrush" Color="{StaticResource LogBackgroundColor}"/>
    <SolidColorBrush x:Key="LogTextBrush" Color="{StaticResource LogTextColor}"/>
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}"/>
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}"/>
    <SolidColorBrush x:Key="ErrorBrush" Color="{StaticResource ErrorColor}"/>
    <SolidColorBrush x:Key="SelectionBrush" Color="{StaticResource SelectionColor}"/>
    <SolidColorBrush x:Key="HoverBrush" Color="{StaticResource HoverColor}"/>
    <SolidColorBrush x:Key="ToolbarBrush" Color="{StaticResource ToolbarColor}"/>

    <!-- Theme toggle icon -->
    <sys:String x:Key="ThemeToggleIcon">🌙</sys:String>
    <sys:String x:Key="ThemeToggleTooltip">Passa al tema scuro</sys:String>

    <!-- Theme toggle DrawingImage — Light theme shows Moon (to switch to dark) -->
    <DrawingImage x:Key="ThemeToggleDrawingImage">
        <DrawingImage.Drawing>
            <GeometryDrawing Brush="{DynamicResource TextPrimaryBrush}"
                             Geometry="M12,3 C7.03,3 3,7.03 3,12 C3,16.97 7.03,21 12,21 C16.97,21 21,16.97 21,12 C21,11.54 20.96,11.08 20.9,10.64 C19.92,12.01 18.32,12.9 16.5,12.9 C13.52,12.9 11.1,10.48 11.1,7.5 C11.1,5.69 11.99,4.08 13.36,3.1 C12.92,3.04 12.46,3 12,3 Z"/>
        </DrawingImage.Drawing>
    </DrawingImage>

</ResourceDictionary>
