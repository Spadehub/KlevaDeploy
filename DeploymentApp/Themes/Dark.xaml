<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!-- ═══════════════════════════════════════════════════════════
         DARK THEME — Windows 11 Dark
    ═══════════════════════════════════════════════════════════ -->

    <!-- Base colors -->
    <Color x:Key="AppBackgroundColor">#FF1C1C1C</Color>
    <Color x:Key="SurfaceColor">#FF2D2D2D</Color>
    <Color x:Key="SurfaceElevatedColor">#FF383838</Color>
    <Color x:Key="BorderColor">#FF4A4A4A</Color>
    <Color x:Key="AccentColor">#FF0078D4</Color>
    <Color x:Key="AccentHoverColor">#FF1A8FE3</Color>
    <Color x:Key="AccentPressedColor">#FF006CBE</Color>
    <Color x:Key="TextPrimaryColor">#FFFFFFFF</Color>
    <Color x:Key="TextSecondaryColor">#FFB0B0B0</Color>
    <Color x:Key="TextDisabledColor">#FF666666</Color>
    <Color x:Key="SidebarColor">#FF202020</Color>
    <Color x:Key="LogBackgroundColor">#FF141414</Color>
    <Color x:Key="LogTextColor">#FFCCCCCC</Color>
    <Color x:Key="SuccessColor">#FF4CAF50</Color>
    <Color x:Key="WarningColor">#FFFFC107</Color>
    <Color x:Key="ErrorColor">#FFCF6679</Color>
    <Color x:Key="SelectionColor">#FF0078D4</Color>
    <Color x:Key="HoverColor">#FF3A3A3A</Color>
    <Color x:Key="ToolbarColor">#FF272727</Color>

    <!-- Brushes -->
    <SolidColorBrush x:Key="AppBackgroundBrush" Color="{StaticResource AppBackgroundColor}"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SurfaceColor}"/>
    <SolidColorBrush x:Key="SurfaceElevatedBrush" Color="{StaticResource SurfaceElevatedColor}"/>
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}"/>
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}"/>
    <SolidColorBrush x:Key="AccentHoverBrush" Color="{StaticResource AccentHoverColor}"/>
    <SolidColorBrush x:Key="AccentPressedBrush" Color="{StaticResource AccentPressedColor}"/>
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimaryColor}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}"/>
    <SolidColorBrush x:Key="TextDisabledBrush" Color="{StaticResource TextDisabledColor}"/>
    <SolidColorBrush x:Key="SidebarBrush" Color="{StaticResource SidebarColor}"/>
    <SolidColorBrush x:Key="LogBackgroundBrush" Color="{StaticResource LogBackgroundColor}"/>
    <SolidColorBrush x:Key="LogTextBrush" Color="{StaticResource LogTextColor}"/>
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}"/>
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}"/>
    <SolidColorBrush x:Key="ErrorBrush" Color="{StaticResource ErrorColor}"/>
    <SolidColorBrush x:Key="SelectionBrush" Color="{StaticResource SelectionColor}"/>
    <SolidColorBrush x:Key="HoverBrush" Color="{StaticResource HoverColor}"/>
    <SolidColorBrush x:Key="ToolbarBrush" Color="{StaticResource ToolbarColor}"/>

    <!-- Theme toggle icon -->
    <sys:String x:Key="ThemeToggleIcon">☀</sys:String>
    <sys:String x:Key="ThemeToggleTooltip">Passa al tema chiaro</sys:String>

    <!-- Theme toggle DrawingImage — Dark theme shows Sun (to switch to light) -->
    <DrawingImage x:Key="ThemeToggleDrawingImage">
        <DrawingImage.Drawing>
            <GeometryDrawing Brush="{DynamicResource TextPrimaryBrush}"
