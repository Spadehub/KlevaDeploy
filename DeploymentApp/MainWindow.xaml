<Window x:Class="DeploymentApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        mc:Ignorable="d"
        Title="IT Deployment Configurator"
        Width="1200" Height="760"
        MinWidth="900" MinHeight="580"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="False"
        ResizeMode="CanResizeWithGrip"
        Background="{DynamicResource AppBackgroundBrush}"
        FontFamily="Segoe UI Variable, Segoe UI, sans-serif">

    <!-- ── WindowChrome: integrates with DWM compositor, eliminates 1px white border artifact ── -->
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="32"
                      ResizeBorderThickness="6"
                      GlassFrameThickness="0,0,0,1"
                      UseAeroCaptionButtons="False"
                      CornerRadius="8"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <!-- ── Preset card item style ── -->
        <Style x:Key="PresetCardItem" TargetType="ListBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="ItemBorder"
                                Background="{DynamicResource SurfaceBrush}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="{StaticResource CornerRadiusMedium}">
                            <ContentPresenter Margin="0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource HoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#1A0078D4"/>
                                <Setter TargetName="ItemBorder" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Window chrome button style ── -->
        <Style x:Key="ChromeButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="46"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Arrow"/>
            <Setter Property="WindowChrome.IsHitTestVisibleInChrome" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderThickness="0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource HoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource BorderBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Close button style (red hover) ── -->
        <Style x:Key="ChromeCloseButton" TargetType="Button" BasedOn="{StaticResource ChromeButton}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderThickness="0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#FFE81123"/>
                                <Setter Property="Foreground" Value="#FFFFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#FFC42B1C"/>
                                <Setter Property="Foreground" Value="#FFFFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Execution queue step item style ── -->
        <Style x:Key="QueueStepItem" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="{StaticResource CornerRadiusSmall}"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
            <Setter Property="Padding" Value="10,8"/>
        </Style>
    </Window.Resources>

    <!-- ═══════════════════════════════════════════════════════════
         OUTER BORDER — BorderThickness="0": WindowChrome handles the frame via DWM
    ═══════════════════════════════════════════════════════════ -->
    <Border BorderThickness="0">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="32"/>   <!-- Custom title bar (caption area) -->
                <RowDefinition Height="48"/>   <!-- Toolbar -->
                <RowDefinition Height="*"/>    <!-- Main content -->
                <RowDefinition Height="190"/>  <!-- Log panel -->
            </Grid.RowDefinitions>

            <!-- ══════════════════════════════════════════════════════
                 ROW 0 — CUSTOM TITLE BAR
                 WindowChrome.IsHitTestVisibleInChrome="True" so mouse events reach children
            ══════════════════════════════════════════════════════ -->
            <Border x:Name="TitleBar"
                    Grid.Row="0"
                    Background="{DynamicResource ToolbarBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="0,0,0,1"
                    WindowChrome.IsHitTestVisibleInChrome="True">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>  <!-- App icon + title -->
                        <ColumnDefinition Width="*"/>     <!-- Drag area -->
                        <ColumnDefinition Width="Auto"/>  <!-- Chrome buttons -->
                    </Grid.ColumnDefinitions>

                    <!-- App icon + title (non-interactive — part of drag area) -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal"
                                VerticalAlignment="Center" Margin="10,0,0,0"
                                IsHitTestVisible="False">
                        <Image Source="{DynamicResource IconPackage}"
                               Width="14" Height="14"
                               VerticalAlignment="Center"
                               Margin="0,0,6,0"
                               RenderOptions.BitmapScalingMode="HighQuality"/>
                        <TextBlock Text="IT Deployment Configurator"
                                   FontSize="12"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Window chrome buttons: Minimize / Maximize / Close -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal"
                                VerticalAlignment="Stretch">
                        <!-- Minimize -->
                        <Button x:Name="BtnMinimize"
                                Style="{StaticResource ChromeButton}"
                                ToolTip="Minimizza">
                            <TextBlock Text="&#x2014;" FontSize="10"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center"/>
                        </Button>
                        <!-- Maximize / Restore -->
                        <Button x:Name="BtnMaximize"
                                Style="{StaticResource ChromeButton}"
                                ToolTip="Ingrandisci">
                            <TextBlock x:Name="MaximizeIcon" Text="&#x25A1;" FontSize="11"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center"/>
                        </Button>
                        <!-- Close -->
                        <Button x:Name="BtnClose"
                                Style="{StaticResource ChromeCloseButton}"
                                ToolTip="Chiudi">
                            <TextBlock Text="&#x2715;" FontSize="11"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ══════════════════════════════════════════════════════
                 ROW 1 — TOOLBAR
            ══════════════════════════════════════════════════════ -->
            <Border Grid.Row="1"
                    Background="{DynamicResource ToolbarBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="0,0,0,1">
                <Grid Margin="12,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- App title -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <Image Source="{DynamicResource IconPackage}"
                               Width="18" Height="18"
                               VerticalAlignment="Center"
                               Margin="0,0,8,0"
                               RenderOptions.BitmapScalingMode="HighQuality"/>
                        <TextBlock Text="DeploymentApp"
                                   Style="{StaticResource Win11TextSubtitle}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Demo Mode Toggle -->
                    <Border Grid.Column="1"
                            CornerRadius="{StaticResource CornerRadiusSmall}"
                            Padding="10,6"
                            Margin="16,0,0,0"
                            VerticalAlignment="Center">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="{DynamicResource SurfaceElevatedBrush}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsDemoMode}" Value="True">
                                        <Setter Property="Background" Value="#1AFF9800"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel Orientation="Horizontal">
                            <CheckBox IsChecked="{Binding IsDemoMode, Mode=TwoWay}"
                                      Style="{StaticResource Win11ToggleSwitch}"
                                      VerticalAlignment="Center"
                                      Margin="0,0,8,0">
                                <TextBlock Text="Modalità Demo"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsDemoMode}" Value="True">
                                                    <Setter Property="Foreground" Value="{DynamicResource WarningBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </CheckBox>
                            <!-- Demo mode indicator badge -->
                            <Border Background="{DynamicResource WarningBrush}"
                                    CornerRadius="3"
                                    Padding="5,2"
                                    VerticalAlignment="Center"
                                    Visibility="{Binding IsDemoMode, Converter={StaticResource BoolToVisibility}}">
                                <TextBlock Text="DATI TEST"
                                           Foreground="White"
                                           FontSize="9"
                                           FontWeight="Bold"/>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- Auth status badge -->
                    <Border Grid.Column="3"
                            CornerRadius="{StaticResource CornerRadiusSmall}"
                            Padding="10,4" Margin="0,0,8,0"
                            VerticalAlignment="Center">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="{DynamicResource SurfaceElevatedBrush}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsAuthenticated}" Value="True">
                                        <Setter Property="Background" Value="#1A4CAF50"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="8" Height="8" VerticalAlignment="Center" Margin="0,0,6,0">
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse">
                                        <Setter Property="Fill" Value="{DynamicResource TextDisabledBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsAuthenticated}" Value="True">
                                                <Setter Property="Fill" Value="{DynamicResource SuccessBrush}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>
                            <TextBlock VerticalAlignment="Center" FontSize="12"
                                       Foreground="{DynamicResource TextSecondaryBrush}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="Non autenticato"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsAuthenticated}" Value="True">
                                                <Setter Property="Text" Value="Autenticato"/>
                                                <Setter Property="Foreground" Value="{DynamicResource SuccessBrush}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <!-- Toolbar action buttons -->
                    <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,8,0">
                        <ProgressBar Width="80" Height="3"
                                     IsIndeterminate="True"
                                     Style="{StaticResource Win11ProgressBar}"
                                     Margin="0,0,12,0"
                                     Visibility="{Binding IsInitializing, Converter={StaticResource BoolToVisibility}}"/>

                        <!-- Login button -->
                        <Button Command="{Binding OpenLoginCommand}"
                                Style="{StaticResource Win11Button}"
                                Margin="0,0,6,0"
                                Padding="10,6">
                            <StackPanel Orientation="Horizontal">
                                <Image Source="{DynamicResource IconLock}"
                                       Width="14" Height="14"
                                       VerticalAlignment="Center"
                                       Margin="0,0,6,0"
                                       RenderOptions.BitmapScalingMode="HighQuality"/>
                                <TextBlock Text="Accedi" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <!-- Logout button -->
                        <Button Command="{Binding LogoutCommand}"
                                Style="{StaticResource Win11Button}"
                                Padding="10,6">
                            <StackPanel Orientation="Horizontal">
                                <Image Source="{DynamicResource IconUnlock}"
                                       Width="14" Height="14"
                                       VerticalAlignment="Center"
                                       Margin="0,0,6,0"
                                       RenderOptions.BitmapScalingMode="HighQuality"/>
                                <TextBlock Text="Esci" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <!-- Theme toggle -->
                    <Button Grid.Column="5"
                            Command="{Binding ToggleThemeCommand}"
                            ToolTip="{Binding ThemeToggleTooltip}"
                            Style="{StaticResource Win11Button}"
                            Width="36" Height="36" Padding="0"
                            VerticalAlignment="Center">
                        <Image Source="{DynamicResource ThemeToggleDrawingImage}"
                               Width="16" Height="16"
                               RenderOptions.BitmapScalingMode="HighQuality"/>
                    </Button>
                </Grid>
            </Border>

            <!-- ══════════════════════════════════════════════════════
                 ROW 2 — MAIN CONTENT
                 Left 3/4 : Deployment Presets
                 Right 1/4: Execution Queue
            ══════════════════════════════════════════════════════ -->
            <Grid Grid.Row="2" Margin="12,12,12,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="3*"/>  <!-- Left: presets -->
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="2*"/>  <!-- Right: execution queue -->
                </Grid.ColumnDefinitions>

                <!-- ────────────────────────────────────────────────
                     LEFT PANEL — Deployment Presets (3/5)
                ──────────────────────────────────────────────────── -->
                <Border Grid.Column="0" Style="{StaticResource Win11Card}" Padding="0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>  <!-- Card header -->
                            <RowDefinition Height="Auto"/>  <!-- Search bar -->
                            <RowDefinition Height="*"/>     <!-- Preset list -->
                            <RowDefinition Height="Auto"/>  <!-- Action bar -->
                        </Grid.RowDefinitions>

                        <!-- Card header -->
                        <Border Grid.Row="0"
                                Background="{DynamicResource SurfaceElevatedBrush}"
                                CornerRadius="8,8,0,0"
                                Padding="16,12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Orientation="Horizontal">
                                    <Image Source="{DynamicResource IconPackage}"
                                           Width="16" Height="16"
                                           VerticalAlignment="Center"
                                           Margin="0,0,8,0"
                                           RenderOptions.BitmapScalingMode="HighQuality"/>
                                    <TextBlock Text="Preset di Installazione"
                                               Style="{StaticResource Win11TextSubtitle}"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding SelectedPresetCount, StringFormat='{}{0} selezionati'}"
                                           Style="{StaticResource Win11TextSecondary}"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <!-- Search bar -->
                        <Border Grid.Row="1"
                                Background="{DynamicResource SurfaceBrush}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="0,1,0,1"
                                Padding="12,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0"
                                         Text="{Binding PresetSearchText, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource Win11TextBox}"
                                         Padding="28,6,8,6"
                                         FontSize="12">
                                    <TextBox.Resources>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                        </Style>
                                    </TextBox.Resources>
                                </TextBox>
                                <!-- Search icon -->
                                <Image Grid.Column="0"
                                       Source="{DynamicResource IconSettings}"
                                       Width="14" Height="14"
                                       HorizontalAlignment="Left"
                                       VerticalAlignment="Center"
                                       Margin="10,0,0,0"
                                       Opacity="0.5"
                                       IsHitTestVisible="False"
                                       RenderOptions.BitmapScalingMode="HighQuality"/>
                                <!-- Clear button -->
                                <Button Grid.Column="1"
                                        Content="✕"
                                        Command="{Binding ClearPresetSearchCommand}"
                                        Style="{StaticResource Win11Button}"
                                        Width="28" Height="28"
                                        Padding="0"
                                        Margin="4,0,0,0"
                                        FontSize="12"
                                        Visibility="{Binding PresetSearchText, Converter={StaticResource StringToVisibilityConverter}}"/>
                            </Grid>
                        </Border>

                        <!-- Preset list — clickable card ToggleButtons -->
                        <ScrollViewer Grid.Row="2"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled"
                                      Padding="8,8,8,0">
                            <ItemsControl ItemsSource="{Binding FilteredPresets}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <ToggleButton Style="{StaticResource PresetCardToggleButton}"
                                                      IsChecked="{Binding IsSelected, Mode=TwoWay}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>  <!-- Icon -->
                                                    <ColumnDefinition Width="*"/>     <!-- Name + desc -->
                                                    <ColumnDefinition Width="Auto"/>  <!-- Checkmark badge / step count -->
                                                </Grid.ColumnDefinitions>

                                                <!-- Emoji icon -->
                                                <Border Grid.Column="0"
                                                        Width="40" Height="40"
                                                        CornerRadius="{StaticResource CornerRadiusMedium}"
                                                        Background="{DynamicResource SurfaceElevatedBrush}"
                                                        Margin="0,0,12,0">
                                                    <TextBlock Text="{Binding Icon, Mode=OneWay}"
                                                               FontSize="18"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"/>
                                                </Border>

                                                <!-- Name + description + category -->
                                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Name, Mode=OneWay}"
                                                               FontWeight="SemiBold"
                                                               FontSize="13"
                                                               Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}"/>
                                                    <TextBlock Text="{Binding Description, Mode=OneWay}"
                                                               FontSize="11"
                                                               TextTrimming="CharacterEllipsis"
                                                               Margin="0,2,0,0"
                                                               Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}"/>
                                                    <TextBlock FontSize="11"
                                                               Margin="0,2,0,0"
                                                               Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}">
                                                        <Run Text="{Binding Category, Mode=OneWay}"/>
                                                        <Run Text=" · "/>
                                                        <Run Text="{Binding StepCount, Mode=OneWay}"/>
                                                        <Run Text=" step"/>
                                                    </TextBlock>
                                                </StackPanel>

                                                <!-- Right column: checkmark badge (selected) or step count badge (unselected) -->
                                                <Grid Grid.Column="2" VerticalAlignment="Top" Margin="8,0,0,0">
                                                    <!-- Step count badge — visible when NOT selected -->
                                                    <Border Background="{DynamicResource SurfaceElevatedBrush}"
                                                            CornerRadius="{StaticResource CornerRadiusSmall}"
                                                            Padding="8,3"
                                                            Visibility="{Binding IsSelected, Converter={StaticResource InverseBoolToVisibility}}">
                                                        <TextBlock Text="{Binding StepCount, StringFormat='{}{0} step', Mode=OneWay}"
                                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                                   FontSize="11"/>
                                                    </Border>
                                                    <!-- Checkmark badge — visible when selected -->
                                                    <Border Width="22" Height="22"
                                                            Background="White"
                                                            CornerRadius="11"
                                                            Visibility="{Binding IsSelected, Converter={StaticResource BoolToVisibility}}">
                                                        <TextBlock Text="✓"
                                                                   FontSize="12"
                                                                   FontWeight="Bold"
                                                                   Foreground="{DynamicResource AccentBrush}"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center"/>
                                                    </Border>
                                                </Grid>
                                            </Grid>
                                        </ToggleButton>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>

                        <!-- Action bar with Create Preset button -->
                        <Border Grid.Row="3"
                                Background="{DynamicResource SurfaceElevatedBrush}"
                                CornerRadius="0,0,8,8"
                                Padding="16,12">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Create New Preset button -->
                                <Button Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2"
                                        Command="{Binding OpenCreatePresetCommand}"
                                        Style="{StaticResource Win11AccentButton}"
                                        HorizontalAlignment="Stretch"
                                        Padding="12,8"
                                        Margin="0,0,0,8">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <TextBlock Text="➕" FontSize="16" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <TextBlock Text="Crea Nuovo Preset" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>

                                <!-- Overall status -->
                                <TextBlock Grid.Row="1" Grid.Column="0"
                                           Text="{Binding OverallStatus}"
                                           TextWrapping="Wrap"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           FontSize="12"/>

                                <!-- Run queue button -->
                                <Button Grid.Row="1" Grid.Column="1"
                                        Content="{Binding IsRunning, Converter={StaticResource BusyToTextConverter},
                                                  ConverterParameter='▶  Esegui Coda|⏳  Esecuzione…'}"
                                        Command="{Binding RunQueueCommand}"
                                        Style="{StaticResource Win11AccentButton}"
                                        Height="36" MinWidth="160"
                                        IsEnabled="{Binding IsRunning, Converter={StaticResource InverseBoolConverter}, FallbackValue=True}"/>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>

                <!-- Splitter -->
                <GridSplitter Grid.Column="1"
                              Width="8"
                              HorizontalAlignment="Stretch"
                              Background="Transparent"
                              Cursor="SizeWE"/>

                <!-- ────────────────────────────────────────────────
                     RIGHT PANEL — Execution Queue (2/5)
                ──────────────────────────────────────────────────── -->
                <Border Grid.Column="2" Style="{StaticResource Win11Card}" Padding="0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>  <!-- Card header -->
                            <RowDefinition Height="Auto"/>  <!-- Search bar + Create button -->
                            <RowDefinition Height="*"/>     <!-- Queue list -->
                        </Grid.RowDefinitions>

                        <!-- Card header -->
                        <Border Grid.Row="0"
                                Background="{DynamicResource SurfaceElevatedBrush}"
                                CornerRadius="8,8,0,0"
                                Padding="14,12">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <Image Source="{DynamicResource IconSettings}"
                                           Width="15" Height="15"
                                           VerticalAlignment="Center"
                                           Margin="0,0,7,0"
                                           RenderOptions.BitmapScalingMode="HighQuality"/>
                                    <TextBlock Text="Coda di Esecuzione"
                                               Style="{StaticResource Win11TextSubtitle}"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Search bar + Create Process button -->
                        <Border Grid.Row="1"
                                Background="{DynamicResource SurfaceBrush}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="0,1,0,1"
                                Padding="12,8">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Search bar -->
                                <Grid Grid.Row="0" Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox Grid.Column="0"
                                             Text="{Binding ProcessSearchText, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource Win11TextBox}"
                                             Padding="28,6,8,6"
                                             FontSize="12">
                                        <TextBox.Resources>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                            </Style>
                                        </TextBox.Resources>
                                    </TextBox>
                                    <!-- Search icon -->
                                    <Image Grid.Column="0"
                                           Source="{DynamicResource IconSettings}"
                                           Width="14" Height="14"
                                           HorizontalAlignment="Left"
                                           VerticalAlignment="Center"
                                           Margin="10,0,0,0"
                                           Opacity="0.5"
                                           IsHitTestVisible="False"
                                           RenderOptions.BitmapScalingMode="HighQuality"/>
                                    <!-- Clear button -->
                                    <Button Grid.Column="1"
                                            Content="✕"
                                            Command="{Binding ClearProcessSearchCommand}"
                                            Style="{StaticResource Win11Button}"
                                            Width="28" Height="28"
                                            Padding="0"
                                            Margin="4,0,0,0"
                                            FontSize="12"
                                            Visibility="{Binding ProcessSearchText, Converter={StaticResource StringToVisibilityConverter}}"/>
                                </Grid>

                                <!-- Create Process button -->
                                <Button Grid.Row="1"
                                        Command="{Binding CreateProcessCommand}"
                                        Style="{StaticResource Win11AccentButton}"
                                        HorizontalAlignment="Stretch"
                                        Padding="10,8">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <TextBlock Text="➕" FontSize="14" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                        <TextBlock Text="Nuovo Processo" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </Grid>
                        </Border>

                        <!-- Empty state -->
                        <TextBlock Grid.Row="2"
                                   Text="Seleziona uno o più preset per costruire la coda di esecuzione"
                                   Style="{StaticResource Win11TextSecondary}"
                                   TextWrapping="Wrap"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   TextAlignment="Center"
                                   Margin="16"
                                   Visibility="{Binding ExecutionQueue.Count,
                                                Converter={StaticResource NullToVisibilityConverter},
                                                ConverterParameter=Inverse}"/>

                        <!-- Queue items -->
                        <ScrollViewer Grid.Row="2"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled"
                                      Padding="8,8,8,8">
                            <ItemsControl ItemsSource="{Binding FilteredExecutionQueue}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <ToggleButton IsChecked="{Binding IsEnabled, Mode=TwoWay}">
                                            <ToggleButton.Style>
                                                <Style TargetType="ToggleButton" BasedOn="{StaticResource ProcessCardToggleButton}">
                                                    <Style.Triggers>
                                                        <!-- ISSUE 4 & 6 FIX: Grey out ONLY when not in selected preset AND not manually enabled -->
                                                        <!-- If IsEnabled=true, always show at full opacity (1.0) -->
                                                        <DataTrigger Binding="{Binding IsEnabled}" Value="True">
                                                            <Setter Property="Opacity" Value="1.0"/>
                                                        </DataTrigger>
                                                        <!-- If IsEnabled=false AND not in preset, grey out more -->
                                                        <MultiDataTrigger>
                                                            <MultiDataTrigger.Conditions>
                                                                <Condition Binding="{Binding IsEnabled}" Value="False"/>
                                                                <Condition Binding="{Binding IsInSelectedPreset}" Value="False"/>
                                                            </MultiDataTrigger.Conditions>
                                                            <Setter Property="Opacity" Value="0.3"/>
                                                        </MultiDataTrigger>
                                                        <!-- If IsEnabled=false BUT in preset (manually deselected), moderate grey -->
                                                        <MultiDataTrigger>
                                                            <MultiDataTrigger.Conditions>
                                                                <Condition Binding="{Binding IsEnabled}" Value="False"/>
                                                                <Condition Binding="{Binding IsInSelectedPreset}" Value="True"/>
                                                            </MultiDataTrigger.Conditions>
                                                            <Setter Property="Opacity" Value="0.5"/>
                                                        </MultiDataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </ToggleButton.Style>
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>  <!-- Checkbox indicator -->
                                                    <ColumnDefinition Width="Auto"/>  <!-- Status icon -->
                                                    <ColumnDefinition Width="*"/>     <!-- Name -->
                                                    <ColumnDefinition Width="Auto"/>  <!-- Kind label -->
                                                </Grid.ColumnDefinitions>

                                                <!-- Checkbox indicator (visual only) -->
                                                <Border Grid.Row="0" Grid.Column="0"
                                                        Width="22" Height="22"
                                                        CornerRadius="11"
                                                        BorderThickness="2"
                                                        VerticalAlignment="Center"
                                                        Margin="0,0,8,0">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
                                                            <Setter Property="Background" Value="Transparent"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsEnabled}" Value="True">
                                                                    <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                                                                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <TextBlock Text="✓"
                                                               FontSize="13"
                                                               FontWeight="Bold"
                                                               Foreground="White"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsEnabled}" Value="True">
                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Border>

                                                <!-- Status icon -->
                                                <TextBlock Grid.Row="0" Grid.Column="1"
                                                           Text="{Binding StatusIcon}"
                                                           FontSize="13"
                                                           VerticalAlignment="Center"
                                                           Margin="0,0,7,0"
                                                           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}"/>

                                                <!-- Process name -->
                                                <TextBlock Grid.Row="0" Grid.Column="2"
                                                           Text="{Binding Name}"
                                                           Style="{StaticResource Win11TextBody}"
                                                           FontWeight="SemiBold"
                                                           TextTrimming="CharacterEllipsis"
                                                           VerticalAlignment="Center"
                                                           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}"/>

                                                <!-- Kind label badge -->
                                                <Border Grid.Row="0" Grid.Column="3"
                                                        Background="{DynamicResource SurfaceElevatedBrush}"
                                                        CornerRadius="3"
                                                        Padding="5,1"
                                                        Margin="6,0,0,0"
                                                        VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding KindLabel}"
                                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                                               FontSize="10"/>
                                                </Border>

                                                <!-- Description + required badge + status text -->
                                                <StackPanel Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="3"
                                                            Orientation="Horizontal"
                                                            Margin="0,4,0,0">
                                                    <TextBlock Text="{Binding Description}"
                                                               Style="{StaticResource Win11TextSecondary}"
                                                               TextTrimming="CharacterEllipsis"
                                                               Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}"/>
                                                    <!-- Required badge -->
                                                    <Border Background="#1AFF9800"
                                                            CornerRadius="3"
                                                            Padding="5,1"
                                                            Margin="6,0,0,0"
                                                            VerticalAlignment="Center"
                                                            Visibility="{Binding IsRequired, Converter={StaticResource BoolToVisibility}}">
                                                        <TextBlock Text="Richiesto"
                                                                   Foreground="{DynamicResource WarningBrush}"
                                                                   FontSize="10"
                                                                   FontWeight="SemiBold"/>
                                                    </Border>
                                                    <!-- Status text -->
                                                    <TextBlock Text="{Binding StatusText}"
                                                               Style="{StaticResource Win11TextSecondary}"
                                                               Margin="8,0,0,0"
                                                               FontSize="10"
                                                               Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}"/>
                                                </StackPanel>
                                            </Grid>
                                        </ToggleButton>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>

            <!-- ══════════════════════════════════════════════════════
                 ROW 3 — LOG PANEL
            ══════════════════════════════════════════════════════ -->
            <Border Grid.Row="3"
                    Margin="12,0,12,12"
                    Style="{StaticResource Win11Card}"
                    Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Background="{DynamicResource SurfaceElevatedBrush}"
                            CornerRadius="8,8,0,0"
                            Padding="16,10">
                        <StackPanel Orientation="Horizontal">
                            <Image Source="{DynamicResource IconLog}"
                                   Width="14" Height="14"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0"
                                   RenderOptions.BitmapScalingMode="HighQuality"/>
                            <TextBlock Text="Log"
                                       Style="{StaticResource Win11TextSubtitle}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="1"
                            Background="{DynamicResource LogBackgroundBrush}"
                            CornerRadius="0,0,8,8">
                        <ListView ItemsSource="{Binding LogViewModel.LogEntries}"
                                  FontFamily="Cascadia Code, Consolas, monospace"
                                  FontSize="11"
                                  Background="Transparent"
                                  BorderThickness="0"
                                  Foreground="{DynamicResource LogTextBrush}"
                                  ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                  Padding="4">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="Ora" Width="72"
                                                    DisplayMemberBinding="{Binding Timestamp, StringFormat=HH:mm:ss}"/>
                                    <GridViewColumn Header="Livello" Width="64"
                                                    DisplayMemberBinding="{Binding Level}"/>
                                    <GridViewColumn Header="Messaggio" Width="900"
                                                    DisplayMemberBinding="{Binding Message}"/>
                                </GridView>
                            </ListView.View>
                        </ListView>
                    </Border>
                </Grid>
            </Border>

            <!-- ══════════════════════════════════════════════════════
                 SLIDING PANEL OVERLAY — Create Preset Panel
                 Appears from left with animation, overlays main content
            ══════════════════════════════════════════════════════ -->
            <Grid Grid.Row="0" Grid.RowSpan="4"
                  Visibility="{Binding IsCreatePresetPanelOpen, Converter={StaticResource BoolToVisibility}}"
                  x:Name="CreatePresetOverlay">
                
                <!-- Semi-transparent backdrop -->
                <Border Background="#80000000" x:Name="Backdrop">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Opacity" Value="0"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsCreatePresetPanelOpen}" Value="True">
                                    <DataTrigger.EnterActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                               To="1" Duration="0:0:0.2"
                                                               EasingFunction="{StaticResource EaseOut}"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </DataTrigger.EnterActions>
                                    <DataTrigger.ExitActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                               To="0" Duration="0:0:0.15"
                                                               EasingFunction="{StaticResource EaseIn}"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </DataTrigger.ExitActions>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                </Border>

                <!-- Sliding panel from left -->
                <Border x:Name="SlidingPanel"
                        Width="500"
                        HorizontalAlignment="Left"
                        Background="{DynamicResource AppBackgroundBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="0,0,1,0"
                        Effect="{StaticResource CardShadow}"
                        RenderTransformOrigin="0,0">
                    <Border.RenderTransform>
                        <TranslateTransform X="-500"/>
                    </Border.RenderTransform>
                    <Border.Style>
                        <Style TargetType="Border">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsCreatePresetPanelOpen}" Value="True">
                                    <DataTrigger.EnterActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(TranslateTransform.X)"
                                                               To="0" Duration="0:0:0.3">
                                                    <DoubleAnimation.EasingFunction>
                                                        <CubicEase EasingMode="EaseOut"/>
                                                    </DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </DataTrigger.EnterActions>
                                    <DataTrigger.ExitActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(TranslateTransform.X)"
                                                               To="-500" Duration="0:0:0.25">
                                                    <DoubleAnimation.EasingFunction>
                                                        <CubicEase EasingMode="EaseIn"/>
                                                    </DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </DataTrigger.ExitActions>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>

                    <Grid DataContext="{Binding CreatePresetViewModel}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>  <!-- Header -->
                            <RowDefinition Height="*"/>     <!-- Content -->
                            <RowDefinition Height="Auto"/>  <!-- Actions -->
                        </Grid.RowDefinitions>

                        <!-- Header -->
                        <Border Grid.Row="0"
                                Background="{DynamicResource SurfaceElevatedBrush}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="0,0,0,1"
                                Padding="20,16">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Crea Nuovo Preset"
                                               Style="{StaticResource Win11TextTitle}"
                                               Margin="0,0,0,4"/>
                                    <TextBlock Text="Configura un nuovo preset di installazione personalizzato"
                                               Style="{StaticResource Win11TextSecondary}"/>
                                </StackPanel>

                                <!-- Close button -->
                                <Button Grid.Column="1"
                                        Command="{Binding CancelCommand}"
                                        Style="{StaticResource Win11Button}"
                                        Width="36" Height="36"
                                        Padding="0"
                                        ToolTip="Chiudi">
                                    <TextBlock Text="✕" FontSize="16"/>
                                </Button>
                            </Grid>
                        </Border>

                        <!-- Content -->
                        <ScrollViewer Grid.Row="1"
                                      VerticalScrollBarVisibility="Auto"
                                      Padding="20,16">
                            <StackPanel>
                                <!-- Validation error -->
                                <Border Background="#1AFF3333"
                                        BorderBrush="{DynamicResource ErrorBrush}"
                                        BorderThickness="1"
                                        CornerRadius="{StaticResource CornerRadiusSmall}"
                                        Padding="12,8"
                                        Margin="0,0,0,16"
                                        Visibility="{Binding ValidationError, Converter={StaticResource StringToVisibilityConverter}}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="⚠️" FontSize="16" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <TextBlock Text="{Binding ValidationError}"
                                                   Foreground="{DynamicResource ErrorBrush}"
                                                   TextWrapping="Wrap"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>

                                <!-- Nome -->
                                <TextBlock Text="Nome *" Style="{StaticResource Win11TextBody}" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource Win11TextBox}"
                                         Margin="0,0,0,16"/>

                                <!-- Icona -->
                                <TextBlock Text="Icona" Style="{StaticResource Win11TextBody}" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                <ComboBox ItemsSource="{Binding AvailableIcons}"
                                          SelectedItem="{Binding Icon}"
                                          Style="{StaticResource Win11ComboBox}"
                                          Margin="0,0,0,16">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding}" FontSize="20"/>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>

                                <!-- Descrizione -->
                                <TextBlock Text="Descrizione" Style="{StaticResource Win11TextBody}" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource Win11TextBox}"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         MinHeight="60"
                                         VerticalScrollBarVisibility="Auto"
                                         Margin="0,0,0,16"/>

                                <!-- Categoria -->
                                <TextBlock Text="Categoria" Style="{StaticResource Win11TextBody}" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                <ComboBox ItemsSource="{Binding CategorySuggestions}"
                                          Text="{Binding Category}"
                                          IsEditable="True"
                                          Style="{StaticResource Win11ComboBox}"
                                          Margin="0,0,0,20"/>

                                <!-- Process Selection Section -->
                                <TextBlock Text="Processi *" Style="{StaticResource Win11TextBody}" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                <TextBlock Text="Seleziona i processi da includere nel preset e marca quelli richiesti"
                                           Style="{StaticResource Win11TextSecondary}"
                                           Margin="0,0,0,8"/>

                                <!-- Search bar -->
                                <TextBox Text="{Binding ProcessSearchText, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource Win11TextBox}"
                                         Padding="28,6,8,6"
                                         Margin="0,0,0,12">
                                    <TextBox.Resources>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                        </Style>
                                    </TextBox.Resources>
                                </TextBox>

                                <!-- Process list with checkboxes -->
                                <Border Background="{DynamicResource SurfaceBrush}"
                                        BorderBrush="{DynamicResource BorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="{StaticResource CornerRadiusSmall}"
                                        MaxHeight="400">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <ItemsControl ItemsSource="{Binding FilteredProcesses}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border BorderBrush="{DynamicResource BorderBrush}"
                                                            BorderThickness="0,0,0,1"
                                                            Padding="12,10">
                                                        <Grid>
                                                            <Grid.RowDefinitions>
                                                                <RowDefinition Height="Auto"/>
                                                                <RowDefinition Height="Auto"/>
                                                            </Grid.RowDefinitions>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>

                                                            <!-- Checkbox -->
                                                            <CheckBox Grid.Row="0" Grid.Column="0"
                                                                      IsChecked="{Binding IsSelected}"
                                                                      VerticalAlignment="Center"
                                                                      Margin="0,0,10,0"/>

                                                            <!-- Order number (when selected) -->
                                                            <Border Grid.Row="0" Grid.Column="1"
                                                                    Background="{DynamicResource AccentBrush}"
                                                                    CornerRadius="10"
                                                                    Width="20" Height="20"
                                                                    Margin="0,0,8,0"
                                                                    Visibility="{Binding IsSelected, Converter={StaticResource BoolToVisibility}}">
                                                                <TextBlock Text="{Binding Order, Converter={StaticResource OrderToDisplayConverter}}"
                                                                           Foreground="White"
                                                                           FontSize="10"
                                                                           FontWeight="Bold"
                                                                           HorizontalAlignment="Center"
                                                                           VerticalAlignment="Center"/>
                                                            </Border>

                                                            <!-- Process info -->
                                                            <StackPanel Grid.Row="0" Grid.Column="2" VerticalAlignment="Center">
                                                                <TextBlock Text="{Binding Name}"
                                                                           Style="{StaticResource Win11TextBody}"
                                                                           FontWeight="SemiBold"/>
                                                                <TextBlock Text="{Binding Description}"
                                                                           Style="{StaticResource Win11TextSecondary}"
                                                                           TextTrimming="CharacterEllipsis"/>
                                                            </StackPanel>

                                                            <!-- Type badge -->
                                                            <Border Grid.Row="0" Grid.Column="3"
                                                                    Background="{DynamicResource SurfaceElevatedBrush}"
                                                                    CornerRadius="3"
                                                                    Padding="6,2"
                                                                    Margin="8,0,8,0"
                                                                    VerticalAlignment="Center">
                                                                <TextBlock Text="{Binding KindLabel}"
                                                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                                                           FontSize="10"/>
                                                            </Border>

                                                            <!-- Reorder buttons (when selected) -->
                                                            <StackPanel Grid.Row="0" Grid.Column="4"
                                                                        Orientation="Horizontal"
                                                                        Visibility="{Binding IsSelected, Converter={StaticResource BoolToVisibility}}">
                                                                <Button Command="{Binding DataContext.MoveProcessUpCommand, RelativeSource={RelativeSource AncestorType=ScrollViewer}}"
                                                                        CommandParameter="{Binding}"
                                                                        Style="{StaticResource Win11Button}"
                                                                        Width="28" Height="28"
                                                                        Padding="0"
                                                                        Margin="0,0,4,0"
                                                                        ToolTip="Sposta su">
                                                                    <TextBlock Text="▲" FontSize="10"/>
                                                                </Button>
                                                                <Button Command="{Binding DataContext.MoveProcessDownCommand, RelativeSource={RelativeSource AncestorType=ScrollViewer}}"
                                                                        CommandParameter="{Binding}"
                                                                        Style="{StaticResource Win11Button}"
                                                                        Width="28" Height="28"
                                                                        Padding="0"
                                                                        ToolTip="Sposta giù">
                                                                    <TextBlock Text="▼" FontSize="10"/>
                                                                </Button>
                                                            </StackPanel>
                                                            
                                                            <!-- Required checkbox (when selected) -->
                                                            <CheckBox Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="3"
                                                                      IsChecked="{Binding IsRequired}"
                                                                      Margin="0,6,0,0"
                                                                      Visibility="{Binding IsSelected, Converter={StaticResource BoolToVisibility}}">
                                                                <TextBlock Text="Richiesto (non può essere disabilitato)"
                                                                           Style="{StaticResource Win11TextSecondary}"
                                                                           FontSize="11"/>
                                                            </CheckBox>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>

                        <!-- Action buttons -->
                        <Border Grid.Row="2"
                                Background="{DynamicResource SurfaceElevatedBrush}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="0,1,0,0"
                                Padding="20,16">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <Button Grid.Column="0"
                                        Content="Annulla"
                                        Command="{Binding CancelCommand}"
                                        Style="{StaticResource Win11Button}"
                                        Height="40"
                                        Margin="0,0,8,0"/>

                                <Button Grid.Column="1"
                                        Content="Salva Preset"
                                        Command="{Binding SaveCommand}"
                                        Style="{StaticResource Win11AccentButton}"
                                        Height="40"
                                        MinWidth="140"/>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>
