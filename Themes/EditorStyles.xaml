<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib"
                    xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework">

    <sys:Double x:Key="EditorShellPadding">10</sys:Double>
    <sys:Double x:Key="EditorPanelGap">8</sys:Double>
    <sys:Double x:Key="EditorSectionGap">8</sys:Double>
    <sys:Double x:Key="EditorSidebarWidth">256</sys:Double>
    <sys:Double x:Key="EditorExplorerWidth">288</sys:Double>
    <sys:Double x:Key="EditorToolbarHeight">36</sys:Double>
    <sys:Double x:Key="EditorToolbarButtonHeight">30</sys:Double>

    <SolidColorBrush x:Key="EditorChromeBrush" Color="{DynamicResource ToolbarColor}"/>
    <SolidColorBrush x:Key="EditorHeaderSurfaceBrush" Color="{DynamicResource ToolbarColor}"/>
    <SolidColorBrush x:Key="EditorToolbarSurfaceBrush" Color="{DynamicResource ToolbarColor}"/>
    <SolidColorBrush x:Key="EditorSidebarHeaderBrush" Color="{DynamicResource ToolbarColor}"/>
    <SolidColorBrush x:Key="EditorSidebarSurfaceBrush" Color="{DynamicResource SidebarColor}"/>
    <SolidColorBrush x:Key="EditorPanelBrush" Color="{DynamicResource SurfaceColor}"/>
    <SolidColorBrush x:Key="EditorPanelAltBrush" Color="{DynamicResource SurfaceColor}"/>
    <SolidColorBrush x:Key="EditorSubtleBorderBrush" Color="{DynamicResource BorderColor}"/>
    <SolidColorBrush x:Key="EditorMutedBrush" Color="#80FFFFFF"/>
    <SolidColorBrush x:Key="EditorInfoSurfaceBrush" Color="#140078D4"/>
    <SolidColorBrush x:Key="EditorSuccessToneBrush" Color="#164CAF50"/>
    <SolidColorBrush x:Key="EditorWarningToneBrush" Color="#18FFC107"/>
    <SolidColorBrush x:Key="EditorErrorToneBrush" Color="#18CF6679"/>
    <SolidColorBrush x:Key="EditorCodeSurfaceBrush" Color="{DynamicResource SurfaceColor}"/>
    <SolidColorBrush x:Key="EditorTerminalSurfaceBrush" Color="{DynamicResource LogBackgroundColor}"/>
    <SolidColorBrush x:Key="EditorTabActiveBrush" Color="#220078D4"/>

    <Style x:Key="EditorShellCard" TargetType="Border" BasedOn="{StaticResource Win11Card}">
        <Setter Property="Padding" Value="0"/>
        <Setter Property="Background" Value="{DynamicResource EditorPanelBrush}"/>
        <Setter Property="CornerRadius" Value="12"/>
        <Setter Property="BorderBrush" Value="{DynamicResource EditorSubtleBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
    </Style>

    <Style x:Key="EditorSectionTitle" TargetType="TextBlock" BasedOn="{StaticResource Win11TextSubtitle}">
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>

    <Style x:Key="EditorSectionCaption" TargetType="TextBlock" BasedOn="{StaticResource Win11TextSecondary}">
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
    </Style>

    <Style x:Key="EditorHeaderTitle" TargetType="TextBlock" BasedOn="{StaticResource Win11TextTitle}">
        <Setter Property="FontSize" Value="17"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>

    <Style x:Key="EditorHeaderSubtitle" TargetType="TextBlock" BasedOn="{StaticResource Win11TextSecondary}">
        <Setter Property="FontSize" Value="10"/>
        <Setter Property="Margin" Value="0,1,0,0"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
    </Style>

    <Style x:Key="EditorWindowLabel" TargetType="TextBlock" BasedOn="{StaticResource Win11TextSecondary}">
        <Setter Property="FontSize" Value="10"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Opacity" Value="0.88"/>
    </Style>

    <Style x:Key="EditorHeaderMetaLabel" TargetType="TextBlock" BasedOn="{StaticResource Win11TextSecondary}">
        <Setter Property="FontSize" Value="10"/>
        <Setter Property="Opacity" Value="0.9"/>
    </Style>

    <Style x:Key="EditorHeaderMetaValue" TargetType="TextBlock" BasedOn="{StaticResource Win11TextBody}">
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>

    <Style x:Key="EditorToolbarButton" TargetType="Button" BasedOn="{StaticResource Win11Button}">
        <Setter Property="Height" Value="{StaticResource EditorToolbarButtonHeight}"/>
        <Setter Property="Padding" Value="10,2"/>
        <Setter Property="Margin" Value="0,0,6,0"/>
        <Setter Property="shell:WindowChrome.IsHitTestVisibleInChrome" Value="True"/>
    </Style>

    <Style x:Key="EditorToolbarAccentButton" TargetType="Button" BasedOn="{StaticResource Win11AccentButton}">
        <Setter Property="Height" Value="{StaticResource EditorToolbarButtonHeight}"/>
        <Setter Property="Padding" Value="10,2"/>
        <Setter Property="Margin" Value="0,0,6,0"/>
        <Setter Property="shell:WindowChrome.IsHitTestVisibleInChrome" Value="True"/>
    </Style>

    <Style x:Key="EditorToolbarIconButton" TargetType="Button" BasedOn="{StaticResource Win11IconButton}">
        <Setter Property="Width" Value="30"/>
        <Setter Property="Height" Value="30"/>
        <Setter Property="Margin" Value="0,0,6,0"/>
        <Setter Property="shell:WindowChrome.IsHitTestVisibleInChrome" Value="True"/>
    </Style>

    <Style x:Key="EditorToolbarIconAccentButton" TargetType="Button" BasedOn="{StaticResource Win11AccentButton}">
        <Setter Property="Width" Value="30"/>
        <Setter Property="Height" Value="30"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="Margin" Value="0,0,6,0"/>
        <Setter Property="shell:WindowChrome.IsHitTestVisibleInChrome" Value="True"/>
    </Style>

    <Style x:Key="EditorToolbarPrimaryButton" TargetType="Button" BasedOn="{StaticResource Win11AccentButton}">
        <Setter Property="Height" Value="{StaticResource EditorToolbarButtonHeight}"/>
        <Setter Property="MinWidth" Value="72"/>
        <Setter Property="Padding" Value="12,0"/>
        <Setter Property="Margin" Value="0,0,8,0"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="shell:WindowChrome.IsHitTestVisibleInChrome" Value="True"/>
    </Style>

    <Style x:Key="EditorMiniButton" TargetType="Button" BasedOn="{StaticResource Win11Button}">
        <Setter Property="Height" Value="28"/>
        <Setter Property="Padding" Value="10,2"/>
        <Setter Property="Margin" Value="0,0,8,0"/>
        <Setter Property="FontSize" Value="12"/>
    </Style>

    <Style x:Key="EditorGlyphButton" TargetType="Button" BasedOn="{StaticResource Win11IconButton}">
        <Setter Property="Width" Value="28"/>
        <Setter Property="Height" Value="28"/>
        <Setter Property="shell:WindowChrome.IsHitTestVisibleInChrome" Value="True"/>
    </Style>

    <Style x:Key="EditorInlineIconButton" TargetType="Button" BasedOn="{StaticResource EditorGlyphButton}">
        <Setter Property="Width" Value="24"/>
        <Setter Property="Height" Value="24"/>
        <Setter Property="Margin" Value="0,0,4,0"/>
        <Setter Property="Opacity" Value="0.88"/>
    </Style>

    <Style x:Key="EditorInlineIconButtonLast" TargetType="Button" BasedOn="{StaticResource EditorInlineIconButton}">
        <Setter Property="Margin" Value="0"/>
    </Style>

    <Style x:Key="EditorIcon12" TargetType="Image">
        <Setter Property="Width" Value="12"/>
        <Setter Property="Height" Value="12"/>
        <Setter Property="Stretch" Value="Uniform"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="UseLayoutRounding" Value="True"/>
    </Style>

    <Style x:Key="EditorIcon16" TargetType="Image">
        <Setter Property="Width" Value="16"/>
        <Setter Property="Height" Value="16"/>
        <Setter Property="Stretch" Value="Uniform"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="UseLayoutRounding" Value="True"/>
    </Style>

    <Style x:Key="EditorIcon20" TargetType="Image">
        <Setter Property="Width" Value="20"/>
        <Setter Property="Height" Value="20"/>
        <Setter Property="Stretch" Value="Uniform"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="UseLayoutRounding" Value="True"/>
    </Style>

    <Style x:Key="EditorTitleIconBorder" TargetType="Border">
        <Setter Property="Width" Value="30"/>
        <Setter Property="Height" Value="30"/>
        <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="9"/>
        <Setter Property="Padding" Value="6"/>
        <Setter Property="Margin" Value="0,0,8,0"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <Style x:Key="EditorPaneActionButton" TargetType="Button" BasedOn="{StaticResource EditorMiniButton}">
        <Setter Property="MinWidth" Value="30"/>
        <Setter Property="Padding" Value="8,1"/>
        <Setter Property="FontSize" Value="11"/>
    </Style>

    <Style x:Key="EditorHeaderMetaGroup" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="Padding" Value="10,6"/>
        <Setter Property="Margin" Value="8,0,0,0"/>
    </Style>

    <Style x:Key="EditorHeaderMetaWrap" TargetType="WrapPanel">
        <Setter Property="Orientation" Value="Horizontal"/>
        <Setter Property="HorizontalAlignment" Value="Right"/>
    </Style>

    <Style x:Key="EditorToolGroup" TargetType="Border">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="CornerRadius" Value="0"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="Margin" Value="0,0,10,0"/>
    </Style>

    <Style x:Key="EditorToolbarDivider" TargetType="Border">
        <Setter Property="Width" Value="1"/>
        <Setter Property="Height" Value="18"/>
        <Setter Property="Margin" Value="4,0,10,0"/>
        <Setter Property="Background" Value="{DynamicResource EditorSubtleBorderBrush}"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <Style x:Key="EditorPaneToggleButton" TargetType="ToggleButton" BasedOn="{StaticResource Win11Button}">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="12,4"/>
        <Setter Property="Margin" Value="0,0,6,0"/>
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="MinHeight" Value="28"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <Border x:Name="Root"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="999"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="{DynamicResource HoverBrush}"/>
                            <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource EditorSubtleBorderBrush}"/>
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="{DynamicResource EditorInfoSurfaceBrush}"/>
                            <Setter TargetName="Root" Property="BorderBrush" Value="#320078D4"/>
                            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                        </Trigger>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource FocusRingBrush}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.45"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="EditorBadgeBorder" TargetType="Border">
        <Setter Property="CornerRadius" Value="999"/>
        <Setter Property="Padding" Value="12,3"/>
        <Setter Property="Margin" Value="0,0,10,0"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="MinHeight" Value="22"/>
        <Setter Property="Opacity" Value="1"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="BorderBrush" Value="#24FFFFFF"/>
    </Style>

    <Style x:Key="EditorActivityBadgeBorder" TargetType="Border" BasedOn="{StaticResource EditorBadgeBorder}">
        <Setter Property="Background" Value="{DynamicResource EditorSuccessToneBrush}"/>
        <Setter Property="BorderBrush" Value="#2A4CAF50"/>
        <Style.Triggers>
            <DataTrigger Binding="{Binding IsRunning}" Value="True">
                <Setter Property="Background" Value="{DynamicResource EditorInfoSurfaceBrush}"/>
                <Setter Property="BorderBrush" Value="#320078D4"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding IsDirty}" Value="True">
                <Setter Property="Background" Value="{DynamicResource EditorWarningToneBrush}"/>
                <Setter Property="BorderBrush" Value="#35FFC107"/>
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="EditorDiagnosticsBadgeBorder" TargetType="Border" BasedOn="{StaticResource EditorBadgeBorder}">
        <Setter Property="Background" Value="{DynamicResource EditorSuccessToneBrush}"/>
        <Setter Property="BorderBrush" Value="#2A4CAF50"/>
        <Style.Triggers>
            <DataTrigger Binding="{Binding HasErrorDiagnostics}" Value="True">
                <Setter Property="Background" Value="{DynamicResource EditorErrorToneBrush}"/>
                <Setter Property="BorderBrush" Value="#35CF6679"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding HasWarningDiagnostics}" Value="True">
                <Setter Property="Background" Value="{DynamicResource EditorWarningToneBrush}"/>
                <Setter Property="BorderBrush" Value="#35FFC107"/>
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="EditorSeverityBadgeBorder" TargetType="Border" BasedOn="{StaticResource EditorBadgeBorder}">
        <Setter Property="Background" Value="{DynamicResource EditorInfoSurfaceBrush}"/>
        <Setter Property="BorderBrush" Value="#320078D4"/>
        <Style.Triggers>
            <DataTrigger Binding="{Binding Severity}" Value="WARN">
                <Setter Property="Background" Value="{DynamicResource EditorWarningToneBrush}"/>
                <Setter Property="BorderBrush" Value="#35FFC107"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding Severity}" Value="ERROR">
                <Setter Property="Background" Value="{DynamicResource EditorErrorToneBrush}"/>
                <Setter Property="BorderBrush" Value="#35CF6679"/>
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="EditorBadgeText" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
        <Setter Property="FontSize" Value="10"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Margin" Value="0,-1,0,0"/>
    </Style>

    <Style x:Key="EditorDocumentBadgeBorder" TargetType="Border" BasedOn="{StaticResource EditorBadgeBorder}">
        <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
        <Setter Property="Padding" Value="8,3"/>
    </Style>

    <Style x:Key="EditorWindowChromeButton" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Width" Value="44"/>
        <Setter Property="Height" Value="44"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Cursor" Value="Arrow"/>
        <Setter Property="shell:WindowChrome.IsHitTestVisibleInChrome" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Root"
                            Background="{TemplateBinding Background}"
                            BorderThickness="0">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="{DynamicResource HoverBrush}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="{DynamicResource BorderBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="EditorWindowChromeCloseButton" TargetType="Button" BasedOn="{StaticResource EditorWindowChromeButton}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Root"
                            Background="{TemplateBinding Background}"
                            BorderThickness="0">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="#FFE81123"/>
                            <Setter Property="Foreground" Value="#FFFFFFFF"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="#FFC42B1C"/>
                            <Setter Property="Foreground" Value="#FFFFFFFF"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="EditorSidebarTree" TargetType="TreeView">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="KeyboardNavigation.TabNavigation" Value="Continue"/>
    </Style>

    <Style x:Key="EditorSidebarTreeItem" TargetType="TreeViewItem">
        <Setter Property="Padding" Value="0"/>
        <Setter Property="Margin" Value="0,0,0,4"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TreeViewItem">
                    <StackPanel>
                        <Border x:Name="ItemChrome"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="1"
                                CornerRadius="10"
                                Padding="6,4">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <ToggleButton x:Name="Expander"
                                              Grid.Column="0"
                                              Width="18"
                                              Height="18"
                                              Margin="0,2,6,0"
                                              Visibility="{Binding HasItems, RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource BoolToVisibility}}"
                                              IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}}"
                                              Style="{StaticResource Win11Button}"
                                              Focusable="False"
                                              Padding="0">
                                    <Image x:Name="ExpanderIcon"
                                           Source="{StaticResource IconChevronRight}"
                                           Style="{StaticResource EditorIcon12}">
                                        <Image.RenderTransform>
                                            <RotateTransform Angle="0"/>
                                        </Image.RenderTransform>
                                        <Image.RenderTransformOrigin>0.5,0.5</Image.RenderTransformOrigin>
                                    </Image>
                                </ToggleButton>
                                <ContentPresenter x:Name="PART_Header"
                                                  Grid.Column="1"
                                                  ContentSource="Header"
                                                  HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                  VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                            </Grid>
                        </Border>
                        <ItemsPresenter x:Name="ItemsHost" Margin="18,4,0,0"/>
                    </StackPanel>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsExpanded" Value="False">
                            <Setter TargetName="ItemsHost" Property="Visibility" Value="Collapsed"/>
                        </Trigger>
                        <Trigger Property="IsExpanded" Value="True">
                            <Setter TargetName="ExpanderIcon" Property="RenderTransform">
                                <Setter.Value>
                                    <RotateTransform Angle="90"/>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="ItemChrome" Property="Background" Value="{DynamicResource HoverBrush}"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="ItemChrome" Property="Background" Value="{DynamicResource EditorTabActiveBrush}"/>
                            <Setter TargetName="ItemChrome" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                        </Trigger>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="ItemChrome" Property="BorderBrush" Value="{DynamicResource FocusRingBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="EditorTabControl" TargetType="TabControl">
        <Setter Property="Background" Value="{DynamicResource ToolbarBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="4,2,4,0"/>
    </Style>

    <Style x:Key="EditorDocumentTabItem" TargetType="TabItem">
        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Margin" Value="0,0,4,0"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TabItem">
                    <Border x:Name="Root"
                            Background="{TemplateBinding Background}"
                            BorderBrush="Transparent"
                            BorderThickness="1"
                            CornerRadius="7,7,0,0"
                            Padding="8,4">
                        <Grid>
                            <Border x:Name="ActiveIndicator"
                                    Height="2"
                                    Background="{DynamicResource AccentBrush}"
                                    VerticalAlignment="Top"
                                Margin="0,-4,0,0"
                                    Opacity="0"/>
                            <ContentPresenter ContentSource="Header"/>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="{DynamicResource SurfaceBrush}"/>
                            <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                            <Setter TargetName="ActiveIndicator" Property="Opacity" Value="1"/>
                            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="{DynamicResource HoverBrush}"/>
                        </Trigger>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource FocusRingBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="EditorTabCloseButton" TargetType="Button" BasedOn="{StaticResource EditorGlyphButton}">
        <Setter Property="Width" Value="20"/>
        <Setter Property="Height" Value="20"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="Opacity" Value="0.78"/>
    </Style>

    <Style x:Key="EditorDiagnosticsList" TargetType="ListBox" BasedOn="{StaticResource Win11ListBox}">
        <Setter Property="Padding" Value="0"/>
    </Style>

    <Style x:Key="EditorDiagnosticsListItem" TargetType="ListBoxItem">
        <Setter Property="Padding" Value="8,6"/>
        <Setter Property="Margin" Value="0,0,0,6"/>
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListBoxItem">
                    <Border x:Name="ItemChrome"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="10"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="ItemChrome" Property="Background" Value="{DynamicResource HoverBrush}"/>
                            <Setter TargetName="ItemChrome" Property="BorderBrush" Value="{DynamicResource EditorSubtleBorderBrush}"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="ItemChrome" Property="Background" Value="{DynamicResource EditorTabActiveBrush}"/>
                            <Setter TargetName="ItemChrome" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                        </Trigger>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="ItemChrome" Property="BorderBrush" Value="{DynamicResource FocusRingBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="EditorTerminalList" TargetType="ListView">
        <Setter Property="Background" Value="{DynamicResource EditorTerminalSurfaceBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
        <Setter Property="FontSize" Value="12"/>
    </Style>

    <Style x:Key="EditorTerminalToolbarGroup" TargetType="Border">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="CornerRadius" Value="0"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="Margin" Value="12,0,0,0"/>
    </Style>

    <Style x:Key="EditorTerminalListItem" TargetType="ListViewItem">
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        <Setter Property="Padding" Value="8,4"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Style.Triggers>
            <DataTrigger Binding="{Binding IsSessionHeader}" Value="True">
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Background" Value="{DynamicResource EditorTabActiveBrush}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource EditorSubtleBorderBrush}"/>
            </DataTrigger>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource HoverBrush}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource EditorSubtleBorderBrush}"/>
            </Trigger>
            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                <Setter Property="BorderBrush" Value="{DynamicResource FocusRingBrush}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="EditorGridViewHeader" TargetType="GridViewColumnHeader">
        <Setter Property="Background" Value="{DynamicResource ToolbarBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="0,0,1,1"/>
        <Setter Property="Padding" Value="8,6"/>
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="HorizontalContentAlignment" Value="Left"/>
    </Style>

    <Style x:Key="EditorStatusBarText" TargetType="TextBlock" BasedOn="{StaticResource Win11TextSecondary}">
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <Style x:Key="EditorEmptyStateBorder" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource EditorSubtleBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="Padding" Value="14,12"/>
        <Setter Property="Margin" Value="10"/>
    </Style>

    <Style x:Key="EditorGridSplitter" TargetType="GridSplitter">
        <Setter Property="Background" Value="{DynamicResource EditorSubtleBorderBrush}"/>
        <Setter Property="Opacity" Value="0.72"/>
        <Setter Property="ShowsPreview" Value="False"/>
        <Setter Property="Cursor" Value="SizeWE"/>
        <Style.Triggers>
            <Trigger Property="ResizeDirection" Value="Rows">
                <Setter Property="Cursor" Value="SizeNS"/>
            </Trigger>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                <Setter Property="Opacity" Value="1"/>
            </Trigger>
            <Trigger Property="IsKeyboardFocused" Value="True">
                <Setter Property="Background" Value="{DynamicResource FocusRingBrush}"/>
                <Setter Property="Opacity" Value="1"/>
            </Trigger>
        </Style.Triggers>
    </Style>
</ResourceDictionary>
