<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <sys:Double x:Key="EditorShellPadding">16</sys:Double>
    <sys:Double x:Key="EditorPanelGap">12</sys:Double>
    <sys:Double x:Key="EditorSectionGap">10</sys:Double>
    <sys:Double x:Key="EditorSidebarWidth">280</sys:Double>
    <sys:Double x:Key="EditorExplorerWidth">320</sys:Double>
    <sys:Double x:Key="EditorToolbarHeight">44</sys:Double>
    <sys:Double x:Key="EditorToolbarButtonHeight">34</sys:Double>

    <SolidColorBrush x:Key="EditorChromeBrush" Color="#140078D4"/>
    <SolidColorBrush x:Key="EditorPanelBrush" Color="{DynamicResource SurfaceColor}"/>
    <SolidColorBrush x:Key="EditorPanelAltBrush" Color="{DynamicResource SurfaceElevatedColor}"/>
    <SolidColorBrush x:Key="EditorSubtleBorderBrush" Color="{DynamicResource BorderColor}"/>
    <SolidColorBrush x:Key="EditorMutedBrush" Color="#80FFFFFF"/>
    <SolidColorBrush x:Key="EditorInfoSurfaceBrush" Color="#140078D4"/>
    <SolidColorBrush x:Key="EditorSuccessToneBrush" Color="#164CAF50"/>
    <SolidColorBrush x:Key="EditorWarningToneBrush" Color="#18FFC107"/>
    <SolidColorBrush x:Key="EditorErrorToneBrush" Color="#18CF6679"/>
    <SolidColorBrush x:Key="EditorCodeSurfaceBrush" Color="#12000000"/>
    <SolidColorBrush x:Key="EditorTerminalSurfaceBrush" Color="#0D000000"/>
    <SolidColorBrush x:Key="EditorTabActiveBrush" Color="#220078D4"/>

    <Style x:Key="EditorShellCard" TargetType="Border" BasedOn="{StaticResource Win11Card}">
        <Setter Property="Padding" Value="0"/>
        <Setter Property="Background" Value="{DynamicResource EditorPanelBrush}"/>
        <Setter Property="CornerRadius" Value="12"/>
    </Style>

    <Style x:Key="EditorSectionTitle" TargetType="TextBlock" BasedOn="{StaticResource Win11TextSubtitle}">
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>

    <Style x:Key="EditorSectionCaption" TargetType="TextBlock" BasedOn="{StaticResource Win11TextSecondary}">
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
    </Style>

    <Style x:Key="EditorHeaderTitle" TargetType="TextBlock" BasedOn="{StaticResource Win11TextTitle}">
        <Setter Property="FontSize" Value="22"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>

    <Style x:Key="EditorHeaderSubtitle" TargetType="TextBlock" BasedOn="{StaticResource Win11TextSecondary}">
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Margin" Value="0,4,0,0"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
    </Style>

    <Style x:Key="EditorToolbarButton" TargetType="Button" BasedOn="{StaticResource Win11Button}">
        <Setter Property="Height" Value="{StaticResource EditorToolbarButtonHeight}"/>
        <Setter Property="Padding" Value="12,4"/>
        <Setter Property="Margin" Value="0,0,8,0"/>
    </Style>

    <Style x:Key="EditorToolbarAccentButton" TargetType="Button" BasedOn="{StaticResource Win11AccentButton}">
        <Setter Property="Height" Value="{StaticResource EditorToolbarButtonHeight}"/>
        <Setter Property="Padding" Value="12,4"/>
        <Setter Property="Margin" Value="0,0,8,0"/>
    </Style>

    <Style x:Key="EditorMiniButton" TargetType="Button" BasedOn="{StaticResource Win11Button}">
        <Setter Property="Height" Value="28"/>
        <Setter Property="Padding" Value="10,2"/>
        <Setter Property="Margin" Value="0,0,6,0"/>
        <Setter Property="FontSize" Value="12"/>
    </Style>

    <Style x:Key="EditorGlyphButton" TargetType="Button" BasedOn="{StaticResource Win11IconButton}">
        <Setter Property="Width" Value="28"/>
        <Setter Property="Height" Value="28"/>
    </Style>

    <Style x:Key="EditorToolGroup" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource EditorPanelAltBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="Padding" Value="8"/>
        <Setter Property="Margin" Value="0,0,10,8"/>
    </Style>

    <Style x:Key="EditorBadgeBorder" TargetType="Border">
        <Setter Property="CornerRadius" Value="999"/>
        <Setter Property="Padding" Value="10,4"/>
        <Setter Property="Margin" Value="0,0,8,0"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <Style x:Key="EditorActivityBadgeBorder" TargetType="Border" BasedOn="{StaticResource EditorBadgeBorder}">
        <Setter Property="Background" Value="{DynamicResource EditorSuccessToneBrush}"/>
        <Style.Triggers>
            <DataTrigger Binding="{Binding IsRunning}" Value="True">
                <Setter Property="Background" Value="{DynamicResource EditorInfoSurfaceBrush}"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding IsDirty}" Value="True">
                <Setter Property="Background" Value="{DynamicResource EditorWarningToneBrush}"/>
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="EditorDiagnosticsBadgeBorder" TargetType="Border" BasedOn="{StaticResource EditorBadgeBorder}">
        <Setter Property="Background" Value="{DynamicResource EditorSuccessToneBrush}"/>
        <Style.Triggers>
            <DataTrigger Binding="{Binding HasErrorDiagnostics}" Value="True">
                <Setter Property="Background" Value="{DynamicResource EditorErrorToneBrush}"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding HasWarningDiagnostics}" Value="True">
                <Setter Property="Background" Value="{DynamicResource EditorWarningToneBrush}"/>
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="EditorSeverityBadgeBorder" TargetType="Border" BasedOn="{StaticResource EditorBadgeBorder}">
        <Setter Property="Background" Value="{DynamicResource EditorInfoSurfaceBrush}"/>
        <Style.Triggers>
            <DataTrigger Binding="{Binding Severity}" Value="WARN">
                <Setter Property="Background" Value="{DynamicResource EditorWarningToneBrush}"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding Severity}" Value="ERROR">
                <Setter Property="Background" Value="{DynamicResource EditorErrorToneBrush}"/>
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="EditorBadgeText" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <Style x:Key="EditorSidebarTree" TargetType="TreeView">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="KeyboardNavigation.TabNavigation" Value="Continue"/>
    </Style>

    <Style x:Key="EditorSidebarTreeItem" TargetType="TreeViewItem">
        <Setter Property="Padding" Value="0"/>
        <Setter Property="Margin" Value="0,0,0,4"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TreeViewItem">
                    <StackPanel>
                        <Border x:Name="ItemChrome"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="1"
                                CornerRadius="10"
                                Padding="6,4">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <ToggleButton x:Name="Expander"
                                              Grid.Column="0"
                                              Width="18"
                                              Height="18"
                                              Margin="0,2,6,0"
                                              Visibility="{Binding HasItems, RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource BoolToVisibility}}"
                                              IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}}"
                                              Style="{StaticResource Win11Button}"
                                              Focusable="False"
                                              Content=">"/>
                                <ContentPresenter Grid.Column="1"/>
                            </Grid>
                        </Border>
                        <ItemsPresenter x:Name="ItemsHost" Margin="18,4,0,0"/>
                    </StackPanel>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsExpanded" Value="False">
                            <Setter TargetName="ItemsHost" Property="Visibility" Value="Collapsed"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="ItemChrome" Property="Background" Value="{DynamicResource HoverBrush}"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="ItemChrome" Property="Background" Value="{DynamicResource EditorTabActiveBrush}"/>
                            <Setter TargetName="ItemChrome" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                        </Trigger>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="ItemChrome" Property="BorderBrush" Value="{DynamicResource FocusRingBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="EditorTabControl" TargetType="TabControl">
        <Setter Property="Background" Value="{DynamicResource EditorPanelAltBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="8,8,8,0"/>
    </Style>

    <Style x:Key="EditorDocumentTabItem" TargetType="TabItem">
        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Margin" Value="0,0,8,0"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TabItem">
                    <Border x:Name="Root"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="10,10,0,0"
                            Padding="10,8">
                        <ContentPresenter ContentSource="Header"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="{DynamicResource EditorTabActiveBrush}"/>
                            <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="{DynamicResource HoverBrush}"/>
                        </Trigger>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource FocusRingBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="EditorDiagnosticsList" TargetType="ListBox" BasedOn="{StaticResource Win11ListBox}">
        <Setter Property="Padding" Value="0"/>
    </Style>

    <Style x:Key="EditorTerminalList" TargetType="ListView">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
        <Setter Property="FontSize" Value="12"/>
    </Style>

    <Style x:Key="EditorStatusBarText" TargetType="TextBlock" BasedOn="{StaticResource Win11TextSecondary}">
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <Style x:Key="EditorGridSplitter" TargetType="GridSplitter">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="ShowsPreview" Value="False"/>
    </Style>
</ResourceDictionary>
