<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!-- ═══════════════════════════════════════════════════════════
         LIGHT THEME — Windows 11 Light
    ═══════════════════════════════════════════════════════════ -->

    <!-- Base colors -->
    <Color x:Key="AppBackgroundColor">#FFF3F3F3</Color>
    <Color x:Key="SurfaceColor">#FFFFFFFF</Color>
    <Color x:Key="SurfaceElevatedColor">#FFEBEBEB</Color>
    <Color x:Key="BorderColor">#FFD0D0D0</Color>
    <Color x:Key="AccentColor">#FF0078D4</Color>
    <Color x:Key="AccentHoverColor">#FF1A8FE3</Color>
    <Color x:Key="AccentPressedColor">#FF006CBE</Color>
    <Color x:Key="TextPrimaryColor">#FF1A1A1A</Color>
    <Color x:Key="TextSecondaryColor">#FF5A5A5A</Color>
    <Color x:Key="TextDisabledColor">#FFAAAAAA</Color>
    <Color x:Key="SidebarColor">#FFE8E8E8</Color>
    <Color x:Key="LogBackgroundColor">#FF1E1E1E</Color>
    <Color x:Key="LogTextColor">#FFCCCCCC</Color>
    <Color x:Key="SuccessColor">#FF2E7D32</Color>
    <Color x:Key="WarningColor">#FFE65100</Color>
    <Color x:Key="ErrorColor">#FFC62828</Color>
    <Color x:Key="SelectionColor">#FF0078D4</Color>
    <Color x:Key="HoverColor">#FFE0E0E0</Color>
    <Color x:Key="IconButtonHoverColor">#FFDADADA</Color>
    <Color x:Key="IconButtonPressedColor">#FFCCCCCC</Color>
    <Color x:Key="ToolbarColor">#FFEEEEEE</Color>

    <!-- Brushes -->
    <SolidColorBrush x:Key="AppBackgroundBrush" Color="{StaticResource AppBackgroundColor}"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SurfaceColor}"/>
    <SolidColorBrush x:Key="SurfaceElevatedBrush" Color="{StaticResource SurfaceElevatedColor}"/>
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}"/>
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}"/>
    <SolidColorBrush x:Key="AccentHoverBrush" Color="{StaticResource AccentHoverColor}"/>
    <SolidColorBrush x:Key="AccentPressedBrush" Color="{StaticResource AccentPressedColor}"/>
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimaryColor}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}"/>
    <SolidColorBrush x:Key="TextDisabledBrush" Color="{StaticResource TextDisabledColor}"/>
    <SolidColorBrush x:Key="SidebarBrush" Color="{StaticResource SidebarColor}"/>
    <SolidColorBrush x:Key="LogBackgroundBrush" Color="{StaticResource LogBackgroundColor}"/>
    <SolidColorBrush x:Key="LogTextBrush" Color="{StaticResource LogTextColor}"/>
    <SolidColorBrush x:Key="ScrollFadeOverlayBrush" Color="{StaticResource AppBackgroundColor}"/>
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}"/>
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}"/>
    <SolidColorBrush x:Key="ErrorBrush" Color="{StaticResource ErrorColor}"/>
    <SolidColorBrush x:Key="SelectionBrush" Color="{StaticResource SelectionColor}"/>
    <SolidColorBrush x:Key="HoverBrush" Color="{StaticResource HoverColor}"/>
    <SolidColorBrush x:Key="IconButtonHoverBrush" Color="{StaticResource IconButtonHoverColor}"/>
    <SolidColorBrush x:Key="IconButtonPressedBrush" Color="{StaticResource IconButtonPressedColor}"/>
    <SolidColorBrush x:Key="ToolbarBrush" Color="{StaticResource ToolbarColor}"/>
    <SolidColorBrush x:Key="OutputLineHoverBrush" Color="#22000000"/>

    <SolidColorBrush x:Key="SelectionSurfaceBrush" Color="#1A0078D4"/>
    <SolidColorBrush x:Key="SelectionBorderBrush" Color="{StaticResource AccentColor}"/>
    <SolidColorBrush x:Key="SelectionForegroundBrush" Color="{StaticResource TextPrimaryColor}"/>

    <SolidColorBrush x:Key="InfoSurfaceBrush" Color="#1A0078D4"/>
    <SolidColorBrush x:Key="SuccessSurfaceBrush" Color="#1A2E7D32"/>
    <SolidColorBrush x:Key="WarningSurfaceBrush" Color="#1AE65100"/>
    <SolidColorBrush x:Key="ErrorSurfaceBrush" Color="#1AC62828"/>

    <SolidColorBrush x:Key="FocusRingBrush" Color="{StaticResource AccentColor}"/>

    <SolidColorBrush x:Key="BrandRailBrush" Color="#FFE30613"/>
    <SolidColorBrush x:Key="BrandRailForegroundBrush" Color="#FFFFFFFF"/>
    <SolidColorBrush x:Key="BrandRailSecondaryForegroundBrush" Color="#E6FFFFFF"/>

    <!-- Theme toggle icon -->
    <sys:String x:Key="ThemeToggleIcon">🌙</sys:String>
    <sys:String x:Key="ThemeToggleTooltip">Passa al tema scuro</sys:String>

    <!-- Theme toggle DrawingImage — Light theme shows turned-ON light bulb (to switch to dark) -->
    <DrawingImage x:Key="ThemeToggleDrawingImage">
        <DrawingImage.Drawing>
            <DrawingGroup>
                <!-- Light bulb filled (on state) -->
                <GeometryDrawing Brush="{DynamicResource TextPrimaryBrush}">
                    <GeometryDrawing.Geometry>
                        <PathGeometry Figures="M12,2 C9.24,2 7,4.24 7,7 C7,8.5 7.63,9.85 8.63,10.81 L8.63,14 C8.63,14.55 9.08,15 9.63,15 L14.37,15 C14.92,15 15.37,14.55 15.37,14 L15.37,10.81 C16.37,9.85 17,8.5 17,7 C17,4.24 14.76,2 12,2 Z M10,16 L10,17 C10,17.55 10.45,18 11,18 L13,18 C13.55,18 14,17.55 14,17 L14,16 L10,16 Z M10,19 L10,20 C10,20.55 10.45,21 11,21 L13,21 C13.55,21 14,20.55 14,20 L14,19 L10,19 Z"/>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
                <!-- Light rays -->
                <GeometryDrawing Brush="{DynamicResource TextPrimaryBrush}">
                    <GeometryDrawing.Geometry>
                        <PathGeometry Figures="M12,0 L12,1.5 M12,0 L12,1.5 M4.22,4.22 L5.28,5.28 M19.78,4.22 L18.72,5.28 M1.5,12 L3,12 M21,12 L22.5,12 M4.22,19.78 L5.28,18.72 M19.78,19.78 L18.72,18.72"/>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
            </DrawingGroup>
        </DrawingImage.Drawing>
    </DrawingImage>

</ResourceDictionary>
