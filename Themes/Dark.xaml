<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!-- ═══════════════════════════════════════════════════════════
         DARK THEME — Windows 11 Dark
    ═══════════════════════════════════════════════════════════ -->

    <!-- Base colors -->
    <Color x:Key="AppBackgroundColor">#FF1C1C1C</Color>
    <Color x:Key="SurfaceColor">#FF2D2D2D</Color>
    <Color x:Key="SurfaceElevatedColor">#FF383838</Color>
    <Color x:Key="BorderColor">#FF4A4A4A</Color>
    <Color x:Key="AccentColor">#FF0078D4</Color>
    <Color x:Key="AccentHoverColor">#FF1A8FE3</Color>
    <Color x:Key="AccentPressedColor">#FF006CBE</Color>
    <Color x:Key="TextPrimaryColor">#FFFFFFFF</Color>
    <Color x:Key="TextSecondaryColor">#FFB0B0B0</Color>
    <Color x:Key="TextDisabledColor">#FF666666</Color>
    <Color x:Key="SidebarColor">#FF202020</Color>
    <Color x:Key="LogBackgroundColor">#FF141414</Color>
    <Color x:Key="LogTextColor">#FFCCCCCC</Color>
    <Color x:Key="SuccessColor">#FF4CAF50</Color>
    <Color x:Key="WarningColor">#FFFFC107</Color>
    <Color x:Key="ErrorColor">#FFCF6679</Color>
    <Color x:Key="SelectionColor">#FF0078D4</Color>
    <Color x:Key="HoverColor">#FF3A3A3A</Color>
    <Color x:Key="IconButtonHoverColor">#FF4A4A4A</Color>
    <Color x:Key="IconButtonPressedColor">#FF2F2F2F</Color>
    <Color x:Key="ToolbarColor">#FF272727</Color>

    <!-- Brushes -->
    <SolidColorBrush x:Key="AppBackgroundBrush" Color="{StaticResource AppBackgroundColor}"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SurfaceColor}"/>
    <SolidColorBrush x:Key="SurfaceElevatedBrush" Color="{StaticResource SurfaceElevatedColor}"/>
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}"/>
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}"/>
    <SolidColorBrush x:Key="AccentHoverBrush" Color="{StaticResource AccentHoverColor}"/>
    <SolidColorBrush x:Key="AccentPressedBrush" Color="{StaticResource AccentPressedColor}"/>
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimaryColor}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}"/>
    <SolidColorBrush x:Key="TextDisabledBrush" Color="{StaticResource TextDisabledColor}"/>
    <SolidColorBrush x:Key="SidebarBrush" Color="{StaticResource SidebarColor}"/>
    <SolidColorBrush x:Key="LogBackgroundBrush" Color="{StaticResource LogBackgroundColor}"/>
    <SolidColorBrush x:Key="LogTextBrush" Color="{StaticResource LogTextColor}"/>
    <SolidColorBrush x:Key="ScrollFadeOverlayBrush" Color="{StaticResource AppBackgroundColor}"/>
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}"/>
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}"/>
    <SolidColorBrush x:Key="ErrorBrush" Color="{StaticResource ErrorColor}"/>
    <SolidColorBrush x:Key="SelectionBrush" Color="{StaticResource SelectionColor}"/>
    <SolidColorBrush x:Key="HoverBrush" Color="{StaticResource HoverColor}"/>
    <SolidColorBrush x:Key="IconButtonHoverBrush" Color="{StaticResource IconButtonHoverColor}"/>
    <SolidColorBrush x:Key="IconButtonPressedBrush" Color="{StaticResource IconButtonPressedColor}"/>
    <SolidColorBrush x:Key="ToolbarBrush" Color="{StaticResource ToolbarColor}"/>
    <SolidColorBrush x:Key="OutputLineHoverBrush" Color="#22000000"/>

    <!-- Theme toggle icon -->
    <sys:String x:Key="ThemeToggleIcon">☀</sys:String>
    <sys:String x:Key="ThemeToggleTooltip">Passa al tema chiaro</sys:String>

    <!-- Theme toggle DrawingImage — Dark theme shows turned-OFF light bulb (to switch to light) -->
    <DrawingImage x:Key="ThemeToggleDrawingImage">
        <DrawingImage.Drawing>
            <DrawingGroup>
                <!-- Light bulb outline (off state) -->
                <GeometryDrawing Brush="{DynamicResource TextPrimaryBrush}">
                    <GeometryDrawing.Geometry>
                        <PathGeometry Figures="M12,2 C9.24,2 7,4.24 7,7 C7,8.5 7.63,9.85 8.63,10.81 L8.63,14 C8.63,14.55 9.08,15 9.63,15 L14.37,15 C14.92,15 15.37,14.55 15.37,14 L15.37,10.81 C16.37,9.85 17,8.5 17,7 C17,4.24 14.76,2 12,2 Z M14,10.5 L14,13 L10,13 L10,10.5 C9.17,9.9 8.63,8.97 8.63,7.94 C8.63,6.32 9.94,5 11.56,5 C13.18,5 14.5,6.32 14.5,7.94 C14.5,8.97 13.96,9.9 14,10.5 Z M10,16 L10,17 C10,17.55 10.45,18 11,18 L13,18 C13.55,18 14,17.55 14,17 L14,16 L10,16 Z M10,19 L10,20 C10,20.55 10.45,21 11,21 L13,21 C13.55,21 14,20.55 14,20 L14,19 L10,19 Z"/>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
            </DrawingGroup>
        </DrawingImage.Drawing>
    </DrawingImage>

</ResourceDictionary>
