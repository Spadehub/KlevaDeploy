<Window x:Class="KlevaDeploy.Views.CreateProcessDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:models="clr-namespace:KlevaDeploy.Models"
        xmlns:conv="clr-namespace:KlevaDeploy.Converters"
        xmlns:behaviors="clr-namespace:KlevaDeploy.Behaviors"
        mc:Ignorable="d"
        Title="{Binding Title}"
        Width="600" Height="704"
        MinWidth="500" MinHeight="604"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="NoResize"
        Background="Transparent"
        Opacity="0"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        FontFamily="Segoe UI Variable, Segoe UI, sans-serif">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <conv:IconVariantToImageSourceConverter x:Key="IconVariantToImageSourceConverter"/>
    </Window.Resources>

    <Border Background="{DynamicResource AppBackgroundBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="8"
            SnapsToDevicePixels="True">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>  <!-- Title bar -->
                <RowDefinition Height="*"/>     <!-- Content -->
                <RowDefinition Height="Auto"/>  <!-- Buttons -->
            </Grid.RowDefinitions>

            <!-- Title Bar -->
            <Border Grid.Row="0"
                    Background="{DynamicResource SurfaceElevatedBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="0,0,0,1"
                    CornerRadius="8,8,0,0"
                    Padding="20,16">
                <Grid>
                    <StackPanel Orientation="Horizontal">
                        <Image Source="{DynamicResource IconSettings}"
                               Width="20" Height="20"
                               VerticalAlignment="Center"
                               Margin="0,0,10,0"
                               RenderOptions.BitmapScalingMode="HighQuality"/>
                        <TextBlock Text="{Binding Title}"
                                   Style="{StaticResource Win11TextSubtitle}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    <Button Content="✕"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Width="32" Height="32"
                            Style="{StaticResource Win11CloseButton}"
                            Click="CloseButton_Click"
                            FontSize="16"
                            Padding="0"/>
                </Grid>
            </Border>

            <Grid Grid.Row="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Background="{DynamicResource ErrorSurfaceBrush}"
                        BorderBrush="{DynamicResource ErrorBrush}"
                        BorderThickness="1"
                        CornerRadius="{StaticResource CornerRadiusSmall}"
                        Padding="12,8"
                        Margin="20,16,20,0"
                        Panel.ZIndex="100"
                        Visibility="{Binding ValidationError, Converter={StaticResource StringToVisibilityConverter}}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Image Source="{DynamicResource IconError}"
                               Width="16" Height="16"
                               VerticalAlignment="Center"
                               Margin="0,0,8,0"
                               RenderOptions.BitmapScalingMode="HighQuality"/>
                        <TextBlock Text="{Binding ValidationError}"
                                   Grid.Column="1"
                                   Foreground="{DynamicResource ErrorBrush}"
                                   TextWrapping="Wrap"
                                   VerticalAlignment="Center"/>
                    </Grid>
                </Border>

                <ScrollViewer x:Name="ContentScrollViewer"
                              Grid.Row="1"
                              VerticalScrollBarVisibility="Auto"
                              Padding="20,16"
                              behaviors:ScrollResetBehavior.IsEnabled="True">
                    <StackPanel x:Name="ContentStackPanel">
                    <!-- Process Name -->
                    <TextBlock Text="Nome Processo *"
                               Style="{StaticResource Win11TextBody}"
                               FontWeight="SemiBold"
                               Margin="0,0,0,6"/>
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0"
                                Command="{Binding OpenIconPickerCommand}"
                                Style="{StaticResource Win11Button}"
                                Width="44"
                                Height="44"
                                Padding="0"
                                Margin="0,0,10,0"
                                ToolTip="Seleziona icona">
                            <Grid>
                                <Image Width="22"
                                       Height="22"
                                       RenderOptions.BitmapScalingMode="HighQuality"
                                       Visibility="{Binding HasCustomIcon, Converter={StaticResource BoolToVisibility}}">
                                    <Image.Source>
                                        <MultiBinding Converter="{StaticResource IconVariantToImageSourceConverter}">
                                            <Binding Path="CustomIconLightPath"/>
                                            <Binding Path="CustomIconDarkPath"/>
                                            <Binding Path="IsDarkTheme"
                                                     RelativeSource="{RelativeSource AncestorType=Window}"/>
                                        </MultiBinding>
                                    </Image.Source>
                                </Image>

                                <TextBlock Text="{Binding Icon}"
                                           FontSize="18"
                                           FontFamily="Segoe UI Emoji"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Visibility="{Binding HasCustomIcon, Converter={StaticResource InverseBoolToVisibility}}"/>
                            </Grid>
                        </Button>

                        <TextBox Grid.Column="1"
                                 Text="{Binding ProcessName, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource Win11TextBox}"/>
                    </Grid>

                    <!-- Description -->
                    <TextBlock Text="Descrizione"
                               Style="{StaticResource Win11TextBody}"
                               FontWeight="SemiBold"
                               Margin="0,0,0,6"/>
                    <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource Win11TextBox}"
                             Margin="0,0,0,16"/>

                    <!-- Process Type -->
                    <TextBlock Text="Tipo di Processo *"
                               Style="{StaticResource Win11TextBody}"
                               FontWeight="SemiBold"
                               Margin="0,0,0,6"/>
                    <ComboBox ItemsSource="{Binding AvailableProcessKinds}"
                              SelectedItem="{Binding SelectedProcessKind}"
                              Style="{StaticResource Win11ComboBox}"
                              Margin="0,0,0,16">
                        <ComboBox.ItemTemplate>
                            <DataTemplate DataType="models:ProcessKind">
                                <TextBlock>
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="{Binding}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding}" Value="{x:Static models:ProcessKind.Installer}">
                                                    <Setter Property="Text" Value="Installer (.exe, .msi, .zip)"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding}" Value="{x:Static models:ProcessKind.PowerShellScript}">
                                                    <Setter Property="Text" Value="PowerShell Script"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding}" Value="{x:Static models:ProcessKind.BatchScript}">
                                                    <Setter Property="Text" Value="Batch/CMD Script"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <!-- Installer Mode Fields -->
                    <StackPanel Visibility="{Binding IsInstallerMode, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="Sorgente Installer *"
                                   Style="{StaticResource Win11TextBody}"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,6"/>

                        <Border Background="{DynamicResource SurfaceBrush}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="12"
                                Padding="3"
                                Height="48"
                                Width="480"
                                Margin="0,0,0,8">
                            <Grid Width="474"
                                  Height="42"
                                  ClipToBounds="True">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Border Background="{DynamicResource AccentBrush}"
                                        BorderBrush="{DynamicResource AccentBrush}"
                                        BorderThickness="1"
                                        Opacity="0.20"
                                        CornerRadius="10"
                                        IsHitTestVisible="False"
                                        Panel.ZIndex="0">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Grid.Column" Value="0"/>
                                            <Setter Property="CornerRadius" Value="10,0,0,10"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding InstallerSourceMode}" Value="{x:Static models:InstallerSourceMode.StaticWeb}">
                                                    <Setter Property="Grid.Column" Value="1"/>
                                                    <Setter Property="CornerRadius" Value="0"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding InstallerSourceMode}" Value="{x:Static models:InstallerSourceMode.DynamicWeb}">
                                                    <Setter Property="Grid.Column" Value="2"/>
                                                    <Setter Property="CornerRadius" Value="0,10,10,0"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                </Border>

                                <RadioButton Grid.Column="0"
                                             GroupName="InstallerSourceMode"
                                             IsChecked="{Binding IsInstallerSourceLocal, Mode=TwoWay}"
                                             Cursor="Hand"
                                             Style="{StaticResource Win11SegmentRadioButton}"
                                             Panel.ZIndex="1">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <Viewbox Width="18" Height="18" Margin="0,0,8,0">
                                            <Path Data="M10 4H4C2.9 4 2 4.9 2 6V18C2 19.1 2.9 20 4 20H16C17.1 20 18 19.1 18 18V12H16V18H4V6H10V4ZM20 4H14V6H20V4ZM20 8H14V10H20V8ZM20 12H14V14H20V12ZM20 16H14V18H20V16Z"
                                                  Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"/>
                                        </Viewbox>
                                        <TextBlock Text="Statico (Locale)"
                                                   FontSize="13"
                                                   FontWeight="SemiBold"
                                                   VerticalAlignment="Center"
                                                   Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"/>
                                    </StackPanel>
                                </RadioButton>

                                <RadioButton Grid.Column="1"
                                             GroupName="InstallerSourceMode"
                                             IsChecked="{Binding IsInstallerSourceStaticWeb, Mode=TwoWay}"
                                             Cursor="Hand"
                                             Style="{StaticResource Win11SegmentRadioButton}"
                                             Panel.ZIndex="1">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <Viewbox Width="18" Height="18" Margin="0,0,8,0">
                                            <Path Data="M5 20H19V18H5V20ZM12 2C8.13 2 5 5.13 5 9C5 11.38 6.19 13.47 8 14.74V17C8 17.55 8.45 18 9 18H15C15.55 18 16 17.55 16 17V14.74C17.81 13.47 19 11.38 19 9C19 5.13 15.87 2 12 2ZM14 14H10V13.5C10 12.95 9.55 12.5 9 12.5C7.62 11.66 6.75 10.23 6.75 9C6.75 6.66 8.66 4.75 11 4.75H13C15.34 4.75 17.25 6.66 17.25 9C17.25 10.23 16.38 11.66 15 12.5C14.45 12.5 14 12.95 14 13.5V14Z"
                                                  Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"/>
                                        </Viewbox>
                                        <TextBlock Text="Statico (Web)"
                                                   FontSize="13"
                                                   FontWeight="SemiBold"
                                                   VerticalAlignment="Center"
                                                   Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"/>
                                    </StackPanel>
                                </RadioButton>

                                <RadioButton Grid.Column="2"
                                             GroupName="InstallerSourceMode"
                                             IsChecked="{Binding IsInstallerSourceDynamicWeb, Mode=TwoWay}"
                                             Cursor="Hand"
                                             Style="{StaticResource Win11SegmentRadioButton}"
                                             Panel.ZIndex="1">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <Viewbox Width="18" Height="18" Margin="0,0,8,0">
                                            <Path Data="M10 4H2V6H10V4ZM10 8H2V10H10V8ZM2 12H10V14H2V12ZM12 20H22V18H12V20ZM16 4H22V10H16V4ZM18 6V8H20V6H18ZM12 12H22V14H12V12ZM12 16H22V18H12V16Z"
                                                  Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"/>
                                        </Viewbox>
                                        <TextBlock Text="Dinamico (Web)"
                                                   FontSize="13"
                                                   FontWeight="SemiBold"
                                                   VerticalAlignment="Center"
                                                   Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"/>
                                    </StackPanel>
                                </RadioButton>
                            </Grid>
                        </Border>

                        <TextBlock FontSize="12"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,16">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource Win11TextSecondary}">
                                    <Setter Property="Text" Value="Scegli come ottenere l'installer."/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding InstallerSourceMode}" Value="{x:Static models:InstallerSourceMode.StaticLocal}">
                                            <Setter Property="Text" Value="Usa un file installer già presente sul PC (nessun download)."/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding InstallerSourceMode}" Value="{x:Static models:InstallerSourceMode.StaticWeb}">
                                            <Setter Property="Text" Value="Scarica un file .exe da un link diretto. Se il file è già stato scaricato, verrà usato come fallback finché non premi “Riscarica installer”."/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding InstallerSourceMode}" Value="{x:Static models:InstallerSourceMode.DynamicWeb}">
                                            <Setter Property="Text" Value="Inserisci una cartella web (es. Passepartout). Puoi scegliere la versione e poi selezionare quale .exe scaricare."/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <StackPanel Visibility="{Binding IsInstallerSourceLocal, Converter={StaticResource BoolToVisibility}}">
                            <TextBlock Text="Percorso File Installer *"
                                       Style="{StaticResource Win11TextBody}"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,6"/>
                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0"
                                         Text="{Binding FilePath, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource Win11TextBox}"
                                         Margin="0,0,8,0"/>
                                <Button Grid.Column="1"
                                        Content="Sfoglia..."
                                        Command="{Binding BrowseFileCommand}"
                                        Style="{StaticResource Win11Button}"
                                        Padding="12,6"/>
                            </Grid>
                        </StackPanel>

                        <StackPanel Visibility="{Binding IsInstallerSourceStaticWeb, Converter={StaticResource BoolToVisibility}}">
                            <TextBlock Text="Link Diretto Installer (Web) *"
                                       Style="{StaticResource Win11TextBody}"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,6"/>
                            <TextBox Text="{Binding DownloadUrl, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource Win11TextBox}"
                                     Margin="0,0,0,16"/>
                        </StackPanel>

                        <StackPanel Visibility="{Binding IsInstallerSourceDynamicWeb, Converter={StaticResource BoolToVisibility}}">
                            <TextBlock Text="Cartella Download (Web) *"
                                       Style="{StaticResource Win11TextBody}"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,6"/>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0"
                                         Text="{Binding DownloadBaseFolderUrl, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource Win11TextBox}"
                                         Margin="0,0,8,0"/>
                                <Button Grid.Column="1"
                                        Content="Su"
                                        Command="{Binding NavigateUpRemoteFolderCommand}"
                                        Style="{StaticResource Win11Button}"
                                        Padding="12,6"
                                        Visibility="{Binding IsRemoteFolderNavigationMode, Converter={StaticResource BoolToVisibility}}"/>
                            </Grid>

                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="3*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0"
                                            Visibility="{Binding HasRemoteInstallerVersions, Converter={StaticResource BoolToVisibility}}">
                                    <TextBlock Text="{Binding RemoteFolderPickerLabel}"
                                               Style="{StaticResource Win11TextBody}"
                                               FontWeight="SemiBold"
                                               Margin="0,0,0,6"/>
                                    <ComboBox ItemsSource="{Binding RemoteInstallerVersions}"
                                              SelectedItem="{Binding DownloadSelectedVersion, Mode=TwoWay}"
                                              Style="{StaticResource Win11ComboBox}"
                                              IsEnabled="{Binding IsInstallerAutoUpdateEnabled, Converter={StaticResource InverseBoolConverter}}"
                                              MaxDropDownHeight="260"/>

                                    <Grid Margin="0,8,0,0"
                                          Visibility="{Binding IsRemoteVersionPickerMode, Converter={StaticResource BoolToVisibility}}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Aggiornamento Automatico Installer"
                                                   Style="{StaticResource Win11TextSecondary}"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,10,0"/>
                                        <CheckBox Grid.Column="1"
                                                  IsChecked="{Binding IsInstallerAutoUpdateEnabled, Mode=TwoWay}"
                                                  Style="{StaticResource Win11ToggleSwitch}"/>
                                    </Grid>

                                    <Button Content="Apri"
                                            Command="{Binding OpenSelectedRemoteFolderCommand}"
                                            Style="{StaticResource Win11Button}"
                                            Height="36"
                                            Margin="0,8,0,0"
                                            Visibility="{Binding IsRemoteFolderNavigationMode, Converter={StaticResource BoolToVisibility}}"/>
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Installer da Scaricare"
                                               Style="{StaticResource Win11TextBody}"
                                               FontWeight="SemiBold"
                                               Margin="0,0,0,6"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <ComboBox Grid.Column="0"
                                                  ItemsSource="{Binding RemoteInstallerFiles}"
                                                  SelectedItem="{Binding DownloadSelectedFileName, Mode=TwoWay}"
                                                  Style="{StaticResource Win11ComboBox}"
                                                  Margin="0,0,8,0"/>
                                        <Button Grid.Column="1"
                                                Content="Aggiorna elenco"
                                                Command="{Binding RefreshRemoteInstallerFilesCommand}"
                                                Style="{StaticResource Win11Button}"
                                                Padding="12,6"/>
                                    </Grid>
                                </StackPanel>
                            </Grid>
                        </StackPanel>

                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="Modalità Installer EXE"
                                       Style="{StaticResource Win11TextBody}"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"/>
                            <Button Grid.Column="1"
                                    Content="Auto-genera"
                                    Command="{Binding AutoGenerateInstallerFlowCommand}"
                                    Style="{StaticResource Win11Button}"
                                    Height="32"
                                    Padding="12,4"
                                    Margin="10,0,0,0"/>
                        </Grid>
                        <ComboBox ItemsSource="{Binding AvailableExeInstallerModes}"
                                  SelectedItem="{Binding SelectedExeInstallerMode, Mode=TwoWay}"
                                  Style="{StaticResource Win11ComboBox}"
                                  behaviors:ComboBoxMouseWheelToScrollViewerBehavior.IsEnabled="True"
                                  Margin="0,0,0,6">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel>
                                        <TextBlock x:Name="ModeTitle"
                                                   Style="{StaticResource Win11TextBody}"
                                                   FontWeight="SemiBold"
                                                   Text="Manuale"/>
                                        <TextBlock x:Name="ModeSubtitle"
                                                   Style="{StaticResource Win11TextSecondary}"
                                                   TextWrapping="Wrap"
                                                   Margin="0,2,0,0"
                                                   Text="Esegue l’EXE così com’è. Se non hai parametri silent può aprire finestre."/>
                                    </StackPanel>

                                    <DataTemplate.Triggers>
                                        <DataTrigger Binding="{Binding}" Value="{x:Static models:ExeInstallerMode.Manual}">
                                            <Setter TargetName="ModeTitle" Property="Text" Value="Manuale"/>
                                            <Setter TargetName="ModeSubtitle" Property="Text" Value="Per EXE standalone lo esegue cosi com'e. Se il processo ha sottoprocessi, l'EXE padre viene solo scaricato/cache-ato e i sottoprocessi fanno il resto."/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding}" Value="{x:Static models:ExeInstallerMode.Auto}">
                                            <Setter TargetName="ModeTitle" Property="Text" Value="Auto ({AUTO})"/>
                                            <Setter TargetName="ModeSubtitle" Property="Text" Value="Decide automaticamente: se trova MSI dentro → AutoExtract; altrimenti prova silent; se non riconosce → manuale."/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding}" Value="{x:Static models:ExeInstallerMode.Silent}">
                                            <Setter TargetName="ModeTitle" Property="Text" Value="Silent ({SILENT})"/>
                                            <Setter TargetName="ModeSubtitle" Property="Text" Value="Inserisce {SILENT}: tenta di riconoscere l’installer (Inno/NSIS/…) e aggiunge i flag quiet."/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding}" Value="{x:Static models:ExeInstallerMode.AutoExtractMainMsi}">
                                            <Setter TargetName="ModeTitle" Property="Text" Value="AutoExtract (MSI principale)"/>
                                            <Setter TargetName="ModeSubtitle" Property="Text" Value="Estrae l’EXE e installa l’MSI principale (e prerequisiti), in silent."/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding}" Value="{x:Static models:ExeInstallerMode.AutoExtractAllMsis}">
                                            <Setter TargetName="ModeTitle" Property="Text" Value="AutoExtract (tutti gli MSI)"/>
                                            <Setter TargetName="ModeSubtitle" Property="Text" Value="Estrae e installa tutti gli MSI trovati. Utile per bundle che contengono più componenti."/>
                                        </DataTrigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                        <TextBlock Text="Questa opzione modifica automaticamente gli argomenti inserendo/rimuovendo i marker {AUTO}, {SILENT} o {AUTOEXTRACT_*} (solo .exe). I file .msi vengono già eseguiti senza UI."
                                   Style="{StaticResource Win11TextSecondary}"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,12"/>

                        <TextBlock Text="Argomenti Riga di Comando"
                                   Style="{StaticResource Win11TextBody}"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,6"/>
                        <TextBox Text="{Binding Arguments, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource Win11TextBox}"
                                 Margin="0,0,0,16"/>

                        <TextBlock Text="Cartella Installazione (opzionale)"
                                   Style="{StaticResource Win11TextBody}"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,6"/>
                        <TextBox Text="{Binding InstallDirectory, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource Win11TextBox}"
                                 Margin="0,0,0,16"/>
                    </StackPanel>

                    <!-- Script Mode Fields -->
                    <StackPanel Visibility="{Binding IsScriptMode, Converter={StaticResource BoolToVis}}">
                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Comando Inline"
                                       Style="{StaticResource Win11TextBody}"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"/>
                            <Button Grid.Column="1"
                                    Content="Open Editor"
                                    Click="OpenScriptEditor_Click"
                                    Style="{StaticResource Win11Button}"
                                    Padding="12,6"/>
                        </Grid>
                        <TextBox Text="{Binding InlineScriptCommand, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource Win11TextBox}"
                                 Margin="0,0,0,8"
                                 Visibility="{Binding HasMultiLineScriptContent, Converter={StaticResource InverseBoolToVisibility}}"/>
                        <Border Style="{StaticResource Win11Card}"
                                Padding="10"
                                Margin="0,0,0,8"
                                Visibility="{Binding HasMultiLineScriptContent, Converter={StaticResource BoolToVis}}">
                            <StackPanel>
                                <TextBlock Text="Multi-line script preview"
                                           Style="{StaticResource Win11TextBody}"
                                           FontWeight="SemiBold"
                                           Margin="0,0,0,6"/>
                                <TextBox Text="{Binding ScriptPreview, Mode=OneWay}"
                                         Style="{StaticResource Win11TextBox}"
                                         IsReadOnly="True"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         Height="120"
                                         VerticalScrollBarVisibility="Auto"
                                         FontFamily="Cascadia Code, Consolas, monospace"
                                         FontSize="11"/>
                            </StackPanel>
                        </Border>
                        <TextBlock Text="{Binding ScriptEditorHint}"
                                   Style="{StaticResource Win11TextSecondary}"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,8"/>
                        <TextBlock Text="— OPPURE —"
                                   Style="{StaticResource Win11TextSecondary}"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,8"/>

                        <!-- Script File Path -->
                        <TextBlock Text="Percorso File Script"
                                   Style="{StaticResource Win11TextBody}"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,6"/>
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0"
                                     Text="{Binding FilePath, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource Win11TextBox}"
                                     Margin="0,0,8,0"/>
                            <Button Grid.Column="1"
                                    Content="Sfoglia..."
                                    Command="{Binding BrowseFileCommand}"
                                    Style="{StaticResource Win11Button}"
                                    Padding="12,6"/>
                        </Grid>
                    </StackPanel>

                    <Border Style="{StaticResource Win11Card}"
                            Padding="0"
                            Margin="0,0,0,16"
                            Visibility="{Binding IsSubProcessEditor, Converter={StaticResource InverseBoolToVisibility}}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Border Background="{DynamicResource SurfaceElevatedBrush}"
                                    Padding="10,8"
                                    CornerRadius="8,8,0,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Sottoprocessi"
                                               FontWeight="SemiBold"
                                               FontSize="14"
                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                               VerticalAlignment="Center"/>
                                    <Button Grid.Column="1"
                                            Content="Crea sottoprocesso..."
                                            Click="CreateSubProcess_Click"
                                            Style="{StaticResource Win11Button}"
                                            Padding="12,6"/>
                                </Grid>
                            </Border>

                            <Border Grid.Row="1"
                                    Padding="12">
                                <StackPanel>
                                    <TextBlock Text="Nessun sottoprocesso."
                                               Style="{StaticResource Win11TextSecondary}"
                                               Margin="0,0,0,8"
                                               Visibility="{Binding HasSubProcesses, Converter={StaticResource InverseBoolToVisibility}}"/>

                                    <ScrollViewer MaxHeight="260"
                                                  VerticalScrollBarVisibility="Auto"
                                                  Visibility="{Binding HasSubProcesses, Converter={StaticResource BoolToVisibility}}">
                                        <ItemsControl ItemsSource="{Binding SubProcesses}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="{DynamicResource SurfaceBrush}"
                                                            BorderBrush="{DynamicResource BorderBrush}"
                                                            BorderThickness="1"
                                                            CornerRadius="{StaticResource CornerRadiusSmall}"
                                                            Padding="10"
                                                            Margin="0,0,0,8">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            <StackPanel>
                                                                <TextBlock Text="{Binding Name}"
                                                                           FontWeight="SemiBold"
                                                                           TextTrimming="CharacterEllipsis"
                                                                           Margin="0,0,0,4"/>
                                                                <TextBlock Text="{Binding KindLabel}"
                                                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                                                           TextTrimming="CharacterEllipsis"
                                                                           Margin="0,0,0,2"/>
                                                                <TextBlock Text="{Binding RelativePath}"
                                                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                                                           TextTrimming="CharacterEllipsis"
                                                                           Margin="0,0,0,2"/>
                                                                <TextBlock Text="{Binding Arguments}"
                                                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                                                           TextTrimming="CharacterEllipsis"/>
                                                            </StackPanel>
                                                            <Button Grid.Column="1"
                                                                    Content="⋯"
                                                                    Style="{StaticResource Win11Button}"
                                                                    Padding="10,4"
                                                                    Margin="8,0,0,0"
                                                                    VerticalAlignment="Top"
                                                                    Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Window}}">
                                                                <Button.ContextMenu>
                                                                    <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}"
                                                                                 Style="{StaticResource Win11ContextMenu}">
                                                                        <MenuItem Header="Modifica..."
                                                                                  Click="EditSubProcess_Click"/>
                                                                        <Separator/>
                                                                        <MenuItem Header="Sposta su"
                                                                                  Command="{Binding PlacementTarget.Tag.MoveSubProcessUpCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                                  CommandParameter="{Binding}"/>
                                                                        <MenuItem Header="Sposta giù"
                                                                                  Command="{Binding PlacementTarget.Tag.MoveSubProcessDownCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                                  CommandParameter="{Binding}"/>
                                                                        <Separator/>
                                                                        <MenuItem Header="Elimina"
                                                                                  Command="{Binding PlacementTarget.Tag.RemoveSubProcessCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                                  CommandParameter="{Binding}"/>
                                                                    </ContextMenu>
                                                                </Button.ContextMenu>
                                                            </Button>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>

                    <!-- Checkboxes -->
                    <StackPanel Margin="0,0,0,16">
                        <CheckBox IsChecked="{Binding RunAsAdmin}"
                                  Style="{StaticResource Win11CheckBox}"
                                  Margin="0,0,0,8">
                            <TextBlock Text="Esegui come Amministratore"
                                       Style="{StaticResource Win11TextBody}"/>
                        </CheckBox>

                        <CheckBox IsChecked="{Binding RequiresInternet}"
                                  Style="{StaticResource Win11CheckBox}">
                            <TextBlock Text="Richiede Connessione Internet"
                                       Style="{StaticResource Win11TextBody}"/>
                        </CheckBox>

                        <CheckBox IsChecked="{Binding PortalAccessEnabled}"
                                  Style="{StaticResource Win11CheckBox}"
                                  Margin="0,8,0,0">
                            <TextBlock Text="Portal login"
                                       Style="{StaticResource Win11TextBody}"/>
                        </CheckBox>

                        <StackPanel Margin="24,8,0,0"
                                    Visibility="{Binding IsPortalPickerVisible, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="Portal"
                                       Style="{StaticResource Win11TextBody}"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,6"/>
                            <ComboBox ItemsSource="{Binding AvailablePortals}"
                                      SelectedValue="{Binding SelectedPortalId}"
                                      SelectedValuePath="Id"
                                      DisplayMemberPath="Name"
                                      Style="{StaticResource Win11ComboBox}"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Warning for Edit Mode -->
                    <Border Background="{DynamicResource InfoSurfaceBrush}"
                            BorderBrush="{DynamicResource AccentBrush}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource CornerRadiusSmall}"
                            Padding="12,8"
                            Margin="0,0,0,16"
                            Visibility="{Binding IsEditMode, Converter={StaticResource BoolToVis}}">
                        <StackPanel Orientation="Horizontal">
                            <Image Source="{DynamicResource IconWarning}"
                                   Width="16" Height="16"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0"
                                   RenderOptions.BitmapScalingMode="HighQuality"/>
                            <TextBlock Text="Attenzione: la modifica di questo processo influirà su tutti i preset che lo utilizzano."
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       FontSize="11"
                                       TextWrapping="Wrap"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <!-- Action Buttons -->
            <Border Grid.Row="2"
                    Background="{DynamicResource SurfaceElevatedBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="0,1,0,0"
                    CornerRadius="0,0,8,8"
                    Padding="20,16">
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right">
                    <Button Content="Annulla"
                            Command="{Binding CancelCommand}"
                            Style="{StaticResource Win11Button}"
                            Padding="20,8"
                            Margin="0,0,8,0"
                            MinWidth="100"/>
                    <Button Content="Crea Processo"
                            Command="{Binding SaveCommand}"
                            Style="{StaticResource Win11AccentButton}"
                            Padding="20,8"
                            MinWidth="140"/>
                </StackPanel>
            </Border>

            <Grid Grid.RowSpan="3"
                  Panel.ZIndex="200"
                  Background="#80000000"
                  Visibility="{Binding IsIconPickerOpen, Converter={StaticResource BoolToVisibility}}">
                <Border Style="{StaticResource Win11Card}"
                        Padding="16"
                        Width="620"
                        MaxHeight="680"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Center">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="Seleziona icona"
                                       Style="{StaticResource Win11TextSubtitle}"
                                       FontWeight="SemiBold"/>

                            <Button Grid.Column="1"
                                    Command="{Binding CloseIconPickerCommand}"
                                    Style="{StaticResource Win11CloseButton}"
                                    Width="32"
                                    Height="32"
                                    Padding="0">
                                <TextBlock Text="✕" FontSize="14"/>
                            </Button>
                        </Grid>

                        <ScrollViewer Grid.Row="1"
                                      VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <TextBlock Text="Emoji"
                                           Style="{StaticResource Win11TextBody}"
                                           FontWeight="SemiBold"
                                           Margin="0,0,0,8"/>

                                <ItemsControl ItemsSource="{Binding AvailableEmojiIcons}"
                                              Margin="0,0,0,16">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button Command="{Binding DataContext.SelectEmojiIconCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding}"
                                                    Style="{StaticResource Win11Button}"
                                                    Width="44"
                                                    Height="44"
                                                    Padding="0"
                                                    Margin="0,0,8,8">
                                                <TextBlock Text="{Binding}"
                                                           FontSize="20"
                                                           FontFamily="Segoe UI Emoji"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <TextBlock Text="Icone caricate"
                                           Style="{StaticResource Win11TextBody}"
                                           FontWeight="SemiBold"
                                           Margin="0,0,0,8"/>

                                <Border Background="{DynamicResource SurfaceElevatedBrush}"
                                        BorderBrush="{DynamicResource BorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="{StaticResource CornerRadiusSmall}"
                                        Padding="12"
                                        Margin="0,0,0,12">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <Border Width="40"
                                                Height="40"
                                                CornerRadius="{StaticResource CornerRadiusSmall}"
                                                Background="{DynamicResource SurfaceBrush}"
                                                BorderBrush="{DynamicResource BorderBrush}"
                                                BorderThickness="1"
                                                VerticalAlignment="Center"
                                                Margin="0,0,12,0">
                                            <Grid>
                                                <Image Width="22"
                                                       Height="22"
                                                       RenderOptions.BitmapScalingMode="HighQuality"
                                                       Visibility="{Binding HasCustomIcon, Converter={StaticResource BoolToVisibility}}">
                                                    <Image.Source>
                                                        <MultiBinding Converter="{StaticResource IconVariantToImageSourceConverter}">
                                                            <Binding Path="CustomIconLightPath"/>
                                                            <Binding Path="CustomIconDarkPath"/>
                                                            <Binding Path="IsDarkTheme"
                                                                     RelativeSource="{RelativeSource AncestorType=Window}"/>
                                                        </MultiBinding>
                                                    </Image.Source>
                                                </Image>

                                                <TextBlock Text="{Binding Icon}"
                                                           FontSize="18"
                                                           FontFamily="Segoe UI Emoji"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           Visibility="{Binding HasCustomIcon, Converter={StaticResource InverseBoolToVisibility}}"/>
                                            </Grid>
                                        </Border>

                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <CheckBox Content="Scegli icona diversa per tema"
                                                      IsChecked="{Binding UseSeparateThemeIcons}"
                                                      Style="{StaticResource Win11ToggleSwitch}"/>
                                            <TextBlock Text="Se attivo, puoi scegliere un’icona per tema chiaro e una per tema scuro."
                                                       Style="{StaticResource Win11TextSecondary}"
                                                       FontSize="11"
                                                       Margin="0,4,0,0"/>
                                        </StackPanel>

                                        <Button Grid.Column="2"
                                                Content="Importa"
                                                Command="{Binding ImportLibraryIconCommand}"
                                                Style="{StaticResource Win11Button}"
                                                Height="36"
                                                MinWidth="120"
                                                VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>

                                <StackPanel Orientation="Horizontal"
                                            Margin="0,0,0,12"
                                            Visibility="{Binding UseSeparateThemeIcons, Converter={StaticResource BoolToVisibility}}">
                                    <Button Content="Chiaro"
                                            Command="{Binding SetIconPickerTargetLightCommand}"
                                            Height="32"
                                            MinWidth="120">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource Win11Button}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsIconPickerTargetDark}" Value="False">
                                                        <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                                                        <Setter Property="Foreground" Value="White"/>
                                                        <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                    <Button Content="Scuro"
                                            Command="{Binding SetIconPickerTargetDarkCommand}"
                                            Height="32"
                                            MinWidth="120"
                                            Margin="8,0,0,0">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource Win11Button}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsIconPickerTargetDark}" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                                                        <Setter Property="Foreground" Value="White"/>
                                                        <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </StackPanel>

                                <ItemsControl ItemsSource="{Binding LibraryIcons}"
                                              Margin="0,0,0,16">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button Command="{Binding DataContext.SelectLibraryIconCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding}"
                                                    Style="{StaticResource Win11Button}"
                                                    Width="56"
                                                    Height="56"
                                                    Padding="0"
                                                    Margin="0,0,8,8">
                                                <Image Stretch="Uniform"
                                                       RenderOptions.BitmapScalingMode="HighQuality"
                                                       Width="28"
                                                       Height="28">
                                                    <Image.Source>
                                                        <MultiBinding Converter="{StaticResource IconVariantToImageSourceConverter}">
                                                            <Binding Path="LightPath"/>
                                                            <Binding Path="DarkPath"/>
                                                            <Binding Path="IsDarkTheme"
                                                                     RelativeSource="{RelativeSource AncestorType=Window}"/>
                                                        </MultiBinding>
                                                    </Image.Source>
                                                </Image>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Chiaro"
                                                   Style="{StaticResource Win11TextSecondary}"
                                                   Margin="0,0,0,6"/>
                                        <Border Background="{DynamicResource SurfaceElevatedBrush}"
                                                BorderBrush="{DynamicResource BorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="{StaticResource CornerRadiusSmall}"
                                                Width="96"
                                                Height="96"
                                                HorizontalAlignment="Left">
                                            <Image Stretch="Uniform"
                                                   RenderOptions.BitmapScalingMode="HighQuality">
                                                <Image.Source>
                                                    <MultiBinding Converter="{StaticResource IconVariantToImageSourceConverter}">
                                                        <Binding Path="CustomIconLightPath"/>
                                                        <Binding Path="CustomIconDarkPath"/>
                                                        <Binding Source="False"/>
                                                    </MultiBinding>
                                                </Image.Source>
                                            </Image>
                                        </Border>
                                    </StackPanel>

                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Scuro"
                                                   Style="{StaticResource Win11TextSecondary}"
                                                   Margin="0,0,0,6"/>
                                        <Border Background="{DynamicResource SurfaceElevatedBrush}"
                                                BorderBrush="{DynamicResource BorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="{StaticResource CornerRadiusSmall}"
                                                Width="96"
                                                Height="96"
                                                HorizontalAlignment="Left">
                                            <Image Stretch="Uniform"
                                                   RenderOptions.BitmapScalingMode="HighQuality">
                                                <Image.Source>
                                                    <MultiBinding Converter="{StaticResource IconVariantToImageSourceConverter}">
                                                        <Binding Path="CustomIconLightPath"/>
                                                        <Binding Path="CustomIconDarkPath"/>
                                                        <Binding Source="True"/>
                                                    </MultiBinding>
                                                </Image.Source>
                                            </Image>
                                        </Border>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </ScrollViewer>

                        <Grid Grid.Row="2" Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Button Content="Rimuovi"
                                    Command="{Binding RemoveCustomIconCommand}"
                                    Style="{StaticResource Win11Button}"
                                    Height="36"
                                    Visibility="{Binding HasCustomIcon, Converter={StaticResource BoolToVisibility}}"
                                    HorizontalAlignment="Left"/>

                            <Button Grid.Column="1"
                                    Content="Chiudi"
                                    Command="{Binding CloseIconPickerCommand}"
                                    Style="{StaticResource Win11AccentButton}"
                                    Height="36"
                                    MinWidth="120"/>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>
