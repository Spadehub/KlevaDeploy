<Window x:Class="KlevaDeploy.Views.ConfirmDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Conferma"
        Width="440" Height="240"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="False"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="{DynamicResource AppBackgroundBrush}"
        FontFamily="Segoe UI Variable, Segoe UI, sans-serif"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        SizeToContent="Height"
        MinHeight="220"
        MaxHeight="360">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="40"
                      ResizeBorderThickness="0"
                      GlassFrameThickness="0,0,0,1"
                      UseAeroCaptionButtons="False"
                      CornerRadius="12"/>
    </WindowChrome.WindowChrome>

    <Border Background="{DynamicResource AppBackgroundBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="12">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border x:Name="TitleBar"
                    Grid.Row="0"
                    Background="{DynamicResource SurfaceElevatedBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="0,0,0,1"
                    CornerRadius="12,12,0,0"
                    Padding="14,0,6,0"
                    shell:WindowChrome.IsHitTestVisibleInChrome="True">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Image Source="{DynamicResource IconWarning}"
                               Width="16" Height="16"
                               Margin="0,0,10,0"
                               VerticalAlignment="Center"
                               RenderOptions.BitmapScalingMode="HighQuality"/>
                        <TextBlock x:Name="TitleText"
                                   Style="{StaticResource Win11TextBody}"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <Button x:Name="BtnClose"
                            Grid.Column="1"
                            Content="✕"
                            Width="38"
                            Height="28"
                            Padding="0"
                            Style="{StaticResource Win11CloseButton}"
                            VerticalAlignment="Center"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True"/>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="24,18,24,24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="16"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           x:Name="BodyText"
                           TextWrapping="Wrap"
                           Style="{StaticResource Win11TextBody}"
                           Foreground="{DynamicResource TextSecondaryBrush}"/>

                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="CancelButton"
                            Content="Annulla"
                            Style="{StaticResource Win11Button}"
                            Width="90" Height="32"
                            Margin="0,0,8,0"
                            IsCancel="True"/>
                    <Button x:Name="ConfirmButton"
                            Content="Elimina"
                            Style="{StaticResource Win11DangerButton}"
                            Width="110" Height="32"
                            IsDefault="True"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
