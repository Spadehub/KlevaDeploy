<Window x:Class="KlevaDeploy.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Accesso Passepartout"
        Width="640" Height="420"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="False"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="{DynamicResource AppBackgroundBrush}"
        FontFamily="Segoe UI Variable, Segoe UI, sans-serif"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="40"
                            ResizeBorderThickness="0"
                            GlassFrameThickness="0,0,0,1"
                            UseAeroCaptionButtons="False"
                            CornerRadius="12"/>
    </shell:WindowChrome.WindowChrome>

    <Border x:Name="RootBorder"
            Background="{DynamicResource AppBackgroundBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="12"
            ClipToBounds="True">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border x:Name="TitleBar"
                    Grid.Row="0"
                    Background="{DynamicResource SurfaceElevatedBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="0,0,0,1"
                    CornerRadius="12,12,0,0"
                    Padding="14,0,6,0"
                    >
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Image Source="{DynamicResource IconLock}"
                               Width="16" Height="16"
                               Margin="0,0,10,0"
                               VerticalAlignment="Center"
                               RenderOptions.BitmapScalingMode="HighQuality"/>
                        <TextBlock Text="Accesso Passepartout"
                                   Style="{StaticResource Win11TextBody}"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <Button x:Name="BtnClose"
                            Grid.Column="1"
                            Content="✕"
                            Width="38"
                            Height="28"
                            Padding="0"
                            Style="{StaticResource Win11CloseButton}"
                            VerticalAlignment="Center"
                            Command="{Binding CancelCommand}"
                            IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}, FallbackValue=True}"/>
                </Grid>
            </Border>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Background="{DynamicResource BrandRailBrush}"
                        CornerRadius="0,0,0,12"
                        Padding="22,18">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Orientation="Horizontal">
                            <Border Background="{DynamicResource BrandRailForegroundBrush}"
                                    CornerRadius="8"
                                    Width="44" Height="44"
                                    VerticalAlignment="Center"
                                    Margin="0,0,12,0">
                                <TextBlock Text="P"
                                           FontSize="24"
                                           FontWeight="Bold"
                                           Foreground="{DynamicResource BrandRailBrush}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Passepartout"
                                           FontSize="18"
                                           FontWeight="Bold"
                                           Foreground="{DynamicResource BrandRailForegroundBrush}"/>
                                <TextBlock Text="Portale Licenze"
                                           FontSize="11"
                                           Foreground="{DynamicResource BrandRailSecondaryForegroundBrush}"
                                           Margin="0,1,0,0"/>
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Grid.Row="2">
                            <TextBlock Text="Usa le tue credenziali per accedere ai download riservati."
                                       TextWrapping="Wrap"
                                       Foreground="{DynamicResource BrandRailSecondaryForegroundBrush}"
                                       FontSize="12"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Grid.Column="1"
                        Padding="26"
                        Background="Transparent">
                    <Border Background="{DynamicResource SurfaceBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource CornerRadiusLarge}"
                            Padding="22">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="10"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="16"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="12"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="18"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0"
                                       Text="Accedi"
                                       Style="{StaticResource Win11TextTitle}"/>

                            <Border Grid.Row="2"
                                    Background="{DynamicResource ErrorSurfaceBrush}"
                                    CornerRadius="{StaticResource CornerRadiusSmall}"
                                    Padding="10,6"
                                    Panel.ZIndex="100"
                                    Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Image Source="{DynamicResource IconError}"
                                           Width="14" Height="14"
                                           VerticalAlignment="Center"
                                           Margin="0,0,6,0"
                                           RenderOptions.BitmapScalingMode="HighQuality"/>
                                    <TextBlock Text="{Binding ErrorMessage}"
                                               Grid.Column="1"
                                               Foreground="{DynamicResource ErrorBrush}"
                                               TextWrapping="Wrap"
                                               FontSize="12"
                                               VerticalAlignment="Center"/>
                                </Grid>
                            </Border>

                            <TextBlock Grid.Row="4"
                                       Text="Utente"
                                       Style="{StaticResource Win11TextSecondary}"
                                       Margin="0,0,0,4"/>

                            <TextBox Grid.Row="5"
                                     Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource Win11TextBox}"
                                     Height="40"/>

                            <TextBlock Grid.Row="7"
                                       Text="Password"
                                       Style="{StaticResource Win11TextSecondary}"
                                       Margin="0,0,0,4"/>

                            <PasswordBox Grid.Row="8"
                                         x:Name="PasswordBox"
                                         Style="{StaticResource Win11PasswordBox}"
                                         Height="40"/>

                            <Grid Grid.Row="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <Button Grid.Column="0"
                                        Content="{Binding IsBusy, Converter={StaticResource BusyToTextConverter}, ConverterParameter='Accedi|Accesso in corso…'}"
                                        Command="{Binding LoginCommand}"
                                        IsDefault="True"
                                        HorizontalAlignment="Stretch"
                                        Height="40"
                                        Style="{StaticResource Win11AccentButton}"
                                        IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}, FallbackValue=True}"/>

                                <Button Grid.Column="2"
                                        Content="Annulla"
                                        Command="{Binding CancelCommand}"
                                        IsCancel="True"
                                        Height="40"
                                        Style="{StaticResource Win11Button}"
                                        IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}, FallbackValue=True}"/>
                            </Grid>
                        </Grid>
                    </Border>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>
