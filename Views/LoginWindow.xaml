<Window x:Class="KlevaDeploy.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Accesso Passepartout"
        Width="420" Height="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="{DynamicResource AppBackgroundBrush}"
        FontFamily="Segoe UI Variable, Segoe UI, sans-serif">

    <Border Margin="0" Background="Transparent">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>  <!-- Passepartout brand header -->
                <RowDefinition Height="*"/>     <!-- Form content -->
            </Grid.RowDefinitions>

            <!-- ══════════════════════════════════════════════════════
                 PASSEPARTOUT BRAND HEADER (logo fallback — pure XAML)
            ══════════════════════════════════════════════════════ -->
            <Border Grid.Row="0"
                    Background="#FFE30613"
                    CornerRadius="0"
                    Padding="20,16">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <!-- "P" monogram badge -->
                    <Border Background="White"
                            CornerRadius="6"
                            Width="40" Height="40"
                            VerticalAlignment="Center"
                            Margin="0,0,12,0">
                        <TextBlock Text="P"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   Foreground="#FFE30613"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <!-- Brand name -->
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Passepartout"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="White"/>
                        <TextBlock Text="Portale Licenze"
                                   FontSize="11"
                                   Foreground="#FFFFE0E0"
                                   Margin="0,1,0,0"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- ══════════════════════════════════════════════════════
                 FORM CONTENT
            ══════════════════════════════════════════════════════ -->
            <Border Grid.Row="1" Margin="32,24,32,32" Background="Transparent">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>  <!-- Title -->
                        <RowDefinition Height="12"/>    <!-- Spacer -->
                        <RowDefinition Height="Auto"/>  <!-- Error -->
                        <RowDefinition Height="16"/>    <!-- Spacer -->
                        <RowDefinition Height="Auto"/>  <!-- Username label -->
                        <RowDefinition Height="Auto"/>  <!-- Username input -->
                        <RowDefinition Height="12"/>    <!-- Spacer -->
                        <RowDefinition Height="Auto"/>  <!-- Password label -->
                        <RowDefinition Height="Auto"/>  <!-- Password input -->
                        <RowDefinition Height="16"/>    <!-- Spacer -->
                        <RowDefinition Height="Auto"/>  <!-- Button -->
                    </Grid.RowDefinitions>

                    <!-- Title -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal">
                        <Image Source="{DynamicResource IconLock}"
                               Width="18" Height="18"
                               VerticalAlignment="Center"
                               Margin="0,0,10,0"
                               RenderOptions.BitmapScalingMode="HighQuality"/>
                        <TextBlock Text="Accesso Passepartout"
                                   Style="{StaticResource Win11TextTitle}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <Border Grid.Row="2"
                            Background="#1ACF6679"
                            CornerRadius="{StaticResource CornerRadiusSmall}"
                            Padding="10,6"
                            Panel.ZIndex="100"
                            Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}">
                        <StackPanel Orientation="Horizontal">
                            <Image Source="{DynamicResource IconError}"
                                   Width="14" Height="14"
                                   VerticalAlignment="Center"
                                   Margin="0,0,6,0"
                                   RenderOptions.BitmapScalingMode="HighQuality"/>
                            <TextBlock Text="{Binding ErrorMessage}"
                                       Foreground="{DynamicResource ErrorBrush}"
                                       TextWrapping="Wrap"
                                       FontSize="12"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Username label -->
                    <TextBlock Grid.Row="4"
                               Text="Utente"
                               Style="{StaticResource Win11TextSecondary}"
                               Margin="0,0,0,4"/>

                    <!-- Username input -->
                    <TextBox Grid.Row="5"
                             Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource Win11TextBox}"
                             Height="36"/>

                    <!-- Password label -->
                    <TextBlock Grid.Row="7"
                               Text="Password"
                               Style="{StaticResource Win11TextSecondary}"
                               Margin="0,0,0,4"/>

                    <!-- Password input -->
                    <PasswordBox Grid.Row="8"
                                 x:Name="PasswordBox"
                                 Style="{StaticResource Win11PasswordBox}"
                                 Height="36"/>

                    <Button Grid.Row="10"
                            Content="{Binding IsBusy, Converter={StaticResource BusyToTextConverter}, ConverterParameter='Accedi|Accesso in corso…'}"
                            Command="{Binding LoginCommand}"
                            IsDefault="True"
                            HorizontalAlignment="Stretch"
                            Height="36"
                            Style="{StaticResource Win11AccentButton}"
                            IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}, FallbackValue=True}"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
