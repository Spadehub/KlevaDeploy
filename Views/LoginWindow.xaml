<Window x:Class="KlevaDeploy.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Accesso Portali"
        Width="700" Height="460"
        MinWidth="620" MinHeight="420"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="CanResize"
        ShowInTaskbar="False"
        Background="Transparent"
        FontFamily="Segoe UI Variable, Segoe UI, sans-serif"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">

    <Window.Resources>
        <Style x:Key="PortalListBox" TargetType="ListBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
        </Style>

        <Style x:Key="PortalListBoxItem" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment" Value="Stretch"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Card"
                                Background="{DynamicResource SurfaceBrush}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="{StaticResource CornerRadiusLarge}"
                                TextElement.Foreground="{DynamicResource TextPrimaryBrush}"
                                Padding="12,10">
                            <Grid>
                                <ContentPresenter/>
                                <Border x:Name="HoverOverlay"
                                        Background="{DynamicResource HoverBrush}"
                                        CornerRadius="{StaticResource CornerRadiusLarge}"
                                        Opacity="0"
                                        IsHitTestVisible="False"/>
                            </Grid>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="HoverOverlay"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="0.18"
                                                             Duration="0:0:0.12"
                                                             EasingFunction="{StaticResource EaseOut}"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="HoverOverlay"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="0"
                                                             Duration="0:0:0.16"
                                                             EasingFunction="{StaticResource EaseOut}"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>

                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Card" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                <Setter TargetName="Card" Property="Background" Value="{DynamicResource SurfaceElevatedBrush}"/>
                            </Trigger>

                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Card" Property="BorderBrush" Value="{DynamicResource FocusRingBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="40"
                            ResizeBorderThickness="6"
                            GlassFrameThickness="0,0,0,1"
                            UseAeroCaptionButtons="False"
                            CornerRadius="12"/>
    </shell:WindowChrome.WindowChrome>

    <Border x:Name="RootBorder"
            Background="{DynamicResource AppBackgroundBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="12"
            TextElement.Foreground="{DynamicResource TextPrimaryBrush}"
            ClipToBounds="True">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border x:Name="TitleBar"
                    Grid.Row="0"
                    Background="{DynamicResource SurfaceElevatedBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="0,0,0,1"
                    CornerRadius="12,12,0,0"
                    Padding="14,0,6,0"
                    >
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Image Source="{DynamicResource IconLock}"
                               Width="16" Height="16"
                               Margin="0,0,10,0"
                               VerticalAlignment="Center"
                               RenderOptions.BitmapScalingMode="HighQuality"/>
                        <TextBlock Text="{Binding SelectedPortal.Name, TargetNullValue=Accesso Portali, FallbackValue=Accesso Portali}"
                                   Style="{StaticResource Win11TextBody}"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <Button x:Name="BtnClose"
                            Grid.Column="1"
                            Content="✕"
                            Width="38"
                            Height="28"
                            Padding="0"
                            Style="{StaticResource Win11CloseButton}"
                            VerticalAlignment="Center"
                            Command="{Binding CancelCommand}"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True"
                            IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}, FallbackValue=True}"/>
                </Grid>
            </Border>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="260"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Background="{DynamicResource SurfaceElevatedBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="0,0,1,0"
                        CornerRadius="0,0,0,12"
                        Padding="18,16">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="12"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="12"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0"
                                   Text="Portali"
                                   Style="{StaticResource Win11TextBody}"
                                   FontWeight="SemiBold"/>

                        <ListBox Grid.Row="2"
                                 ItemsSource="{Binding Portals}"
                                 SelectedItem="{Binding SelectedPortal, Mode=TwoWay}"
                                 Style="{StaticResource PortalListBox}">
                            <ListBox.Resources>
                                <Style TargetType="ListBoxItem" BasedOn="{StaticResource PortalListBoxItem}"/>
                            </ListBox.Resources>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="4"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <TextBlock Text="{Binding Name}"
                                                   FontWeight="SemiBold"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Grid.Row="2"
                                                   Text="{Binding HomeUrl}"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <Grid Grid.Row="4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Button Content="Gestisci"
                                    Command="{Binding GestisciPortaliCommand}"
                                    Style="{StaticResource Win11Button}"
                                    Height="34"
                                    Padding="12,0"/>

                            <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="10,0,0,0">
                                <Button Command="{Binding ModificaPortaleCommand}"
                                        ToolTip="Modifica"
                                        Style="{StaticResource Win11IconButton}"
                                        Width="34" Height="34"
                                        Margin="0,0,6,0">
                                    <Image Source="{DynamicResource IconEdit}"
                                           Width="16" Height="16"
                                           RenderOptions.BitmapScalingMode="HighQuality"/>
                                </Button>
                                <Button Command="{Binding EliminaPortaleCommand}"
                                        ToolTip="Elimina"
                                        Style="{StaticResource Win11IconButton}"
                                        Width="34" Height="34">
                                    <Image Source="{DynamicResource IconDelete}"
                                           Width="16" Height="16"
                                           RenderOptions.BitmapScalingMode="HighQuality"/>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>

                <Border Grid.Column="1"
                        Padding="26"
                        Background="Transparent">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="14"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0">
                            <TextBlock Text="{Binding SelectedPortal.Name, FallbackValue=Seleziona un portale, TargetNullValue=Seleziona un portale}"
                                       Style="{StaticResource Win11TextTitle}"
                                       FontSize="24"/>
                            <TextBlock Text="Accedi"
                                       Style="{StaticResource Win11TextSecondary}"
                                       FontSize="12"
                                       Margin="0,4,0,0"
                                       Visibility="{Binding IsSelectedPortalLoggedIn, Converter={StaticResource InverseBoolToVisibility}, FallbackValue=Visible}"/>
                            <TextBlock Text="{Binding LoggedInAsText}"
                                       Style="{StaticResource Win11TextSecondary}"
                                       FontSize="12"
                                       Margin="0,4,0,0"
                                       Visibility="{Binding IsSelectedPortalLoggedIn, Converter={StaticResource BoolToVisibility}, FallbackValue=Collapsed}"/>
                        </StackPanel>

                        <ScrollViewer Grid.Row="2"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                            <Border Style="{StaticResource Win11Card}"
                                    Padding="22"
                                    CornerRadius="{StaticResource CornerRadiusLarge}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="14"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="12"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <Border Grid.Row="0"
                                            Background="{DynamicResource ErrorSurfaceBrush}"
                                            CornerRadius="{StaticResource CornerRadiusSmall}"
                                            Padding="10,6"
                                            Panel.ZIndex="100"
                                            Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Image Source="{DynamicResource IconError}"
                                                   Width="14" Height="14"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,6,0"
                                                   RenderOptions.BitmapScalingMode="HighQuality"/>
                                            <TextBlock Text="{Binding ErrorMessage}"
                                                       Grid.Column="1"
                                                       Foreground="{DynamicResource ErrorBrush}"
                                                       TextWrapping="Wrap"
                                                       FontSize="12"
                                                       VerticalAlignment="Center"/>
                                        </Grid>
                                    </Border>

                                    <Grid Grid.Row="2">
                                        <Grid Visibility="{Binding IsSelectedPortalLoggedIn, Converter={StaticResource InverseBoolToVisibility}, FallbackValue=Visible}">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="12"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <TextBlock Grid.Row="0"
                                                       Text="Utente"
                                                       Style="{StaticResource Win11TextSecondary}"
                                                       Margin="0,0,0,4"/>
                                            <TextBox Grid.Row="1"
                                                     Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                                                     Style="{StaticResource Win11TextBox}"
                                                     Height="40"/>

                                            <TextBlock Grid.Row="3"
                                                       Text="Password"
                                                       Style="{StaticResource Win11TextSecondary}"
                                                       Margin="0,0,0,4"/>
                                            <Grid Grid.Row="4">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <TextBox Grid.Column="0"
                                                         Text="{Binding Password, UpdateSourceTrigger=PropertyChanged}"
                                                         Height="40">
                                                    <TextBox.Style>
                                                        <Style TargetType="TextBox" BasedOn="{StaticResource Win11TextBox}">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsPasswordVisible}" Value="True">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBox.Style>
                                                </TextBox>

                                                <PasswordBox Grid.Column="0"
                                                             x:Name="PasswordBox"
                                                             Height="40"
                                                             IsVisibleChanged="OnPasswordVisibilityChanged">
                                                    <PasswordBox.Style>
                                                        <Style TargetType="PasswordBox" BasedOn="{StaticResource Win11PasswordBox}">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsPasswordVisible}" Value="True">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </PasswordBox.Style>
                                                </PasswordBox>

                                                <Button Grid.Column="1"
                                                        Margin="10,0,0,0"
                                                        Width="36"
                                                        Height="36"
                                                        Style="{StaticResource Win11IconButton}"
                                                        Click="OnTogglePasswordVisibility"
                                                        ToolTip="Mostra o nascondi password"
                                                        AutomationProperties.Name="Mostra o nascondi password">
                                                    <Image Width="18"
                                                           Height="18"
                                                           Stretch="Uniform">
                                                        <Image.Style>
                                                            <Style TargetType="Image">
                                                                <Setter Property="Source" Value="{DynamicResource IconEyeOpen}"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsPasswordVisible}" Value="True">
                                                                        <Setter Property="Source" Value="{DynamicResource IconEyeClosed}"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Image.Style>
                                                    </Image>
                                                </Button>
                                            </Grid>
                                        </Grid>

                                        <StackPanel Visibility="{Binding IsSelectedPortalLoggedIn, Converter={StaticResource BoolToVisibility}, FallbackValue=Collapsed}">
                                            <TextBlock Text="{Binding LoggedInAsText}"
                                                       FontWeight="SemiBold"/>
                                        </StackPanel>
                                    </Grid>

                                    <Grid Grid.Row="5"
                                          Margin="0,10,0,0">
                                        <Grid Visibility="{Binding IsSelectedPortalLoggedIn, Converter={StaticResource InverseBoolToVisibility}, FallbackValue=Visible}">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="12"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <Button Grid.Column="0"
                                                    Content="{Binding IsBusy, Converter={StaticResource BusyToTextConverter}, ConverterParameter='Accedi|Accesso in corso…'}"
                                                    Command="{Binding LoginCommand}"
                                                    IsDefault="True"
                                                    HorizontalAlignment="Stretch"
                                                    Height="40"
                                                    Style="{StaticResource Win11AccentButton}"
                                                    IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}, FallbackValue=True}"/>

                                            <Button Grid.Column="2"
                                                    Content="Annulla"
                                                    Command="{Binding CancelCommand}"
                                                    IsCancel="True"
                                                    Height="40"
                                                    MinWidth="120"
                                                    Style="{StaticResource Win11Button}"
                                                    IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}, FallbackValue=True}"/>
                                        </Grid>

                                        <Grid Visibility="{Binding IsSelectedPortalLoggedIn, Converter={StaticResource BoolToVisibility}, FallbackValue=Collapsed}">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="12"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <Button Content="Logout"
                                                    Command="{Binding LogoutCommand}"
                                                    Height="40"
                                                    MinWidth="120"
                                                    Style="{StaticResource Win11DangerButton}"
                                                    IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}, FallbackValue=True}"/>

                                            <Button Grid.Column="2"
                                                    Content="Chiudi"
                                                    Command="{Binding CancelCommand}"
                                                    Height="40"
                                                    MinWidth="120"
                                                    Style="{StaticResource Win11Button}"
                                                    IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}, FallbackValue=True}"/>
                                        </Grid>
                                    </Grid>
                                </Grid>
                            </Border>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>
